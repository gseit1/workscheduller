# Development environment variables example
# Copy this file to .env and .env.production and update with your values

# Environment (development, production, test)
NODE_ENV=development

# Backend API URL
# Development: http://localhost:3001/api
# Production: https://your-backend-app.onrender.com/api
VUE_APP_API_URL=http://localhost:3001/api

# Application Title
VUE_APP_TITLE=Job Analytics Pro
