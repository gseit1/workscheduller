{"ast":null,"code":"import { computed } from 'vue';\nimport { useToast } from 'vue-toastification';\nimport { useCustomizationStore } from '../stores/customization';\nexport default {\n  __name: 'Settings',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const toast = useToast();\n    const customizationStore = useCustomizationStore();\n\n    // Computed properties for two-way binding\n    const settings = computed({\n      get: () => ({\n        theme: customizationStore.theme,\n        compactMode: customizationStore.compactMode,\n        goalReminders: customizationStore.goalReminders,\n        scheduleAlerts: customizationStore.scheduleAlerts,\n        weeklyReports: customizationStore.weeklyReports\n      }),\n      set: value => {\n        if (value.theme !== undefined) customizationStore.setTheme(value.theme);\n        if (value.compactMode !== undefined) customizationStore.setCompactMode(value.compactMode);\n        if (value.goalReminders !== undefined) customizationStore.setGoalReminders(value.goalReminders);\n        if (value.scheduleAlerts !== undefined) customizationStore.setScheduleAlerts(value.scheduleAlerts);\n        if (value.weeklyReports !== undefined) customizationStore.setWeeklyReports(value.weeklyReports);\n      }\n    });\n    const saveSettings = () => {\n      customizationStore.saveSettings();\n      toast.success('Settings saved successfully!');\n    };\n    const exportData = async () => {\n      try {\n        toast.info('Preparing your data export...');\n\n        // In a real implementation, you would fetch all user data from API\n        const userData = {\n          exportDate: new Date().toISOString(),\n          settings: settings.value,\n          message: 'Data export functionality to be implemented'\n        };\n        const dataStr = JSON.stringify(userData, null, 2);\n        const dataBlob = new Blob([dataStr], {\n          type: 'application/json'\n        });\n        const url = URL.createObjectURL(dataBlob);\n        const link = document.createElement('a');\n        link.href = url;\n        link.download = `analytics-data-${new Date().toISOString().split('T')[0]}.json`;\n        document.body.appendChild(link);\n        link.click();\n        document.body.removeChild(link);\n        URL.revokeObjectURL(url);\n        toast.success('Data exported successfully!');\n      } catch (error) {\n        toast.error('Failed to export data');\n      }\n    };\n    const clearCache = () => {\n      try {\n        localStorage.removeItem('appCache');\n        sessionStorage.clear();\n        toast.success('Cache cleared successfully!');\n      } catch (error) {\n        toast.error('Failed to clear cache');\n      }\n    };\n    const deleteAccount = () => {\n      if (confirm('Are you sure you want to delete your account? This action cannot be undone.')) {\n        toast.error('Account deletion feature not implemented yet');\n        // TODO: Implement account deletion via API\n      }\n    };\n    const __returned__ = {\n      toast,\n      customizationStore,\n      settings,\n      saveSettings,\n      exportData,\n      clearCache,\n      deleteAccount,\n      computed,\n      get useToast() {\n        return useToast;\n      },\n      get useCustomizationStore() {\n        return useCustomizationStore;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["computed","useToast","useCustomizationStore","toast","customizationStore","settings","get","theme","compactMode","goalReminders","scheduleAlerts","weeklyReports","set","value","undefined","setTheme","setCompactMode","setGoalReminders","setScheduleAlerts","setWeeklyReports","saveSettings","success","exportData","info","userData","exportDate","Date","toISOString","message","dataStr","JSON","stringify","dataBlob","Blob","type","url","URL","createObjectURL","link","document","createElement","href","download","split","body","appendChild","click","removeChild","revokeObjectURL","error","clearCache","localStorage","removeItem","sessionStorage","clear","deleteAccount","confirm"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Settings.vue"],"sourcesContent":["<template>\r\n  <div class=\"settings-page\">\r\n    <div class=\"page-header\">\r\n      <h1>Settings</h1>\r\n      <p>Customize your application preferences</p>\r\n    </div>\r\n\r\n    <div class=\"settings-content\">\r\n      <div class=\"settings-card\">\r\n        <h3>Appearance</h3>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Theme</h4>\r\n            <p>Choose your preferred color scheme</p>\r\n          </div>\r\n          <select v-model=\"theme\" @change=\"onThemeChange\" class=\"form-select\">\r\n            <option value=\"light\">Light</option>\r\n            <option value=\"dark\">Dark</option>\r\n            <option value=\"auto\">Auto</option>\r\n          </select>\r\n        </div>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Compact Mode</h4>\r\n            <p>Reduce spacing for a denser layout</p>\r\n          </div>\r\n          <label class=\"toggle\">\r\n            <input v-model=\"compactMode\" @change=\"onCompactModeChange\" type=\"checkbox\" />\r\n            <span class=\"toggle-slider\"></span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"settings-card\">\r\n        <h3>Notifications</h3>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Goal Reminders</h4>\r\n            <p>Get notified about upcoming goal deadlines</p>\r\n          </div>\r\n          <label class=\"toggle\">\r\n            <input v-model=\"goalReminders\" @change=\"onGoalRemindersChange\" type=\"checkbox\" />\r\n            <span class=\"toggle-slider\"></span>\r\n          </label>\r\n        </div>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Work Schedule Alerts</h4>\r\n            <p>Receive alerts for scheduled work days</p>\r\n          </div>\r\n          <label class=\"toggle\">\r\n            <input v-model=\"scheduleAlerts\" @change=\"onScheduleAlertsChange\" type=\"checkbox\" />\r\n            <span class=\"toggle-slider\"></span>\r\n          </label>\r\n        </div>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Weekly Reports</h4>\r\n            <p>Get weekly summary of your work and earnings</p>\r\n          </div>\r\n          <label class=\"toggle\">\r\n            <input v-model=\"weeklyReports\" @change=\"onWeeklyReportsChange\" type=\"checkbox\" />\r\n            <span class=\"toggle-slider\"></span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"settings-card\">\r\n        <h3>Data & Privacy</h3>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Export Data</h4>\r\n            <p>Download all your data in JSON format</p>\r\n          </div>\r\n          <button @click=\"exportData\" class=\"btn btn-secondary\">\r\n            <i class=\"bi bi-download\"></i>\r\n            Export\r\n          </button>\r\n        </div>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Clear Cache</h4>\r\n            <p>Clear application cache and temporary data</p>\r\n          </div>\r\n          <button @click=\"clearCache\" class=\"btn btn-outline-secondary\">\r\n            <i class=\"bi bi-trash\"></i>\r\n            Clear\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"settings-card danger-zone\">\r\n        <h3>Danger Zone</h3>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Delete Account</h4>\r\n            <p>Permanently delete your account and all data</p>\r\n          </div>\r\n          <button @click=\"deleteAccount\" class=\"btn btn-danger\">\r\n            <i class=\"bi bi-exclamation-triangle\"></i>\r\n            Delete Account\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"settings-actions\">\r\n        <button @click=\"saveSettings\" class=\"btn btn-primary btn-lg\">\r\n          <i class=\"bi bi-check-circle\"></i>\r\n          Save Settings\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { computed } from 'vue'\r\nimport { useToast } from 'vue-toastification'\r\nimport { useCustomizationStore } from '../stores/customization'\r\n\r\nconst toast = useToast()\r\nconst customizationStore = useCustomizationStore()\r\n\r\n// Computed properties for two-way binding\r\nconst settings = computed({\r\n  get: () => ({\r\n    theme: customizationStore.theme,\r\n    compactMode: customizationStore.compactMode,\r\n    goalReminders: customizationStore.goalReminders,\r\n    scheduleAlerts: customizationStore.scheduleAlerts,\r\n    weeklyReports: customizationStore.weeklyReports\r\n  }),\r\n  set: (value) => {\r\n    if (value.theme !== undefined) customizationStore.setTheme(value.theme)\r\n    if (value.compactMode !== undefined) customizationStore.setCompactMode(value.compactMode)\r\n    if (value.goalReminders !== undefined) customizationStore.setGoalReminders(value.goalReminders)\r\n    if (value.scheduleAlerts !== undefined) customizationStore.setScheduleAlerts(value.scheduleAlerts)\r\n    if (value.weeklyReports !== undefined) customizationStore.setWeeklyReports(value.weeklyReports)\r\n  }\r\n})\r\n\r\nconst saveSettings = () => {\r\n  customizationStore.saveSettings()\r\n  toast.success('Settings saved successfully!')\r\n}\r\n\r\nconst exportData = async () => {\r\n  try {\r\n    toast.info('Preparing your data export...')\r\n    \r\n    // In a real implementation, you would fetch all user data from API\r\n    const userData = {\r\n      exportDate: new Date().toISOString(),\r\n      settings: settings.value,\r\n      message: 'Data export functionality to be implemented'\r\n    }\r\n    \r\n    const dataStr = JSON.stringify(userData, null, 2)\r\n    const dataBlob = new Blob([dataStr], { type: 'application/json' })\r\n    const url = URL.createObjectURL(dataBlob)\r\n    \r\n    const link = document.createElement('a')\r\n    link.href = url\r\n    link.download = `analytics-data-${new Date().toISOString().split('T')[0]}.json`\r\n    document.body.appendChild(link)\r\n    link.click()\r\n    document.body.removeChild(link)\r\n    URL.revokeObjectURL(url)\r\n    \r\n    toast.success('Data exported successfully!')\r\n  } catch (error) {\r\n    toast.error('Failed to export data')\r\n  }\r\n}\r\n\r\nconst clearCache = () => {\r\n  try {\r\n    localStorage.removeItem('appCache')\r\n    sessionStorage.clear()\r\n    toast.success('Cache cleared successfully!')\r\n  } catch (error) {\r\n    toast.error('Failed to clear cache')\r\n  }\r\n}\r\n\r\nconst deleteAccount = () => {\r\n  if (confirm('Are you sure you want to delete your account? This action cannot be undone.')) {\r\n    toast.error('Account deletion feature not implemented yet')\r\n    // TODO: Implement account deletion via API\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.settings-page {\r\n  max-width: 900px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  margin-bottom: var(--spacing-xl);\r\n  \r\n  h1 {\r\n    font-size: 2rem;\r\n    font-weight: 800;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-xs);\r\n  }\r\n  \r\n  p {\r\n    color: var(--text-secondary);\r\n  }\r\n}\r\n\r\n.settings-content {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--spacing-lg);\r\n}\r\n\r\n.settings-card {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-xl);\r\n  box-shadow: var(--shadow-sm);\r\n  \r\n  h3 {\r\n    font-size: 1.25rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-lg);\r\n    padding-bottom: var(--spacing-sm);\r\n    border-bottom: 2px solid var(--border-color);\r\n  }\r\n  \r\n  &.danger-zone {\r\n    border: 2px solid var(--danger);\r\n    \r\n    h3 {\r\n      color: var(--danger);\r\n      border-color: var(--danger);\r\n    }\r\n  }\r\n}\r\n\r\n.setting-item {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: var(--spacing-lg);\r\n  background: var(--bg-secondary);\r\n  border-radius: var(--radius-md);\r\n  margin-bottom: var(--spacing-md);\r\n  \r\n  &:last-child {\r\n    margin-bottom: 0;\r\n  }\r\n  \r\n  .setting-info {\r\n    flex: 1;\r\n    \r\n    h4 {\r\n      font-size: 1rem;\r\n      font-weight: 600;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      font-size: 0.875rem;\r\n      color: var(--text-secondary);\r\n      margin: 0;\r\n    }\r\n  }\r\n  \r\n  .form-select {\r\n    width: 150px;\r\n  }\r\n}\r\n\r\n.toggle {\r\n  position: relative;\r\n  display: inline-block;\r\n  width: 60px;\r\n  height: 34px;\r\n  \r\n  input {\r\n    opacity: 0;\r\n    width: 0;\r\n    height: 0;\r\n    \r\n    &:checked + .toggle-slider {\r\n      background: var(--primary);\r\n      \r\n      &:before {\r\n        transform: translateX(26px);\r\n      }\r\n    }\r\n  }\r\n  \r\n  .toggle-slider {\r\n    position: absolute;\r\n    cursor: pointer;\r\n    top: 0;\r\n    left: 0;\r\n    right: 0;\r\n    bottom: 0;\r\n    background: var(--bg-secondary);\r\n    border: 2px solid var(--border-color);\r\n    border-radius: 34px;\r\n    transition: 0.3s;\r\n    \r\n    &:before {\r\n      content: '';\r\n      position: absolute;\r\n      height: 24px;\r\n      width: 24px;\r\n      left: 3px;\r\n      bottom: 3px;\r\n      background: white;\r\n      border-radius: 50%;\r\n      transition: 0.3s;\r\n      box-shadow: var(--shadow-sm);\r\n    }\r\n  }\r\n}\r\n\r\n.settings-actions {\r\n  padding-top: var(--spacing-lg);\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .page-header h1 {\r\n    font-size: 1.5rem;\r\n  }\r\n  \r\n  .settings-card {\r\n    padding: var(--spacing-lg);\r\n  }\r\n  \r\n  .setting-item {\r\n    flex-direction: column;\r\n    align-items: flex-start;\r\n    gap: var(--spacing-md);\r\n    \r\n    .form-select {\r\n      width: 100%;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA4HA,SAASA,QAAQ,QAAQ,KAAK;AAC9B,SAASC,QAAQ,QAAQ,oBAAoB;AAC7C,SAASC,qBAAqB,QAAQ,yBAAyB;;;;;;;IAE/D,MAAMC,KAAK,GAAGF,QAAQ,CAAC,CAAC;IACxB,MAAMG,kBAAkB,GAAGF,qBAAqB,CAAC,CAAC;;IAElD;IACA,MAAMG,QAAQ,GAAGL,QAAQ,CAAC;MACxBM,GAAG,EAAEA,CAAA,MAAO;QACVC,KAAK,EAAEH,kBAAkB,CAACG,KAAK;QAC/BC,WAAW,EAAEJ,kBAAkB,CAACI,WAAW;QAC3CC,aAAa,EAAEL,kBAAkB,CAACK,aAAa;QAC/CC,cAAc,EAAEN,kBAAkB,CAACM,cAAc;QACjDC,aAAa,EAAEP,kBAAkB,CAACO;MACpC,CAAC,CAAC;MACFC,GAAG,EAAGC,KAAK,IAAK;QACd,IAAIA,KAAK,CAACN,KAAK,KAAKO,SAAS,EAAEV,kBAAkB,CAACW,QAAQ,CAACF,KAAK,CAACN,KAAK,CAAC;QACvE,IAAIM,KAAK,CAACL,WAAW,KAAKM,SAAS,EAAEV,kBAAkB,CAACY,cAAc,CAACH,KAAK,CAACL,WAAW,CAAC;QACzF,IAAIK,KAAK,CAACJ,aAAa,KAAKK,SAAS,EAAEV,kBAAkB,CAACa,gBAAgB,CAACJ,KAAK,CAACJ,aAAa,CAAC;QAC/F,IAAII,KAAK,CAACH,cAAc,KAAKI,SAAS,EAAEV,kBAAkB,CAACc,iBAAiB,CAACL,KAAK,CAACH,cAAc,CAAC;QAClG,IAAIG,KAAK,CAACF,aAAa,KAAKG,SAAS,EAAEV,kBAAkB,CAACe,gBAAgB,CAACN,KAAK,CAACF,aAAa,CAAC;MACjG;IACF,CAAC,CAAC;IAEF,MAAMS,YAAY,GAAGA,CAAA,KAAM;MACzBhB,kBAAkB,CAACgB,YAAY,CAAC,CAAC;MACjCjB,KAAK,CAACkB,OAAO,CAAC,8BAA8B,CAAC;IAC/C,CAAC;IAED,MAAMC,UAAU,GAAG,MAAAA,CAAA,KAAY;MAC7B,IAAI;QACFnB,KAAK,CAACoB,IAAI,CAAC,+BAA+B,CAAC;;QAE3C;QACA,MAAMC,QAAQ,GAAG;UACfC,UAAU,EAAE,IAAIC,IAAI,CAAC,CAAC,CAACC,WAAW,CAAC,CAAC;UACpCtB,QAAQ,EAAEA,QAAQ,CAACQ,KAAK;UACxBe,OAAO,EAAE;QACX,CAAC;QAED,MAAMC,OAAO,GAAGC,IAAI,CAACC,SAAS,