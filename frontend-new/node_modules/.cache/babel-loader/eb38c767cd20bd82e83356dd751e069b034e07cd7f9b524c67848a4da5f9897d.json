{"ast":null,"code":"import { ref, computed, onMounted } from 'vue';\nimport { format, startOfWeek, addDays, addWeeks, subWeeks, isToday, isBefore, startOfDay } from 'date-fns';\nimport api from '../services/api';\nimport { useToast } from 'vue-toastification';\nexport default {\n  __name: 'Schedule',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const toast = useToast();\n    const currentWeekStart = ref(startOfWeek(new Date(), {\n      weekStartsOn: 0\n    }));\n    const scheduledDays = ref([]);\n    const showAddModal = ref(false);\n    const loading = ref(false);\n    const fetchScheduledDays = async () => {\n      try {\n        loading.value = true;\n        const startDate = format(currentWeekStart.value, 'yyyy-MM-dd');\n        const endDate = format(addDays(currentWeekStart.value, 6), 'yyyy-MM-dd');\n        const response = await api.get('/calendar/events', {\n          params: {\n            startDate,\n            endDate\n          }\n        });\n        scheduledDays.value = response.data.map(event => format(new Date(event.event_date), 'yyyy-MM-dd'));\n      } catch (error) {\n        console.error('Error fetching scheduled days:', error);\n        toast.error('Failed to load schedule');\n      } finally {\n        loading.value = false;\n      }\n    };\n    const weekRange = computed(() => {\n      const start = currentWeekStart.value;\n      const end = addDays(start, 6);\n      return `${format(start, 'MMM d')} - ${format(end, 'MMM d, yyyy')}`;\n    });\n    const weekDays = computed(() => {\n      const days = [];\n      const today = startOfDay(new Date());\n      for (let i = 0; i < 7; i++) {\n        const date = addDays(currentWeekStart.value, i);\n        const dateStr = format(date, 'yyyy-MM-dd');\n        days.push({\n          date: date.toISOString(),\n          dateStr: format(date, 'MMM d'),\n          dayName: format(date, 'EEEE'),\n          isToday: isToday(date),\n          isPast: isBefore(date, today),\n          isScheduled: scheduledDays.value.includes(dateStr)\n        });\n      }\n      return days;\n    });\n    const upcomingDays = computed(() => {\n      const today = startOfDay(new Date());\n      return scheduledDays.value.map(dateStr => {\n        const date = new Date(dateStr);\n        return {\n          date: dateStr,\n          dateStr: format(date, 'MMM d, yyyy'),\n          dayName: format(date, 'EEEE'),\n          rawDate: date\n        };\n      }).filter(item => !isBefore(item.rawDate, today)).sort((a, b) => a.rawDate - b.rawDate).slice(0, 5);\n    });\n    const previousWeek = () => {\n      currentWeekStart.value = subWeeks(currentWeekStart.value, 1);\n      fetchScheduledDays();\n    };\n    const nextWeek = () => {\n      currentWeekStart.value = addWeeks(currentWeekStart.value, 1);\n      fetchScheduledDays();\n    };\n    const scheduleDay = async day => {\n      try {\n        const dateStr = format(new Date(day.date), 'yyyy-MM-dd');\n        await api.post('/work/schedule', {\n          date: dateStr,\n          hours: 8,\n          notes: 'Scheduled work day'\n        });\n        toast.success('Day scheduled successfully');\n        fetchScheduledDays();\n      } catch (error) {\n        console.error('Error scheduling day:', error);\n        toast.error('Failed to schedule day');\n      }\n    };\n    const removeSchedule = async day => {\n      try {\n        const dateStr = format(new Date(day.date), 'yyyy-MM-dd');\n        await api.delete(`/work/schedule/${dateStr}`);\n        toast.success('Schedule removed successfully');\n        fetchScheduledDays();\n      } catch (error) {\n        console.error('Error removing schedule:', error);\n        toast.error('Failed to remove schedule');\n      }\n    };\n    onMounted(() => {\n      fetchScheduledDays();\n    });\n    const __returned__ = {\n      toast,\n      currentWeekStart,\n      scheduledDays,\n      showAddModal,\n      loading,\n      fetchScheduledDays,\n      weekRange,\n      weekDays,\n      upcomingDays,\n      previousWeek,\n      nextWeek,\n      scheduleDay,\n      removeSchedule,\n      ref,\n      computed,\n      onMounted,\n      get format() {\n        return format;\n      },\n      get startOfWeek() {\n        return startOfWeek;\n      },\n      get addDays() {\n        return addDays;\n      },\n      get addWeeks() {\n        return addWeeks;\n      },\n      get subWeeks() {\n        return subWeeks;\n      },\n      get isToday() {\n        return isToday;\n      },\n      get isBefore() {\n        return isBefore;\n      },\n      get startOfDay() {\n        return startOfDay;\n      },\n      get api() {\n        return api;\n      },\n      get useToast() {\n        return useToast;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","format","startOfWeek","addDays","addWeeks","subWeeks","isToday","isBefore","startOfDay","api","useToast","toast","currentWeekStart","Date","weekStartsOn","scheduledDays","showAddModal","loading","fetchScheduledDays","value","startDate","endDate","response","get","params","data","map","event","event_date","error","console","weekRange","start","end","weekDays","days","today","i","date","dateStr","push","toISOString","dayName","isPast","isScheduled","includes","upcomingDays","rawDate","filter","item","sort","a","b","slice","previousWeek","nextWeek","scheduleDay","day","post","hours","notes","success","removeSchedule","delete"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Schedule.vue"],"sourcesContent":["<template>\r\n  <div class=\"schedule-page\">\r\n    <div class=\"page-header\">\r\n      <div class=\"header-content\">\r\n        <h1>Schedule</h1>\r\n        <p>Manage your work schedule and planned days</p>\r\n      </div>\r\n      <div class=\"header-actions\">\r\n        <button class=\"btn btn-primary\" @click=\"showAddModal = true\">\r\n          <i class=\"bi bi-plus-circle\"></i>\r\n          <span>Add Day</span>\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"schedule-content\">\r\n      <!-- Week View -->\r\n      <div class=\"week-selector\">\r\n        <button @click=\"previousWeek\" class=\"btn btn-icon\">\r\n          <i class=\"bi bi-chevron-left\"></i>\r\n        </button>\r\n        <h2>{{ weekRange }}</h2>\r\n        <button @click=\"nextWeek\" class=\"btn btn-icon\">\r\n          <i class=\"bi bi-chevron-right\"></i>\r\n        </button>\r\n      </div>\r\n\r\n      <div class=\"week-grid\">\r\n        <div \r\n          v-for=\"day in weekDays\" \r\n          :key=\"day.date\"\r\n          :class=\"['day-card', {\r\n            'today': day.isToday,\r\n            'scheduled': day.isScheduled,\r\n            'past': day.isPast\r\n          }]\"\r\n        >\r\n          <div class=\"day-header\">\r\n            <div class=\"day-name\">{{ day.dayName }}</div>\r\n            <div class=\"day-date\">{{ day.dateStr }}</div>\r\n          </div>\r\n          <div class=\"day-content\">\r\n            <div v-if=\"day.isScheduled\" class=\"scheduled-info\">\r\n              <i class=\"bi bi-calendar-check\"></i>\r\n              <span>Scheduled</span>\r\n            </div>\r\n            <div v-else class=\"no-schedule\">\r\n              <i class=\"bi bi-calendar-x\"></i>\r\n              <span>Not scheduled</span>\r\n            </div>\r\n          </div>\r\n          <div class=\"day-actions\">\r\n            <button \r\n              v-if=\"!day.isScheduled && !day.isPast\" \r\n              @click=\"scheduleDay(day)\"\r\n              class=\"btn btn-sm btn-primary\"\r\n            >\r\n              Schedule\r\n            </button>\r\n            <button \r\n              v-else-if=\"day.isScheduled && !day.isPast\" \r\n              @click=\"removeSchedule(day)\"\r\n              class=\"btn btn-sm btn-danger\"\r\n            >\r\n              Remove\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Upcoming Scheduled Days -->\r\n      <div class=\"upcoming-section\">\r\n        <h3>Upcoming Scheduled Days</h3>\r\n        <div class=\"upcoming-list\">\r\n          <div v-for=\"item in upcomingDays\" :key=\"item.date\" class=\"upcoming-item\">\r\n            <div class=\"upcoming-date\">\r\n              <i class=\"bi bi-calendar-event\"></i>\r\n              <span>{{ item.dateStr }}</span>\r\n            </div>\r\n            <div class=\"upcoming-day\">{{ item.dayName }}</div>\r\n            <button @click=\"removeSchedule(item)\" class=\"btn btn-sm btn-outline-danger\">\r\n              <i class=\"bi bi-trash\"></i>\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\nimport { format, startOfWeek, addDays, addWeeks, subWeeks, isToday, isBefore, startOfDay } from 'date-fns'\r\nimport api from '../services/api'\r\nimport { useToast } from 'vue-toastification'\r\n\r\nconst toast = useToast()\r\nconst currentWeekStart = ref(startOfWeek(new Date(), { weekStartsOn: 0 }))\r\nconst scheduledDays = ref([])\r\nconst showAddModal = ref(false)\r\nconst loading = ref(false)\r\n\r\nconst fetchScheduledDays = async () => {\r\n  try {\r\n    loading.value = true\r\n    const startDate = format(currentWeekStart.value, 'yyyy-MM-dd')\r\n    const endDate = format(addDays(currentWeekStart.value, 6), 'yyyy-MM-dd')\r\n    \r\n    const response = await api.get('/calendar/events', {\r\n      params: { startDate, endDate }\r\n    })\r\n    \r\n    scheduledDays.value = response.data.map(event => format(new Date(event.event_date), 'yyyy-MM-dd'))\r\n  } catch (error) {\r\n    console.error('Error fetching scheduled days:', error)\r\n    toast.error('Failed to load schedule')\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\nconst weekRange = computed(() => {\r\n  const start = currentWeekStart.value\r\n  const end = addDays(start, 6)\r\n  return `${format(start, 'MMM d')} - ${format(end, 'MMM d, yyyy')}`\r\n})\r\n\r\nconst weekDays = computed(() => {\r\n  const days = []\r\n  const today = startOfDay(new Date())\r\n  \r\n  for (let i = 0; i < 7; i++) {\r\n    const date = addDays(currentWeekStart.value, i)\r\n    const dateStr = format(date, 'yyyy-MM-dd')\r\n    \r\n    days.push({\r\n      date: date.toISOString(),\r\n      dateStr: format(date, 'MMM d'),\r\n      dayName: format(date, 'EEEE'),\r\n      isToday: isToday(date),\r\n      isPast: isBefore(date, today),\r\n      isScheduled: scheduledDays.value.includes(dateStr)\r\n    })\r\n  }\r\n  \r\n  return days\r\n})\r\n\r\nconst upcomingDays = computed(() => {\r\n  const today = startOfDay(new Date())\r\n  return scheduledDays.value\r\n    .map(dateStr => {\r\n      const date = new Date(dateStr)\r\n      return {\r\n        date: dateStr,\r\n        dateStr: format(date, 'MMM d, yyyy'),\r\n        dayName: format(date, 'EEEE'),\r\n        rawDate: date\r\n      }\r\n    })\r\n    .filter(item => !isBefore(item.rawDate, today))\r\n    .sort((a, b) => a.rawDate - b.rawDate)\r\n    .slice(0, 5)\r\n})\r\n\r\nconst previousWeek = () => {\r\n  currentWeekStart.value = subWeeks(currentWeekStart.value, 1)\r\n  fetchScheduledDays()\r\n}\r\n\r\nconst nextWeek = () => {\r\n  currentWeekStart.value = addWeeks(currentWeekStart.value, 1)\r\n  fetchScheduledDays()\r\n}\r\n\r\nconst scheduleDay = async (day) => {\r\n  try {\r\n    const dateStr = format(new Date(day.date), 'yyyy-MM-dd')\r\n    await api.post('/work/schedule', {\r\n      date: dateStr,\r\n      hours: 8,\r\n      notes: 'Scheduled work day'\r\n    })\r\n    toast.success('Day scheduled successfully')\r\n    fetchScheduledDays()\r\n  } catch (error) {\r\n    console.error('Error scheduling day:', error)\r\n    toast.error('Failed to schedule day')\r\n  }\r\n}\r\n\r\nconst removeSchedule = async (day) => {\r\n  try {\r\n    const dateStr = format(new Date(day.date), 'yyyy-MM-dd')\r\n    await api.delete(`/work/schedule/${dateStr}`)\r\n    toast.success('Schedule removed successfully')\r\n    fetchScheduledDays()\r\n  } catch (error) {\r\n    console.error('Error removing schedule:', error)\r\n    toast.error('Failed to remove schedule')\r\n  }\r\n}\r\n\r\nonMounted(() => {\r\n  fetchScheduledDays()\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.schedule-page {\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-xl);\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-md);\r\n  \r\n  .header-content {\r\n    h1 {\r\n      font-size: 2rem;\r\n      font-weight: 800;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      color: var(--text-secondary);\r\n    }\r\n  }\r\n}\r\n\r\n.schedule-content {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--spacing-xl);\r\n}\r\n\r\n.week-selector {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: var(--spacing-lg);\r\n  \r\n  h2 {\r\n    font-size: 1.5rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    min-width: 250px;\r\n    text-align: center;\r\n  }\r\n}\r\n\r\n.week-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));\r\n  gap: var(--spacing-md);\r\n}\r\n\r\n.day-card {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  transition: all 0.3s;\r\n  border: 2px solid transparent;\r\n  \r\n  &.today {\r\n    border-color: var(--primary);\r\n    box-shadow: var(--shadow-md);\r\n  }\r\n  \r\n  &.scheduled {\r\n    background: linear-gradient(135deg, var(--success-li