{"ast":null,"code":"import { ref, computed, onMounted } from 'vue';\nimport { format } from 'date-fns';\nimport api from '../services/api';\nimport { useToast } from 'vue-toastification';\nexport default {\n  __name: 'Work',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const toast = useToast();\n    const showAddModal = ref(false);\n    const dateFilter = ref('month');\n    const workEntries = ref([]);\n    const loading = ref(false);\n    const fetchWorkEntries = async () => {\n      try {\n        loading.value = true;\n        let params = {};\n        const now = new Date();\n        if (dateFilter.value === 'today') {\n          params.date = format(now, 'yyyy-MM-dd');\n        } else if (dateFilter.value === 'week') {\n          const weekAgo = new Date(now.setDate(now.getDate() - 7));\n          params.startDate = format(weekAgo, 'yyyy-MM-dd');\n          params.endDate = format(new Date(), 'yyyy-MM-dd');\n        } else if (dateFilter.value === 'month') {\n          params.month = now.getMonth() + 1;\n          params.year = now.getFullYear();\n        }\n        const response = await api.get('/work/days', {\n          params\n        });\n        const workData = response.data.workDays || [];\n        workEntries.value = workData.map(entry => ({\n          id: entry.id,\n          date: format(new Date(entry.work_date), 'MMM d, yyyy'),\n          hours: entry.hours_worked,\n          earnings: entry.calculated_payment || entry.hours_worked * entry.hourly_rate,\n          description: entry.notes || 'No description'\n        }));\n      } catch (error) {\n        console.error('Error fetching work entries:', error);\n        toast.error('Failed to load work entries');\n      } finally {\n        loading.value = false;\n      }\n    };\n    const editEntry = entry => {\n      console.log('Edit entry:', entry);\n      // TODO: Implement edit functionality\n    };\n    const deleteEntry = async entry => {\n      if (!confirm('Are you sure you want to delete this work entry?')) return;\n      try {\n        await api.delete(`/work/days/${entry.id}`);\n        toast.success('Work entry deleted successfully');\n        fetchWorkEntries();\n      } catch (error) {\n        console.error('Error deleting work entry:', error);\n        toast.error('Failed to delete work entry');\n      }\n    };\n    onMounted(() => {\n      fetchWorkEntries();\n    });\n    const __returned__ = {\n      toast,\n      showAddModal,\n      dateFilter,\n      workEntries,\n      loading,\n      fetchWorkEntries,\n      editEntry,\n      deleteEntry,\n      ref,\n      computed,\n      onMounted,\n      get format() {\n        return format;\n      },\n      get api() {\n        return api;\n      },\n      get useToast() {\n        return useToast;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","format","api","useToast","toast","showAddModal","dateFilter","workEntries","loading","fetchWorkEntries","value","params","now","Date","date","weekAgo","setDate","getDate","startDate","endDate","month","getMonth","year","getFullYear","response","get","workData","data","workDays","map","entry","id","work_date","hours","hours_worked","earnings","calculated_payment","hourly_rate","description","notes","error","console","editEntry","log","deleteEntry","confirm","delete","success"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Work.vue"],"sourcesContent":["<template>\r\n  <div class=\"work-page\">\r\n    <div class=\"page-header\">\r\n      <div class=\"header-content\">\r\n        <h1>Work Entries</h1>\r\n        <p>Log and track your daily work hours</p>\r\n      </div>\r\n      <div class=\"header-actions\">\r\n        <button class=\"btn btn-primary\" @click=\"showAddModal = true\">\r\n          <i class=\"bi bi-plus-circle\"></i>\r\n          <span>Add Work</span>\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"work-content\">\r\n      <div class=\"filters-bar\">\r\n        <div class=\"filter-group\">\r\n          <label>Date Range</label>\r\n          <select v-model=\"dateFilter\" class=\"form-select\">\r\n            <option value=\"today\">Today</option>\r\n            <option value=\"week\">This Week</option>\r\n            <option value=\"month\">This Month</option>\r\n            <option value=\"all\">All Time</option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"work-list\">\r\n        <div v-if=\"workEntries.length === 0\" class=\"empty-state\">\r\n          <i class=\"bi bi-clipboard-x\"></i>\r\n          <h3>No work entries yet</h3>\r\n          <p>Start by adding your first work entry</p>\r\n          <button class=\"btn btn-primary\" @click=\"showAddModal = true\">\r\n            <i class=\"bi bi-plus-circle\"></i>\r\n            Add Work Entry\r\n          </button>\r\n        </div>\r\n\r\n        <div v-else class=\"entries-grid\">\r\n          <div v-for=\"entry in workEntries\" :key=\"entry.id\" class=\"work-entry-card\">\r\n            <div class=\"entry-header\">\r\n              <div class=\"entry-date\">\r\n                <i class=\"bi bi-calendar3\"></i>\r\n                <span>{{ entry.date }}</span>\r\n              </div>\r\n              <div class=\"entry-actions\">\r\n                <button @click=\"editEntry(entry)\" class=\"btn btn-sm btn-icon\">\r\n                  <i class=\"bi bi-pencil\"></i>\r\n                </button>\r\n                <button @click=\"deleteEntry(entry)\" class=\"btn btn-sm btn-icon btn-danger\">\r\n                  <i class=\"bi bi-trash\"></i>\r\n                </button>\r\n              </div>\r\n            </div>\r\n            \r\n            <div class=\"entry-body\">\r\n              <div class=\"entry-stat\">\r\n                <i class=\"bi bi-clock\"></i>\r\n                <div class=\"stat-content\">\r\n                  <span class=\"stat-label\">Hours</span>\r\n                  <span class=\"stat-value\">{{ entry.hours }}</span>\r\n                </div>\r\n              </div>\r\n              \r\n              <div class=\"entry-stat\">\r\n                <i class=\"bi bi-cash-coin\"></i>\r\n                <div class=\"stat-content\">\r\n                  <span class=\"stat-label\">Earnings</span>\r\n                  <span class=\"stat-value\">${{ entry.earnings }}</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            \r\n            <div v-if=\"entry.description\" class=\"entry-description\">\r\n              <p>{{ entry.description }}</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\nimport { format } from 'date-fns'\r\nimport api from '../services/api'\r\nimport { useToast } from 'vue-toastification'\r\n\r\nconst toast = useToast()\r\nconst showAddModal = ref(false)\r\nconst dateFilter = ref('month')\r\nconst workEntries = ref([])\r\nconst loading = ref(false)\r\n\r\nconst fetchWorkEntries = async () => {\r\n  try {\r\n    loading.value = true\r\n    let params = {}\r\n    \r\n    const now = new Date()\r\n    if (dateFilter.value === 'today') {\r\n      params.date = format(now, 'yyyy-MM-dd')\r\n    } else if (dateFilter.value === 'week') {\r\n      const weekAgo = new Date(now.setDate(now.getDate() - 7))\r\n      params.startDate = format(weekAgo, 'yyyy-MM-dd')\r\n      params.endDate = format(new Date(), 'yyyy-MM-dd')\r\n    } else if (dateFilter.value === 'month') {\r\n      params.month = now.getMonth() + 1\r\n      params.year = now.getFullYear()\r\n    }\r\n    \r\n    const response = await api.get('/work/days', { params })\r\n    const workData = response.data.workDays || []\r\n    workEntries.value = workData.map(entry => ({\r\n      id: entry.id,\r\n      date: format(new Date(entry.work_date), 'MMM d, yyyy'),\r\n      hours: entry.hours_worked,\r\n      earnings: entry.calculated_payment || (entry.hours_worked * entry.hourly_rate),\r\n      description: entry.notes || 'No description'\r\n    }))\r\n  } catch (error) {\r\n    console.error('Error fetching work entries:', error)\r\n    toast.error('Failed to load work entries')\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\nconst editEntry = (entry) => {\r\n  console.log('Edit entry:', entry)\r\n  // TODO: Implement edit functionality\r\n}\r\n\r\nconst deleteEntry = async (entry) => {\r\n  if (!confirm('Are you sure you want to delete this work entry?')) return\r\n  \r\n  try {\r\n    await api.delete(`/work/days/${entry.id}`)\r\n    toast.success('Work entry deleted successfully')\r\n    fetchWorkEntries()\r\n  } catch (error) {\r\n    console.error('Error deleting work entry:', error)\r\n    toast.error('Failed to delete work entry')\r\n  }\r\n}\r\n\r\nonMounted(() => {\r\n  fetchWorkEntries()\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.work-page {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-xl);\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-md);\r\n  \r\n  .header-content {\r\n    h1 {\r\n      font-size: 2rem;\r\n      font-weight: 800;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      color: var(--text-secondary);\r\n    }\r\n  }\r\n}\r\n\r\n.filters-bar {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  margin-bottom: var(--spacing-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  \r\n  .filter-group {\r\n    label {\r\n      display: block;\r\n      font-weight: 600;\r\n      color: var(--text-secondary);\r\n      margin-bottom: var(--spacing-sm);\r\n      font-size: 0.875rem;\r\n    }\r\n    \r\n    .form-select {\r\n      width: 200px;\r\n    }\r\n  }\r\n}\r\n\r\n.empty-state {\r\n  text-align: center;\r\n  padding: var(--spacing-3xl) var(--spacing-xl);\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  \r\n  i {\r\n    font-size: 4rem;\r\n    color: var(--text-secondary);\r\n    opacity: 0.3;\r\n    margin-bottom: var(--spacing-lg);\r\n  }\r\n  \r\n  h3 {\r\n    font-size: 1.5rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-sm);\r\n  }\r\n  \r\n  p {\r\n    color: var(--text-secondary);\r\n    margin-bottom: var(--spacing-xl);\r\n  }\r\n}\r\n\r\n.entries-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\r\n  gap: var(--spacing-lg);\r\n}\r\n\r\n.work-entry-card {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  transition: all 0.3s;\r\n  \r\n  &:hover {\r\n    box-shadow: var(--shadow-md);\r\n    transform: translateY(-2px);\r\n  }\r\n  \r\n  .entry-header {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    margin-bottom: var(--spacing-md);\r\n    padding-bottom: var(--spacing-md);\r\n    border-bottom: 1px solid var(--border-color);\r\n    \r\n    .entry-date {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: var(--spacing-sm);\r\n      font-weight: 600;\r\n      color: var(--text-primary);\r\n    }\r\n    \r\n    .entry-actions {\r\n      display: flex;\r\n      gap: var(--spacing-sm);\r\n    }\r\n  }\r\n  \r\n  .entry-body {\r\n    display: grid;\r\n    grid-template-columns: 1fr 1fr;\r\n    gap: var(--spacing-md);\r\n    margin-bottom: var(--spacing-md);\r\n    \r\n    .entry-stat {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: var(--spacing-sm);\r\n      \r\n      i {\r\n        font-size: 1.5rem;\r\n        color: var(--primary);\r\n      }\r\n      \r\n      .stat-content {\r\n        display: flex;\r\n        flex-direction: column;\r\n        \r\n        .stat-label {\r\n          font-size: 0.75rem;\r\n          color: var(--text-secondary);\r\n          text-transform: uppercase;\r\n          letter-spacing: 0.5px;\r\n        }\r\n        \r\n        .stat-value {\r\n          font-size: 1.25rem;\r\n          font-weight: 700;\r\n          color: var(--text-primary);\r\n        }\r\n      }\r\n    }\r\n  }\r\n  \r\n  .entry-description {\r\n    padding-top: var(--spacing-md);\r\n    border-top: 1px solid var(--border-color);\r\n    \r\n    p {\r\n      color: var(--text-secondary);\r\n      font-size: 0.875rem;\r\n      line-height: 1.5;\r\n      margin: 0;\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .page-header {\r\n    .header-content h1 {\r\n      font-size: 1.5rem;\r\n    }\r\n  }\r\n  \r\n  .entries-grid {\r\n    grid-template-columns: 1fr;\r\n  }\r\n  \r\n  .filters-bar .filter-group .form-select {\r\n    width: 100%;\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AAqFA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,QAAQ,KAAK;AAC9C,SAASC,MAAM,QAAQ,UAAU;AACjC,OAAOC,GAAG,MAAM,iBAAiB;AACjC,SAASC,QAAQ,QAAQ,oBAAoB;;;;;;;IAE7C,MAAMC,KAAK,GAAGD,QAAQ,CAAC,CAAC;IACxB,MAAME,YAAY,GAAGP,GAAG,CAAC,KAAK,CAAC;IAC/B,MAAMQ,UAAU,GAAGR,GAAG,CAAC,OAAO,CAAC;IAC/B,MAAMS,WAAW,GAAGT,GAAG,CAAC,EAAE,CAAC;IAC3B,MAAMU,OAAO,GAAGV,GAAG,CAAC,KAAK,CAAC;IAE1B,MAAMW,gBAAgB,GAAG,MAAAA,CAAA,KAAY;MACnC,IAAI;QACFD,OAAO,CAACE,KAAK,GAAG,IAAI;QACpB,IAAIC,MAAM,GAAG,CAAC,CAAC;QAEf,MAAMC,GAAG,GAAG,IAAIC,IAAI,CAAC,CAAC;QACtB,IAAIP,UAAU,CAACI,KAAK,KAAK,OAAO,EAAE;UAChCC,MAAM,CAACG,IAAI,GAAGb,MAAM,CAACW,GAAG,EAAE,YAAY,CAAC;QACzC,CAAC,MAAM,IAAIN,UAAU,CAACI,KAAK,KAAK,MAAM,EAAE;UACtC,MAAMK,OAAO,GAAG,IAAIF,IAAI,CAACD,GAAG,CAACI,OAAO,CAACJ,GAAG,CAACK,OAAO,CAAC,CAAC,GAAG,CAAC,CAAC,CAAC;UACxDN,MAAM,CAACO,SAAS,GAAGjB,MAAM,CAACc,OAAO,EAAE,YAAY,CA