ader-actions\">\r\n        <button class=\"btn btn-primary\" @click=\"showAddModal = true\">\r\n          <i class=\"bi bi-plus-circle\"></i>\r\n          <span>Add Work</span>\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"work-content\">\r\n      <div class=\"filters-bar\">\r\n        <div class=\"filter-group\">\r\n          <label>Date Range</label>\r\n          <select v-model=\"dateFilter\" class=\"form-select\">\r\n            <option value=\"today\">Today</option>\r\n            <option value=\"week\">This Week</option>\r\n            <option value=\"month\">This Month</option>\r\n            <option value=\"all\">All Time</option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"work-list\">\r\n        <div v-if=\"workEntries.length === 0\" class=\"empty-state\">\r\n          <i class=\"bi bi-clipboard-x\"></i>\r\n          <h3>No work entries yet</h3>\r\n          <p>Start by adding your first work entry</p>\r\n          <button class=\"btn btn-primary\" @click=\"showAddModal = true\">\r\n            <i class=\"bi bi-plus-circle\"></i>\r\n            Add Work Entry\r\n          </button>\r\n        </div>\r\n\r\n        <div v-else class=\"entries-grid\">\r\n          <div v-for=\"entry in workEntries\" :key=\"entry.id\" class=\"work-entry-card\">\r\n            <div class=\"entry-header\">\r\n              <div class=\"entry-date\">\r\n                <i class=\"bi bi-calendar3\"></i>\r\n                <span>{{ entry.date }}</span>\r\n              </div>\r\n              <div class=\"entry-actions\">\r\n                <button @click=\"editEntry(entry)\" class=\"btn btn-sm btn-icon\">\r\n                  <i class=\"bi bi-pencil\"></i>\r\n                </button>\r\n                <button @click=\"deleteEntry(entry)\" class=\"btn btn-sm btn-icon btn-danger\">\r\n                  <i class=\"bi bi-trash\"></i>\r\n                </button>\r\n              </div>\r\n            </div>\r\n            \r\n            <div class=\"entry-body\">\r\n              <div class=\"entry-stat\">\r\n                <i class=\"bi bi-clock\"></i>\r\n                <div class=\"stat-content\">\r\n                  <span class=\"stat-label\">Hours</span>\r\n                  <span class=\"stat-value\">{{ entry.hours }}</span>\r\n                </div>\r\n              </div>\r\n              \r\n              <div class=\"entry-stat\">\r\n                <i class=\"bi bi-cash-coin\"></i>\r\n                <div class=\"stat-content\">\r\n                  <span class=\"stat-label\">Earnings</span>\r\n                  <span class=\"stat-value\">${{ entry.earnings }}</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            \r\n            <div v-if=\"entry.description\" class=\"entry-description\">\r\n              <p>{{ entry.description }}</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\nimport { format } from 'date-fns'\r\n\r\nconst showAddModal = ref(false)\r\nconst dateFilter = ref('month')\r\nconst workEntries = ref([\r\n  {\r\n    id: 1,\r\n    date: 'Jan 15, 2024',\r\n    hours: 8,\r\n    earnings: 240,\r\n    description: 'Full day project work'\r\n  },\r\n  {\r\n    id: 2,\r\n    date: 'Jan 14, 2024',\r\n    hours: 6.5,\r\n    earnings: 195,\r\n    description: 'Client meeting and coding'\r\n  },\r\n  {\r\n    id: 3,\r\n    date: 'Jan 13, 2024',\r\n    hours: 7,\r\n    earnings: 210,\r\n    description: 'Bug fixes and testing'\r\n  }\r\n])\r\n\r\nconst editEntry = (entry) => {\r\n  console.log('Edit entry:', entry)\r\n  // TODO: Implement edit functionality\r\n}\r\n\r\nconst deleteEntry = (entry) => {\r\n  console.log('Delete entry:', entry)\r\n  // TODO: Implement delete functionality\r\n}\r\n\r\nonMounted(() => {\r\n  // TODO: Fetch work entries from API\r\n})\r\n</script>\r\n