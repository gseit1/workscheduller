{"ast":null,"code":"import { ref, computed, onMounted } from 'vue';\nimport { format, startOfMonth, endOfMonth, eachDayOfInterval, isSameMonth, isToday, addMonths, subMonths } from 'date-fns';\nimport api from '../services/api';\nimport { useToast } from 'vue-toastification';\nexport default {\n  __name: 'Calendar',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const toast = useToast();\n    const currentDate = ref(new Date());\n    const daysOfWeek = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']; // Sunday moved to end\n    const scheduledDays = ref([]);\n    const workDays = ref([]);\n    const workDaysData = ref([]); // Store full work day data\n    const scheduledDaysData = ref([]); // Store full scheduled day data\n    const loading = ref(false);\n\n    // Schedule modal state\n    const showScheduleModal = ref(false);\n    const editingSchedule = ref(false);\n    const scheduleForm = ref({\n      id: null,\n      date: '',\n      title: '',\n      notes: ''\n    });\n\n    // Work edit modal state\n    const showEditWorkModal = ref(false);\n    const workForm = ref({\n      id: null,\n      workDate: '',\n      hoursWorked: 0,\n      hourlyRate: 0,\n      tipsAmount: 0,\n      notes: ''\n    });\n    const currentMonthYear = computed(() => {\n      return format(currentDate.value, 'MMMM yyyy');\n    });\n    const fetchCalendarData = async () => {\n      try {\n        loading.value = true;\n        const month = currentDate.value.getMonth() + 1;\n        const year = currentDate.value.getFullYear();\n\n        // Fetch work days\n        const workResponse = await api.get('/work/days', {\n          params: {\n            month,\n            year\n          }\n        });\n        const workData = workResponse.data.workDays || [];\n        workDays.value = workData.filter(day => day.workDate) // Filter out entries without valid date\n        .map(day => format(new Date(day.workDate), 'yyyy-MM-dd'));\n\n        // Fetch scheduled days from calendar events\n        const calendarResponse = await api.get('/calendar/events', {\n          params: {\n            month,\n            year\n          }\n        });\n        const eventsData = calendarResponse.data.events || [];\n        scheduledDays.value = eventsData.filter(event => event.startDate) // Filter out entries without valid date\n        .map(event => format(new Date(event.startDate), 'yyyy-MM-dd'));\n      } catch (error) {\n        console.error('Error fetching calendar data:', error);\n        toast.error('Failed to load calendar data');\n      } finally {\n        loading.value = false;\n      }\n    };\n    const calendarDays = computed(() => {\n      const start = startOfMonth(currentDate.value);\n      const end = endOfMonth(currentDate.value);\n      const days = eachDayOfInterval({\n        start,\n        end\n      });\n\n      // Add padding days from previous month\n      const startDay = start.getDay();\n      const previousMonthEnd = new Date(start);\n      previousMonthEnd.setDate(0);\n      const previousMonthDays = [];\n      for (let i = startDay - 1; i >= 0; i--) {\n        const date = new Date(previousMonthEnd);\n        date.setDate(previousMonthEnd.getDate() - i);\n        previousMonthDays.push(date);\n      }\n\n      // Add padding days from next month\n      const endDay = end.getDay();\n      const nextMonthDays = [];\n      for (let i = 1; i <= 6 - endDay; i++) {\n        const date = new Date(end);\n        date.setDate(end.getDate() + i);\n        nextMonthDays.push(date);\n      }\n      const allDays = [...previousMonthDays, ...days, ...nextMonthDays];\n      return allDays.map(date => ({\n        date: date.toISOString(),\n        day: date.getDate(),\n        isToday: isToday(date),\n        isCurrentMonth: isSameMonth(date, currentDate.value),\n        hasWork: workDays.value.includes(format(date, 'yyyy-MM-dd')),\n        isScheduled: scheduledDays.value.includes(format(date, 'yyyy-MM-dd'))\n      }));\n    });\n    const previousMonth = () => {\n      currentDate.value = subMonths(currentDate.value, 1);\n      fetchCalendarData();\n    };\n    const nextMonth = () => {\n      currentDate.value = addMonths(currentDate.value, 1);\n      fetchCalendarData();\n    };\n    const goToToday = () => {\n      currentDate.value = new Date();\n      fetchCalendarData();\n    };\n    const selectDay = day => {\n      console.log('Selected day:', day);\n      // TODO: Implement day selection logic\n    };\n    onMounted(() => {\n      fetchCalendarData();\n    });\n    const __returned__ = {\n      toast,\n      currentDate,\n      daysOfWeek,\n      scheduledDays,\n      workDays,\n      workDaysData,\n      scheduledDaysData,\n      loading,\n      showScheduleModal,\n      editingSchedule,\n      scheduleForm,\n      showEditWorkModal,\n      workForm,\n      currentMonthYear,\n      fetchCalendarData,\n      calendarDays,\n      previousMonth,\n      nextMonth,\n      goToToday,\n      selectDay,\n      ref,\n      computed,\n      onMounted,\n      get format() {\n        return format;\n      },\n      get startOfMonth() {\n        return startOfMonth;\n      },\n      get endOfMonth() {\n        return endOfMonth;\n      },\n      get eachDayOfInterval() {\n        return eachDayOfInterval;\n      },\n      get isSameMonth() {\n        return isSameMonth;\n      },\n      get isToday() {\n        return isToday;\n      },\n      get addMonths() {\n        return addMonths;\n      },\n      get subMonths() {\n        return subMonths;\n      },\n      get api() {\n        return api;\n      },\n      get useToast() {\n        return useToast;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","format","startOfMonth","endOfMonth","eachDayOfInterval","isSameMonth","isToday","addMonths","subMonths","api","useToast","toast","currentDate","Date","daysOfWeek","scheduledDays","workDays","workDaysData","scheduledDaysData","loading","showScheduleModal","editingSchedule","scheduleForm","id","date","title","notes","showEditWorkModal","workForm","workDate","hoursWorked","hourlyRate","tipsAmount","currentMonthYear","value","fetchCalendarData","month","getMonth","year","getFullYear","workResponse","get","params","workData","data","filter","day","map","calendarResponse","eventsData","events","event","startDate","error","console","calendarDays","start","end","days","startDay","getDay","previousMonthEnd","setDate","previousMonthDays","i","getDate","push","endDay","nextMonthDays","allDays","toISOString","isCurrentMonth","hasWork","includes","isScheduled","previousMonth","nextMonth","goToToday","selectDay","log"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Calendar.vue"],"sourcesContent":["<template>\r\n  <div class=\"calendar-page\">\r\n    <div class=\"page-header\">\r\n      <div class=\"header-content\">\r\n        <h1>Calendar</h1>\r\n        <p>View your work schedule and planned days</p>\r\n      </div>\r\n      <div class=\"header-actions\">\r\n        <button class=\"btn btn-primary\" @click=\"openScheduleModal\">\r\n          <i class=\"bi bi-plus-circle\"></i>\r\n          <span>Schedule Day</span>\r\n        </button>\r\n        <button class=\"btn btn-secondary\" @click=\"goToToday\">\r\n          <i class=\"bi bi-calendar-today\"></i>\r\n          <span>Today</span>\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"calendar-controls\">\r\n      <button @click=\"previousMonth\" class=\"btn btn-icon\">\r\n        <i class=\"bi bi-chevron-left\"></i>\r\n      </button>\r\n      <h2>{{ currentMonthYear }}</h2>\r\n      <button @click=\"nextMonth\" class=\"btn btn-icon\">\r\n        <i class=\"bi bi-chevron-right\"></i>\r\n      </button>\r\n    </div>\r\n\r\n    <div class=\"calendar-grid\">\r\n      <div class=\"calendar-header\">\r\n        <div class=\"day-label\" v-for=\"day in daysOfWeek\" :key=\"day\">{{ day }}</div>\r\n      </div>\r\n      <div class=\"calendar-body\">\r\n        <div \r\n          v-for=\"day in calendarDays\" \r\n          :key=\"day.date\"\r\n          :class=\"['calendar-day', {\r\n            'today': day.isToday,\r\n            'other-month': !day.isCurrentMonth,\r\n            'has-work': day.hasWork,\r\n            'scheduled': day.isScheduled\r\n          }]\"\r\n        >\r\n          <div class=\"day-content\">\r\n            <div class=\"day-number\">{{ day.day }}</div>\r\n            <div v-if=\"day.hasWork\" class=\"day-details\">\r\n              <div class=\"earnings\">€{{ day.totalEarnings }}</div>\r\n              <div class=\"day-actions\">\r\n                <button @click.stop=\"editWorkDay(day)\" class=\"btn-icon-sm\" title=\"Edit\">\r\n                  <i class=\"bi bi-pencil\"></i>\r\n                </button>\r\n                <button @click.stop=\"deleteWorkDay(day)\" class=\"btn-icon-sm\" title=\"Delete\">\r\n                  <i class=\"bi bi-trash\"></i>\r\n                </button>\r\n              </div>\r\n            </div>\r\n            <div v-else-if=\"day.isScheduled\" class=\"day-details\">\r\n              <div class=\"scheduled-label\">Scheduled</div>\r\n              <div class=\"day-actions\">\r\n                <button @click.stop=\"editScheduledDay(day)\" class=\"btn-icon-sm\" title=\"Edit\">\r\n                  <i class=\"bi bi-pencil\"></i>\r\n                </button>\r\n                <button @click.stop=\"deleteScheduledDay(day)\" class=\"btn-icon-sm\" title=\"Delete\">\r\n                  <i class=\"bi bi-trash\"></i>\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"calendar-legend\">\r\n      <div class=\"legend-item\">\r\n        <span class=\"legend-dot scheduled\"></span>\r\n        <span>Scheduled</span>\r\n      </div>\r\n      <div class=\"legend-item\">\r\n        <span class=\"legend-dot has-work\"></span>\r\n        <span>Worked</span>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Schedule Day Modal -->\r\n    <div v-if=\"showScheduleModal\" class=\"modal-overlay\" @click=\"closeScheduleModal\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>{{ editingSchedule ? 'Edit Scheduled Day' : 'Schedule Work Day' }}</h3>\r\n          <button class=\"btn-close\" @click=\"closeScheduleModal\">\r\n            <i class=\"bi bi-x\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Date</label>\r\n            <input \r\n              v-model=\"scheduleForm.date\" \r\n              type=\"date\" \r\n              class=\"form-control\"\r\n              required\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Title (Optional)</label>\r\n            <input \r\n              v-model=\"scheduleForm.title\" \r\n              type=\"text\" \r\n              class=\"form-control\"\r\n              placeholder=\"e.g., Morning Shift\"\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Notes (Optional)</label>\r\n            <textarea \r\n              v-model=\"scheduleForm.notes\" \r\n              class=\"form-control\"\r\n              rows=\"3\"\r\n              placeholder=\"Any additional details...\"\r\n            ></textarea>\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button class=\"btn btn-secondary\" @click=\"closeScheduleModal\">Cancel</button>\r\n          <button class=\"btn btn-primary\" @click=\"saveScheduledDay\" :disabled=\"!scheduleForm.date\">\r\n            {{ editingSchedule ? 'Update' : 'Schedule' }}\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Edit Work Day Modal -->\r\n    <div v-if=\"showEditWorkModal\" class=\"modal-overlay\" @click=\"closeEditWorkModal\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Edit Work Day</h3>\r\n          <button class=\"btn-close\" @click=\"closeEditWorkModal\">\r\n            <i class=\"bi bi-x\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Date</label>\r\n            <input \r\n              v-model=\"workForm.workDate\" \r\n              type=\"date\" \r\n              class=\"form-control\"\r\n              required\r\n            />\r\n          </div>\r\n          <div class=\"form-row\">\r\n            <div class=\"form-group\">\r\n              <label>Hours Worked</label>\r\n              <input \r\n                v-model.number=\"workForm.hoursWorked\" \r\n                type=\"number\" \r\n                step=\"0.5\"\r\n                min=\"0\"\r\n                class=\"form-control\"\r\n                required\r\n              />\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label>Hourly Rate (€)</label>\r\n              <input \r\n                v-model.number=\"workForm.hourlyRate\" \r\n                type=\"number\" \r\n                step=\"0.5\"\r\n                min=\"0\"\r\n                class=\"form-control\"\r\n                required\r\n              />\r\n            </div>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Tips (€)</label>\r\n            <input \r\n              v-model.number=\"workForm.tipsAmount\" \r\n              type=\"number\" \r\n              step=\"0.5\"\r\n              min=\"0\"\r\n              class=\"form-control\"\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Notes (Optional)</label>\r\n            <textarea \r\n              v-model=\"workForm.notes\" \r\n              class=\"form-control\"\r\n              rows=\"3\"\r\n            ></textarea>\r\n          </div>\r\n          <div class=\"earnings-preview\" v-if=\"workForm.hoursWorked && workForm.hourlyRate\">\r\n            <div class=\"preview-label\">Earnings Preview:</div>\r\n            <div class=\"preview-value\">\r\n              €{{ (workForm.hoursWorked * workForm.hourlyRate).toFixed(2) }}\r\n              <span v-if=\"workForm.tipsAmount\"> + €{{ workForm.tipsAmount }} tips</span>\r\n              = €{{ ((workForm.hoursWorked * workForm.hourlyRate) + (workForm.tipsAmount || 0)).toFixed(2) }}\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button class=\"btn btn-secondary\" @click=\"closeEditWorkModal\">Cancel</button>\r\n          <button class=\"btn btn-primary\" @click=\"saveWorkDay\" :disabled=\"!workForm.workDate || !workForm.hoursWorked || !workForm.hourlyRate\">\r\n            Update\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\nimport { format, startOfMonth, endOfMonth, eachDayOfInterval, isSameMonth, isToday, addMonths, subMonths } from 'date-fns'\r\nimport api from '../services/api'\r\nimport { useToast } from 'vue-toastification'\r\n\r\nconst toast = useToast()\r\nconst currentDate = ref(new Date())\r\nconst daysOfWeek = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'] // Sunday moved to end\r\nconst scheduledDays = ref([])\r\nconst workDays = ref([])\r\nconst workDaysData = ref([]) // Store full work day data\r\nconst scheduledDaysData = ref([]) // Store full scheduled day data\r\nconst loading = ref(false)\r\n\r\n// Schedule modal state\r\nconst showScheduleModal = ref(false)\r\nconst editingSchedule = ref(false)\r\nconst scheduleForm = ref({\r\n  id: null,\r\n  date: '',\r\n  title: '',\r\n  notes: ''\r\n})\r\n\r\n// Work edit modal state\r\nconst showEditWorkModal = ref(false)\r\nconst workForm = ref({\r\n  id: null,\r\n  workDate: '',\r\n  hoursWorked: 0,\r\n  hourlyRate: 0,\r\n  tipsAmount: 0,\r\n  notes: ''\r\n})\r\n\r\nconst currentMonthYear = computed(() => {\r\n  return format(currentDate.value, 'MMMM yyyy')\r\n})\r\n\r\nconst fetchCalendarData = async () => {\r\n  try {\r\n    loading.value = true\r\n    const month = currentDate.value.getMonth() + 1\r\n    const year = currentDate.value.getFullYear()\r\n    \r\n    // Fetch work days\r\n    const workResponse = await api.get('/work/days', {\r\n      params: { month, year }\r\n    })\r\n    const workData = workResponse.data.workDays || []\r\n    workDays.value = workData\r\n      .filter(day => day.workDate) // Filter out entries without valid date\r\n      .map(day => format(new Date(day.workDate), 'yyyy-MM-dd'))\r\n    \r\n    // Fetch scheduled days from calendar events\r\n    const calendarResponse = await api.get('/calendar/events', {\r\n      params: { month, year }\r\n    })\r\n    const eventsData = calendarResponse.data.events || []\r\n    scheduledDays.value = eventsData\r\n      .filter(event => event.startDate) // Filter out entries without valid date\r\n      .map(event => format(new Date(event.startDate), 'yyyy-MM-dd'))\r\n    \r\n  } catch (error) {\r\n    console.error('Error fetching calendar data:', error)\r\n    toast.error('Failed to load calendar data')\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\nconst calendarDays = computed(() => {\r\n  const start = startOfMonth(currentDate.value)\r\n  const end = endOfMonth(currentDate.value)\r\n  const days = eachDayOfInterval({ start, end })\r\n  \r\n  // Add padding days from previous month\r\n  const startDay = start.getDay()\r\n  const previousMonthEnd = new Date(start)\r\n  previousMonthEnd.setDate(0)\r\n  const previousMonthDays = []\r\n  for (let i = startDay - 1; i >= 0; i--) {\r\n    const date = new Date(previousMonthEnd)\r\n    date.setDate(previousMonthEnd.getDate() - i)\r\n    previousMonthDays.push(date)\r\n  }\r\n  \r\n  // Add padding days from next month\r\n  const endDay = end.getDay()\r\n  const nextMonthDays = []\r\n  for (let i = 1; i <= (6 - endDay); i++) {\r\n    const date = new Date(end)\r\n    date.setDate(end.getDate() + i)\r\n    nextMonthDays.push(date)\r\n  }\r\n  \r\n  const allDays = [...previousMonthDays, ...days, ...nextMonthDays]\r\n  \r\n  return allDays.map(date => ({\r\n    date: date.toISOString(),\r\n    day: date.getDate(),\r\n    isToday: isToday(date),\r\n    isCurrentMonth: isSameMonth(date, currentDate.value),\r\n    hasWork: workDays.value.includes(format(date, 'yyyy-MM-dd')),\r\n    isScheduled: scheduledDays.value.includes(format(date, 'yyyy-MM-dd'))\r\n  }))\r\n})\r\n\r\nconst previousMonth = () => {\r\n  currentDate.value = subMonths(currentDate.value, 1)\r\n  fetchCalendarData()\r\n}\r\n\r\nconst nextMonth = () => {\r\n  currentDate.value = addMonths(currentDate.value, 1)\r\n  fetchCalendarData()\r\n}\r\n\r\nconst goToToday = () => {\r\n  currentDate.value = new Date()\r\n  fetchCalendarData()\r\n}\r\n\r\nconst selectDay = (day) => {\r\n  console.log('Selected day:', day)\r\n  // TODO: Implement day selection logic\r\n}\r\n\r\nonMounted(() => {\r\n  fetchCalendarData()\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.calendar-page {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-xl);\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-md);\r\n  \r\n  .header-content {\r\n    h1 {\r\n      font-size: 2rem;\r\n      font-weight: 800;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      color: var(--text-secondary);\r\n    }\r\n  }\r\n}\r\n\r\n.calendar-controls {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: var(--spacing-lg);\r\n  margin-bottom: var(--spacing-xl);\r\n  \r\n  h2 {\r\n    font-size: 1.5rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    min-width: 200px;\r\n    text-align: center;\r\n  }\r\n}\r\n\r\n.calendar-grid {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  box-shadow: var(--shadow-sm);\r\n}\r\n\r\n.calendar-header {\r\n  display: grid;\r\n  grid-template-columns: repeat(7, 1fr);\r\n  gap: var(--spacing-sm);\r\n  margin-bottom: var(--spacing-md);\r\n  \r\n  .day-label {\r\n    text-align: center;\r\n    font-weight: 600;\r\n    color: var(--text-secondary);\r\n    font-size: 0.875rem;\r\n    padding: var(--spacing-sm);\r\n  }\r\n}\r\n\r\n.calendar-body {\r\n  display: grid;\r\n  grid-template-columns: repeat(7, 1fr);\r\n  gap: var(--spacing-sm);\r\n}\r\n\r\n.calendar-day {\r\n  aspect-ratio: 1;\r\n  border-radius: var(--radius-md);\r\n  padding: var(--spacing-sm);\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n  background: var(--bg-secondary);\r\n  position: relative;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  \r\n  &:hover {\r\n    background: var(--primary-light);\r\n    transform: scale(1.05);\r\n  }\r\n  \r\n  &.other-month {\r\n    opacity: 0.3;\r\n  }\r\n  \r\n  &.today {\r\n    background: var(--primary);\r\n    color: white;\r\n    \r\n    .day-number {\r\n      color: white;\r\n    }\r\n  }\r\n  \r\n  &.scheduled {\r\n    border: 2px solid var(--warning);\r\n  }\r\n  \r\n  &.has-work {\r\n    border: 2px solid var(--success);\r\n  }\r\n  \r\n  .day-number {\r\n    font-weight: 600;\r\n    color: var(--text-primary);\r\n    font-size: 0.875rem;\r\n  }\r\n  \r\n  .day-indicator {\r\n    width: 6px;\r\n    height: 6px;\r\n    border-radius: 50%;\r\n    background: var(--primary);\r\n    margin-top: var(--spacing-xs);\r\n  }\r\n}\r\n\r\n.calenda