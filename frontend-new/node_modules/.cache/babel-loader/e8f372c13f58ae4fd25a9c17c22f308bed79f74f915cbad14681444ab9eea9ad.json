\">\r\n            <span class=\"stat-label\">Hours Worked</span>\r\n            <span class=\"stat-value\">168</span>\r\n            <span class=\"stat-change positive\">+8.3%</span>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"stat-card\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"bi bi-graph-up-arrow\"></i>\r\n          </div>\r\n          <div class=\"stat-content\">\r\n            <span class=\"stat-label\">Avg. Rate</span>\r\n            <span class=\"stat-value\">$74.11</span>\r\n            <span class=\"stat-change positive\">+4.2%</span>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"stat-card\">\r\n          <div class=\"stat-icon\">\r\n            <i class=\"bi bi-calendar-check\"></i>\r\n          </div>\r\n          <div class=\"stat-content\">\r\n            <span class=\"stat-label\">Work Days</span>\r\n            <span class=\"stat-value\">21</span>\r\n            <span class=\"stat-change neutral\">0%</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"charts-section\">\r\n        <div class=\"chart-card\">\r\n          <h3>Earnings Trend</h3>\r\n          <div class=\"chart-placeholder\">\r\n            <i class=\"bi bi-bar-chart-line\"></i>\r\n            <p>Chart visualization will appear here</p>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"chart-card\">\r\n          <h3>Work Distribution</h3>\r\n          <div class=\"chart-placeholder\">\r\n            <i class=\"bi bi-pie-chart\"></i>\r\n            <p>Chart visualization will appear here</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"insights-section\">\r\n        <h3>Key Insights</h3>\r\n        <div class=\"insights-grid\">\r\n          <div class=\"insight-card\">\r\n            <i class=\"bi bi-trophy\"></i>\r\n            <div class=\"insight-content\">\r\n              <h4>Best Performing Day</h4>\r\n      