", _hoisted_15, [_createElementVNode(\"div\", _hoisted_16, [_cache[12] || (_cache[12] = _createElementVNode(\"label\", null, \"Category\", -1 /* CACHED */)), _withDirectives(_createElementVNode(\"select\", {\n    \"onUpdate:modelValue\": _cache[1] || (_cache[1] = $event => $setup.categoryFilter = $event),\n    class: \"form-select\"\n  }, [...(_cache[11] || (_cache[11] = [_createStaticVNode(\"<option value=\\\"all\\\" data-v-ff3c6056>All Categories</option><option value=\\\"software\\\" data-v-ff3c6056>Software</option><option value=\\\"equipment\\\" data-v-ff3c6056>Equipment</option><option value=\\\"office\\\" data-v-ff3c6056>Office</option><option value=\\\"other\\\" data-v-ff3c6056>Other</option>\", 5)]))], 512 /* NEED_PATCH */), [[_vModelSelect, $setup.categoryFilter]])]), _createElementVNode(\"div\", _hoisted_17, [_cache[14] || (_cache[14] = _createElementVNode(\"label\", null, \"Period\", -1 /* CACHED */)), _withDirectives(_createElementVNode(\"select\", {\n    \"onUpdate:modelValue\": _cache[2] || (_cache[2] = $event => $setup.periodFilter = $event),\n    class: \"form-select\"\n  }, [...(_cache[13] || (_cache[13] = [_createElementVNode(\"option\", {\n    value: \"month\"\n  }, \"This Month\", -1 /* CACHED */), _createElementVNode(\"option\", {\n    value: \"quarter\"\n  }, \"This Quarter\", -1 /* CACHED */), _createElementVNode(\"option\", {\n    value: \"year\"\n  }, \"This Year\", -1 /* CACHED */), _createElementVNode(\"option\", {\n    value: \"all\"\n  }, \"All Time\", -1 /* CACHED */)]))], 512 /* NEED_PATCH */), [[_vModelSelect, $setup.periodFilter]])])]), _createElementVNode(\"div\", _hoisted_18, [_createElementVNode(\"table\", null, [_cache[17] || (_cache[17] = _createElementVNode(\"thead\", null, [_createElementVNode(\"tr\", null, [_createElementVNode(\"th\", null, \"Date\"), _createElementVNode(\"th\", null, \"Description\"), _createElementVNode(\"th\", null, \"Category\"), _createElementVNode(\"th\", null, \"Amount\"), _createElementVNode(\"th\", null, \"Actions\")])], -1 /* CACHED */)), _createElementVNode(\"tbody\", null, [(_openBlock(true), _createElementBlock(_Fragment, null, _renderList($setup.expenses, expense => {\n    return _openBlock(), _createElementBlock(\"tr\", {\n      key: expense.id\n    }, [_createElementVNode(\"td\", null, _toDisplayString(expense.date), 1 /* TEXT */), _createElementVNode(\"td\", null, _toDisplayString(expense.description), 1 /* TEXT */), _createElementVNode(\"td\", null, [_createElementVNode(\"span\", {\n      class: _normalizeClass(['badge', `badge-${expense.category}`])\n    }, _toDisplayString(expense.category), 3 /* TEXT, CLASS */)]), _createElementVNode(\"td\", _hoisted_19, \"$\" + _toDisplayString(expense.amount), 1 /* TEXT */), _createElementVNode(\"td\", _hoisted_20, [_createElementVNode(\"button\", {\n      onClick: $event => $setup.editExpense(expense),\n      class: \"btn btn-sm btn-icon\"\n    }, [...(_cache[15] || (_cache[15] = [_createElementVNode(\"i\", {\n      class: \"bi bi-pencil\"\n    }, null, -1 /* CACHED */)]))], 8 /* PROPS */, _hoisted_21), _createElementVNode(\"button\", {\n      onClick: $event => $setup.deleteExpense(expense),\n      class: \"btn btn-sm btn-icon btn-danger\"\n    }, [...(_cache[16] || (_cache[16] = [_createElementVNode(\"i\", {\n      class: \"bi bi-trash\"\n    }, null, -1 /* CACHED */)]))], 8 /* PROPS */, _hoisted_22)])]);\n  }), 128 /* KEYED_FRAGMENT */))])])])])]);\n}","map":{"version":3,"names":["class","_createElementBlock","_hoisted_1","_createElementVNode","_hoisted_2","_hoisted_3","onClick","_cache","$event","$setup","showAddModal","_hoisted_4","_hoisted_5","_hoisted_6","_hoisted_7","_toDisplayString","monthlyTotal","_hoisted_8","_hoisted_9","_hoisted_10","yearlyTotal","_hoisted_11","_hoisted_12","_hoisted_13","averageMonthly","_hoisted_14","_hoisted_15","_hoisted_16","categoryFilter","_hoisted_17","periodFilter","value","_hoisted_18","_Fragment","_renderList","expenses","expense","key","id","date","description","_normalizeClass","category","_hoisted_19","amount","_hoisted_20","editExpense","deleteExpense"],"sources":["C:\\xampp\\htdocs\\jobAnalytics\\frontend-new\\src\\views\\Expenses.vue"],"sourcesContent":["<template>\r\n  <div class=\"expenses-page\">\r\n    <div class=\"page-header\">\r\n      <div class=\"header-content\">\r\n        <h1>Expenses</h1>\r\n        <p>Track and manage your business expenses</p>\r\n      </div>\r\n      <div class=\"header-actions\">\r\n        <button class=\"btn btn-primary\" @click=\"showAddModal = true\">\r\n          <i class=\"bi bi-plus-circle\"></i>\r\n          <span>Add Expense</span>\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"expenses-summary\">\r\n      <div class=\"summary-card\">\r\n        <div class=\"summary-icon\">\r\n          <i class=\"bi bi-calendar-month\"></i>\r\n        </div>\r\n        <div class=\"summary-content\">\r\n          <span class=\"summary-label\">This Month</span>\r\n          <span class=\"summary-value\">${{ monthlyTotal }}</span>\r\n        </div>\r\n      </div>\r\n      \r\n      <div class=\"summary-card\">\r\n        <div class=\"summary-icon\">\r\n          <i class=\"bi bi-calendar-range\"></i>\r\n        </div>\r\n        <div class=\"summary-content\">\r\n          <span class=\"summary-label\">This Year</span>\r\n          <span class=\"summary-value\">${{ yearlyTotal }}</span>\r\n        </div>\r\n      </div>\r\n      \r\n      <div class=\"summary-card\">\r\n        <div class=\"summary-icon\">\r\n          <i class=\"bi bi-piggy-bank\"></i>\r\n        </div>\r\n        <div class=\"summary-content\">\r\n          <span class=\"summary-label\">Average/Month</span>\r\n          <span class=\"summary-value\">${{ averageMonthly }}</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"expenses-content\">\r\n      <div class=\"filters-bar\">\r\n        <div class=\"filter-group\">\r\n          <label>Category</label>\r\n          <select v-model=\"categoryFilter\" class=\"form-select\">\r\n            <option value=\"all\">All Categories</option>\r\n            <option value=\"software\">Software</option>\r\n            <option value=\"equipment\">Equipment</option>\r\n            <option value=\"office\">Office</option>\r\n            <option value=\"other\">Other</option>\r\n          </select>\r\n        </div>\r\n        \r\n        <div class=\"filter-group\">\r\n          <label>Period</label>\r\n          <select v-model=\"periodFilter\" class=\"form-select\">\r\n            <option value=\"month\">This Month</option>\r\n            <option value=\"quarter\">This Quarter</option>\r\n            <option value=\"year\">This Year</option>\r\n            <option value=\"all\">All Time</option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"expenses-table\">\r\n        <table>\r\n          <thead>\r\n            <tr>\r\n              <th>Date</th>\r\n              <th>Description</th>\r\n              <th>Category</th>\r\n              <th>Amount</th>\r\n              <th>Actions</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            <tr v-for=\"expense in expenses\" :key=\"expense.id\">\r\n              <td>{{ expense.date }}</td>\r\n              <td>{{ expense.description }}</td>\r\n              <td>\r\n                <span :class=\"['badge', `badge-${expense.category}`]\">\r\n                  {{ expense.category }}\r\n                </span>\r\n              </td>\r\n              <td class=\"amount\">${{ expense.amount }}</td>\r\n              <td class=\"actions\">\r\n                <button @click=\"editExpense(expense)\" class=\"btn btn-sm btn-icon\">\r\n                  <i class=\"bi bi-pencil\"></i>\r\n                </button>\r\n                <button @click=\"deleteExpense(expense)\" class=\"btn btn-sm btn-icon btn-danger\">\r\n                  <i class=\"bi bi-trash\"></i>\r\n                </button>\r\n              </td>\r\n            </tr>\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted, watch } from 'vue'\r\nimport api from '../services/api'\r\nimport { useToast } from 'vue-toastification'\r\nimport { format } from 'date-fns'\r\n\r\nconst toast = useToast()\r\nconst showAddModal = ref(false)\r\nconst categoryFilter = ref('all')\r\nconst periodFilter = ref('month')\r\nconst monthlyTotal = ref(0)\r\nconst yearlyTotal = ref(0)\r\nconst averageMonthly = ref(0)\r\nconst expenses = ref([])\r\nconst loading = ref(false)\r\n\r\nconst fetchExpenses = async () => {\r\n  try {\r\n    loading.value = true\r\n    let params = { type: 'expense' }\r\n    \r\n    const now = new Date()\r\n    if (periodFilter.value === 'month') {\r\n      params.month = now.getMonth() + 1\r\n      params.year = now.getFullYear()\r\n    } else if (periodFilter.value === 'quarter') {\r\n      params.quarter = Math.floor(now.getMonth() / 3) + 1\r\n      params.year = now.getFullYear()\r\n    } else if (periodFilter.value === 'year') {\r\n      params.year = now.getFullYear()\r\n    }\r\n    \r\n    if (categoryFilter.value !== 'all') {\r\n      params.category = categoryFilter.value\r\n    }\r\n    \r\n    const response = await api.get('/expenses', { params })\r\n    const expensesData = response.data.expenses || []\r\n    expenses.value = expensesData.map(expense => ({\r\n      id: expense.id,\r\n      date: format(new Date(expense.expense_date), 'MMM d, yyyy'),\r\n      description: expense.description,\r\n      category: expense.category || 'other',\r\n      amount: expense.amount\r\n    }))\r\n    \r\n    // Calculate totals\r\n    monthlyTotal.value = expenses.value.reduce((sum, exp) => sum + exp.amount, 0)\r\n  } catch (error) {\r\n    console.error('Error fetching expenses:', error)\r\n    toast.error('Failed to load expenses')\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\nconst fetchSummary = async () => {\r\n  try {\r\n    const now = new Date()\r\n    const monthResponse = await api.get('/expenses/summary/monthly', {\r\n      params: { month: now.getMonth() + 1, year: now.getFullYear(), type: 'expense' }\r\n    })\r\n    monthlyTotal.value = monthResponse.data.total || 0\r\n    \r\n    const yearResponse = await api.get('/expenses/summary/monthly', {\r\n      params: { year: now.getFullYear(), type: 'expense' }\r\n    })\r\n    yearlyTotal.value = yearResponse.data.total || 0\r\n    averageMonthly.value = yearlyTotal.value / 12\r\n  } catch (error) {\r\n    console.error('Error fetching expense summary:', error)\r\n  }\r\n}\r\n\r\nconst editExpense = (expense) => {\r\n  console.log('Edit expense:', expense)\r\n  // TODO: Implement edit functionality\r\n}\r\n\r\nconst deleteExpense = async (expense) => {\r\n  if (!confirm('Are you sure you want to delete this expense?')) return\r\n  \r\n  try {\r\n    await api.delete(`/expenses/${expense.id}`)\r\n    toast.success('Expense deleted successfully')\r\n    fetchExpenses()\r\n    fetchSummary()\r\n  } catch (error) {\r\n    console.error('Error deleting expense:', error)\r\n    toast.error('Failed to delete expense')\r\n  }\r\n}\r\n\r\nwatch([categoryFilter, periodFilter], () => {\r\n  fetchExpenses()\r\n})\r\n\r\nonMounted(() => {\r\n  fetchExpenses()\r\n  fetchSummary()\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.expenses-page {\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-xl);\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-md);\r\n  \r\n  .header-content {\r\n    h1 {\r\n      font-size: 2rem;\r\n      font-weight: 800;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      color: var(--text-secondary);\r\n    }\r\n  }\r\n}\r\n\r\n.expenses-summary {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\r\n  gap: var(--spacing-lg);\r\n  margin-bottom: var(--spacing-xl);\r\n  \r\n  .summary-card {\r\n    background: var(--bg-primary);\r\n    border-radius: var(--radius-lg);\r\n    padding: var(--spacing-lg);\r\n    display: flex;\r\n    align-items: center;\r\n    gap: var(--spacing-md);\r\n    box-shadow: var(--shadow-sm);\r\n    \r\n    .summary-icon {\r\n      width: 60px;\r\n      height: 60px;\r\n      border-radius: var(--radius-lg);\r\n      background: linear-gradient(135deg, var(--danger) 0%, var(--danger-light) 100%);\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      color: white;\r\n      font-size: 1.5rem;\r\n    }\r\n    \r\n    .summary-content {\r\n      display: flex;\r\n      flex-direction: column;\r\n      \r\n      .summary-label {\r\n        font-size: 0.875rem;\r\n        color: var(--text-secondary);\r\n        margin-bottom: var(--spacing-xs);\r\n      }\r\n      \r\n      .summary-value {\r\n        font-size: 1.75rem;\r\n        font-weight: 800;\r\n        color: var(--text-primary);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n.filters-bar {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  margin-bottom: var(--spacing-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  display: flex;\r\n  gap: var(--spacing-lg);\r\n  flex-wrap: wrap;\r\n  \r\n  .filter-group {\r\n    flex: 1;\r\n    min-width: 200px;\r\n    \r\n    label {\r\n      display: block;\r\n      font-weight: 600;\r\n      color: var(--text-secondary);\r\n      margin-bottom: var(--spacing-sm);\r\n      font-size: 0.875rem;\r\n    }\r\n  }\r\n}\r\n\r\n.expenses-table {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  overflow: hidden;\r\n  \r\n  table {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    \r\n    thead {\r\n      background: var(--bg-secondary);\r\n      \r\n      th {\r\n        padding: var(--spacing-md) var(--spacing-lg);\r\n        text-align: left;\r\n        font-weight: 600;\r\n        color: var(--text-secondary);\r\n        font-size: 0.875rem;\r\n        text-transform: uppercase;\r\n        letter-spacing: 0.5px;\r\n      }\r\n    }\r\n    \r\n    tbody {\r\n      tr {\r\n        border-bottom: 1px solid var(--border-color);\r\n        transition: background-color 0.2s;\r\n        \r\n        &:hover {\r\n          background: var(--bg-secondary);\r\n        }\r\n        \r\n        &:last-child {\r\n          border-bottom: none;\r\n        }\r\n        \r\n        td {\r\n          padding: var(--spacing-md) var(--spacing-lg);\r\n          color: var(--text-primary);\r\n          \r\n          &.amount {\r\n            font-weight: 700;\r\n            color: var(--danger);\r\n          }\r\n          \r\n          &.actions {\r\n            display: flex;\r\n            gap: var(--spacing-sm);\r\n          }\r\n          \r\n          .badge {\r\n            display: inline-block;\r\n            padding: var(--spacing-xs) var(--spacing-sm);\r\n            border-radius: var(--radius-full);\r\n            font-size: 0.75rem;\r\n            font-weight: 600;\r\n            text-transform: capitalize;\r\n            \r\n            &.badge-software {\r\n              background: var(--primary-light);\r\n              color: var(--primary);\r\n            }\r\n            \r\n            &.badge-equipment {\r\n              background: var(--warning-light);\r\n              color: var(--warning);\r\n            }\r\n            \r\n            &.badge-office {\r\n              background: var(--success-light);\r\n              color: var(--success);\r\n            }\r\n            \r\n            &.badge-other {\r\n              background: var(--bg-secondary);\r\n              color: var(--text-secondary);\r\n            }\r\n          }\r\n        }\r\n      }\r\n    }\r\n  }\