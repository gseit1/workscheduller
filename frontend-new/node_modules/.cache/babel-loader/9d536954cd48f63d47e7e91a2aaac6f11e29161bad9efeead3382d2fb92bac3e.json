{"ast":null,"code":"import { ref, computed, onMounted, watch } from 'vue';\nimport api from '../services/api';\nimport { useToast } from 'vue-toastification';\nimport { format, addMonths, subMonths } from 'date-fns';\nexport default {\n  __name: 'Expenses',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const toast = useToast();\n    const showAddModal = ref(false);\n    const editingExpense = ref(null);\n    const currentDate = ref(new Date());\n    const typeFilter = ref('expense');\n    const expenses = ref([]);\n    const loading = ref(false);\n\n    // Monthly statistics\n    const monthlyStats = ref({\n      totalExpenses: 0,\n      expenseCount: 0,\n      averageExpense: 0,\n      netIncome: 0\n    });\n\n    // Expense form\n    const expenseForm = ref({\n      id: null,\n      expenseDate: format(new Date(), 'yyyy-MM-dd'),\n      type: 'expense',\n      description: '',\n      amount: 0,\n      notes: ''\n    });\n    const currentMonthLabel = computed(() => {\n      return format(currentDate.value, 'MMMM yyyy');\n    });\n    const netIncomeClass = computed(() => {\n      return monthlyStats.value.netIncome >= 0 ? 'positive' : 'negative';\n    });\n    const previousMonth = () => {\n      currentDate.value = subMonths(currentDate.value, 1);\n      fetchExpenses();\n      fetchMonthlyStats();\n    };\n    const nextMonth = () => {\n      currentDate.value = addMonths(currentDate.value, 1);\n      fetchExpenses();\n      fetchMonthlyStats();\n    };\n    const goToCurrentMonth = () => {\n      currentDate.value = new Date();\n      fetchExpenses();\n      fetchMonthlyStats();\n    };\n    const fetchExpenses = async () => {\n      try {\n        loading.value = true;\n        let params = {\n          type: 'expense'\n        };\n        const now = new Date();\n        if (periodFilter.value === 'month') {\n          params.month = now.getMonth() + 1;\n          params.year = now.getFullYear();\n        } else if (periodFilter.value === 'quarter') {\n          params.quarter = Math.floor(now.getMonth() / 3) + 1;\n          params.year = now.getFullYear();\n        } else if (periodFilter.value === 'year') {\n          params.year = now.getFullYear();\n        }\n        if (categoryFilter.value !== 'all') {\n          params.category = categoryFilter.value;\n        }\n        const response = await api.get('/expenses', {\n          params\n        });\n        const expensesData = response.data.expenses || [];\n        expenses.value = expensesData.map(expense => ({\n          id: expense.id,\n          date: format(new Date(expense.expense_date), 'MMM d, yyyy'),\n          description: expense.description,\n          category: expense.category || 'other',\n          amount: expense.amount\n        }));\n\n        // Calculate totals\n        monthlyTotal.value = expenses.value.reduce((sum, exp) => sum + exp.amount, 0);\n      } catch (error) {\n        console.error('Error fetching expenses:', error);\n        toast.error('Failed to load expenses');\n      } finally {\n        loading.value = false;\n      }\n    };\n    const fetchSummary = async () => {\n      try {\n        const now = new Date();\n        const monthResponse = await api.get('/expenses/summary/monthly', {\n          params: {\n            month: now.getMonth() + 1,\n            year: now.getFullYear(),\n            type: 'expense'\n          }\n        });\n        monthlyTotal.value = monthResponse.data.total || 0;\n        const yearResponse = await api.get('/expenses/summary/monthly', {\n          params: {\n            year: now.getFullYear(),\n            type: 'expense'\n          }\n        });\n        yearlyTotal.value = yearResponse.data.total || 0;\n        averageMonthly.value = yearlyTotal.value / 12;\n      } catch (error) {\n        console.error('Error fetching expense summary:', error);\n      }\n    };\n    const editExpense = expense => {\n      console.log('Edit expense:', expense);\n      // TODO: Implement edit functionality\n    };\n    const deleteExpense = async expense => {\n      if (!confirm('Are you sure you want to delete this expense?')) return;\n      try {\n        await api.delete(`/expenses/${expense.id}`);\n        toast.success('Expense deleted successfully');\n        fetchExpenses();\n        fetchSummary();\n      } catch (error) {\n        console.error('Error deleting expense:', error);\n        toast.error('Failed to delete expense');\n      }\n    };\n    watch([categoryFilter, periodFilter], () => {\n      fetchExpenses();\n    });\n    onMounted(() => {\n      fetchExpenses();\n      fetchSummary();\n    });\n    const __returned__ = {\n      toast,\n      showAddModal,\n      editingExpense,\n      currentDate,\n      typeFilter,\n      expenses,\n      loading,\n      monthlyStats,\n      expenseForm,\n      currentMonthLabel,\n      netIncomeClass,\n      previousMonth,\n      nextMonth,\n      goToCurrentMonth,\n      fetchExpenses,\n      fetchSummary,\n      editExpense,\n      deleteExpense,\n      ref,\n      computed,\n      onMounted,\n      watch,\n      get api() {\n        return api;\n      },\n      get useToast() {\n        return useToast;\n      },\n      get format() {\n        return format;\n      },\n      get addMonths() {\n        return addMonths;\n      },\n      get subMonths() {\n        return subMonths;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","watch","api","useToast","format","addMonths","subMonths","toast","showAddModal","editingExpense","currentDate","Date","typeFilter","expenses","loading","monthlyStats","totalExpenses","expenseCount","averageExpense","netIncome","expenseForm","id","expenseDate","type","description","amount","notes","currentMonthLabel","value","netIncomeClass","previousMonth","fetchExpenses","fetchMonthlyStats","nextMonth","goToCurrentMonth","params","now","periodFilter","month","getMonth","year","getFullYear","quarter","Math","floor","categoryFilter","category","response","get","expensesData","data","map","expense","date","expense_date","monthlyTotal","reduce","sum","exp","error","console","fetchSummary","monthResponse","total","yearResponse","yearlyTotal","averageMonthly","editExpense","log","deleteExpense","confirm","delete","success"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Expenses.vue"],"sourcesContent":["<template>\r\n  <div class=\"expenses-page\">\r\n    <div class=\"page-header\">\r\n      <div class=\"header-content\">\r\n        <h1>Expenses</h1>\r\n        <p>Track and manage your business expenses</p>\r\n      </div>\r\n      <div class=\"header-actions\">\r\n        <button class=\"btn btn-primary\" @click=\"showAddModal = true\">\r\n          <i class=\"bi bi-plus-circle\"></i>\r\n          <span>Add Expense</span>\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"expenses-summary\">\r\n      <div class=\"summary-card\">\r\n        <div class=\"summary-icon\">\r\n          <i class=\"bi bi-cash-stack\"></i>\r\n        </div>\r\n        <div class=\"summary-content\">\r\n          <span class=\"summary-label\">Total Expenses</span>\r\n          <span class=\"summary-value\">€{{ monthlyStats.totalExpenses }}</span>\r\n        </div>\r\n      </div>\r\n      \r\n      <div class=\"summary-card\">\r\n        <div class=\"summary-icon\">\r\n          <i class=\"bi bi-receipt\"></i>\r\n        </div>\r\n        <div class=\"summary-content\">\r\n          <span class=\"summary-label\">Number of Expenses</span>\r\n          <span class=\"summary-value\">{{ monthlyStats.expenseCount }}</span>\r\n        </div>\r\n      </div>\r\n      \r\n      <div class=\"summary-card\">\r\n        <div class=\"summary-icon\">\r\n          <i class=\"bi bi-bar-chart\"></i>\r\n        </div>\r\n        <div class=\"summary-content\">\r\n          <span class=\"summary-label\">Average Expense</span>\r\n          <span class=\"summary-value\">€{{ monthlyStats.averageExpense }}</span>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"summary-card\">\r\n        <div class=\"summary-icon\">\r\n          <i class=\"bi bi-piggy-bank\"></i>\r\n        </div>\r\n        <div class=\"summary-content\">\r\n          <span class=\"summary-label\">Net Income</span>\r\n          <span class=\"summary-value\" :class=\"netIncomeClass\">€{{ monthlyStats.netIncome }}</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"expenses-content\">\r\n      <div class=\"filters-bar\">\r\n        <div class=\"filter-group\">\r\n          <label>Month & Year</label>\r\n          <div class=\"date-navigation\">\r\n            <button @click=\"previousMonth\" class=\"btn btn-icon\">\r\n              <i class=\"bi bi-chevron-left\"></i>\r\n            </button>\r\n            <span class=\"current-month\">{{ currentMonthLabel }}</span>\r\n            <button @click=\"nextMonth\" class=\"btn btn-icon\">\r\n              <i class=\"bi bi-chevron-right\"></i>\r\n            </button>\r\n            <button @click=\"goToCurrentMonth\" class=\"btn btn-secondary btn-sm\">\r\n              Today\r\n            </button>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"filter-group\">\r\n          <label>Type</label>\r\n          <select v-model=\"typeFilter\" class=\"form-select\">\r\n            <option value=\"expense\">Expenses</option>\r\n            <option value=\"income\">Income</option>\r\n            <option value=\"all\">All</option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"expenses-table\">\r\n        <div v-if=\"expenses.length === 0\" class=\"empty-state\">\r\n          <i class=\"bi bi-inbox\"></i>\r\n          <h3>No expenses yet</h3>\r\n          <p>Start by adding your first expense for this month</p>\r\n          <button class=\"btn btn-primary\" @click=\"showAddModal = true\">\r\n            <i class=\"bi bi-plus-circle\"></i>\r\n            Add Expense\r\n          </button>\r\n        </div>\r\n\r\n        <table v-else>\r\n          <thead>\r\n            <tr>\r\n              <th>Date</th>\r\n              <th>Description</th>\r\n              <th>Type</th>\r\n              <th>Amount</th>\r\n              <th>Actions</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            <tr v-for=\"expense in expenses\" :key=\"expense.id\">\r\n              <td>{{ expense.date }}</td>\r\n              <td>{{ expense.description }}</td>\r\n              <td>\r\n                <span :class=\"['badge', `badge-${expense.type}`]\">\r\n                  {{ expense.type }}\r\n                </span>\r\n              </td>\r\n              <td :class=\"['amount', expense.type === 'income' ? 'income' : 'expense']\">\r\n                {{ expense.type === 'income' ? '+' : '-' }}€{{ expense.amount }}\r\n              </td>\r\n              <td class=\"actions\">\r\n                <button @click=\"editExpense(expense)\" class=\"btn btn-sm btn-icon\">\r\n                  <i class=\"bi bi-pencil\"></i>\r\n                </button>\r\n                <button @click=\"deleteExpense(expense)\" class=\"btn btn-sm btn-icon btn-danger\">\r\n                  <i class=\"bi bi-trash\"></i>\r\n                </button>\r\n              </td>\r\n            </tr>\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Add/Edit Expense Modal -->\r\n    <div v-if=\"showAddModal\" class=\"modal-overlay\" @click=\"closeModal\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>{{ editingExpense ? 'Edit Entry' : 'Add Entry' }}</h3>\r\n          <button class=\"btn-close\" @click=\"closeModal\">\r\n            <i class=\"bi bi-x\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Date</label>\r\n            <input \r\n              v-model=\"expenseForm.expenseDate\" \r\n              type=\"date\" \r\n              class=\"form-control\"\r\n              required\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Type</label>\r\n            <select v-model=\"expenseForm.type\" class=\"form-control\">\r\n              <option value=\"expense\">Expense</option>\r\n              <option value=\"income\">Income</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Description</label>\r\n            <input \r\n              v-model=\"expenseForm.description\" \r\n              type=\"text\" \r\n              class=\"form-control\"\r\n              placeholder=\"e.g., Office supplies\"\r\n              required\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Amount (€)</label>\r\n            <input \r\n              v-model.number=\"expenseForm.amount\" \r\n              type=\"number\" \r\n              step=\"0.01\"\r\n              min=\"0\"\r\n              class=\"form-control\"\r\n              required\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Notes (Optional)</label>\r\n            <textarea \r\n              v-model=\"expenseForm.notes\" \r\n              class=\"form-control\"\r\n              rows=\"3\"\r\n              placeholder=\"Any additional details...\"\r\n            ></textarea>\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button class=\"btn btn-secondary\" @click=\"closeModal\">Cancel</button>\r\n          <button class=\"btn btn-primary\" @click=\"saveExpense\" :disabled=\"!expenseForm.expenseDate || !expenseForm.description || !expenseForm.amount\">\r\n            {{ editingExpense ? 'Update' : 'Add' }}\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted, watch } from 'vue'\r\nimport api from '../services/api'\r\nimport { useToast } from 'vue-toastification'\r\nimport { format, addMonths, subMonths } from 'date-fns'\r\n\r\nconst toast = useToast()\r\nconst showAddModal = ref(false)\r\nconst editingExpense = ref(null)\r\nconst currentDate = ref(new Date())\r\nconst typeFilter = ref('expense')\r\nconst expenses = ref([])\r\nconst loading = ref(false)\r\n\r\n// Monthly statistics\r\nconst monthlyStats = ref({\r\n  totalExpenses: 0,\r\n  expenseCount: 0,\r\n  averageExpense: 0,\r\n  netIncome: 0\r\n})\r\n\r\n// Expense form\r\nconst expenseForm = ref({\r\n  id: null,\r\n  expenseDate: format(new Date(), 'yyyy-MM-dd'),\r\n  type: 'expense',\r\n  description: '',\r\n  amount: 0,\r\n  notes: ''\r\n})\r\n\r\nconst currentMonthLabel = computed(() => {\r\n  return format(currentDate.value, 'MMMM yyyy')\r\n})\r\n\r\nconst netIncomeClass = computed(() => {\r\n  return monthlyStats.value.netIncome >= 0 ? 'positive' : 'negative'\r\n})\r\n\r\nconst previousMonth = () => {\r\n  currentDate.value = subMonths(currentDate.value, 1)\r\n  fetchExpenses()\r\n  fetchMonthlyStats()\r\n}\r\n\r\nconst nextMonth = () => {\r\n  currentDate.value = addMonths(currentDate.value, 1)\r\n  fetchExpenses()\r\n  fetchMonthlyStats()\r\n}\r\n\r\nconst goToCurrentMonth = () => {\r\n  currentDate.value = new Date()\r\n  fetchExpenses()\r\n  fetchMonthlyStats()\r\n}\r\n\r\nconst fetchExpenses = async () => {\r\n  try {\r\n    loading.value = true\r\n    let params = { type: 'expense' }\r\n    \r\n    const now = new Date()\r\n    if (periodFilter.value === 'month') {\r\n      params.month = now.getMonth() + 1\r\n      params.year = now.getFullYear()\r\n    } else if (periodFilter.value === 'quarter') {\r\n      params.quarter = Math.floor(now.getMonth() / 3) + 1\r\n      params.year = now.getFullYear()\r\n    } else if (periodFilter.value === 'year') {\r\n      params.year = now.getFullYear()\r\n    }\r\n    \r\n    if (categoryFilter.value !== 'all') {\r\n      params.category = categoryFilter.value\r\n    }\r\n    \r\n    const response = await api.get('/expenses', { params })\r\n    const expensesData = response.data.expenses || []\r\n    expenses.value = expensesData.map(expense => ({\r\n      id: expense.id,\r\n      date: format(new Date(expense.expense_date), 'MMM d, yyyy'),\r\n      description: expense.description,\r\n      category: expense.category || 'other',\r\n      amount: expense.amount\r\n    }))\r\n    \r\n    // Calculate totals\r\n    monthlyTotal.value = expenses.value.reduce((sum, exp) => sum + exp.amount, 0)\r\n  } catch (error) {\r\n    console.error('Error fetching expenses:', error)\r\n    toast.error('Failed to load expenses')\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\nconst fetchSummary = async () => {\r\n  try {\r\n    const now = new Date()\r\n    const monthResponse = await api.get('/expenses/summary/monthly', {\r\n      params: { month: now.getMonth() + 1, year: now.getFullYear(), type: 'expense' }\r\n    })\r\n    monthlyTotal.value = monthResponse.data.total || 0\r\n    \r\n    const yearResponse = await api.get('/expenses/summary/monthly', {\r\n      params: { year: now.getFullYear(), type: 'expense' }\r\n    })\r\n    yearlyTotal.value = yearResponse.data.total || 0\r\n    averageMonthly.value = yearlyTotal.value / 12\r\n  } catch (error) {\r\n    console.error('Error fetching expense summary:', error)\r\n  }\r\n}\r\n\r\nconst editExpense = (expense) => {\r\n  console.log('Edit expense:', expense)\r\n  // TODO: Implement edit functionality\r\n}\r\n\r\nconst deleteExpense = async (expense) => {\r\n  if (!confirm('Are you sure you want to delete this expense?')) return\r\n  \r\n  try {\r\n    await api.delete(`/expenses/${expense.id}`)\r\n    toast.success('Expense deleted successfully')\r\n    fetchExpenses()\r\n    fetchSummary()\r\n  } catch (error) {\r\n    console.error('Error deleting expense:', error)\r\n    toast.error('Failed to delete expense')\r\n  }\r\n}\r\n\r\nwatch([categoryFilter, periodFilter], () => {\r\n  fetchExpenses()\r\n})\r\n\r\nonMounted(() => {\r\n  fetchExpenses()\r\n  fetchSummary()\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.expenses-page {\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-xl);\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-md);\r\n  \r\n  .header-content {\r\n    h1 {\r\n      font-size: 2rem;\r\n      font-weight: 800;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      color: var(--text-secondary);\r\n    }\r\n  }\r\n}\r\n\r\n.expenses-summary {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\r\n  gap: var(--spacing-lg);\r\n  margin-bottom: var(--spacing-xl);\r\n  \r\n  .summary-card {\r\n    background: var(--bg-primary);\r\n    border-radius: var(--radius-lg);\r\n    padding: var(--spacing-lg);\r\n    display: flex;\r\n    align-items: center;\r\n    gap: var(--spacing-md);\r\n    box-shadow: var(--shadow-sm);\r\n    \r\n    .summary-icon {\r\n      width: 60px;\r\n      height: 60px;\r\n      border-radius: var(--radius-lg);\r\n      background: linear-gradient(135deg, var(--danger) 0%, var(--danger-light) 100%);\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      color: white;\r\n      font-size: 1.5rem;\r\n    }\r\n    \r\n    .summary-content {\r\n      display: flex;\r\n      flex-direction: column;\r\n      \r\n      .summary-label {\r\n        font-size: 0.875rem;\r\n        color: var(--text-secondary);\r\n        margin-bottom: var(--spacing-xs);\r\n      }\r\n      \r\n      .summary-value {\r\n        font-size: 1.75rem;\r\n        font-weight: 800;\r\n        color: var(--text-primary);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n.filters-bar {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  margin-bottom: var(--spacing-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  display: flex;\r\n  gap: var(--spacing-lg);\r\n  flex-wrap: wrap;\r\n  \r\n  .filter-group {\r\n    flex: 1;\r\n    min-width: 200px;\r\n    \r\n    label {\r\n      display: block;\r\n      font-weight: 600;\r\n      color: var(--text-secondary);\r\n      margin-bottom: var(--spacing-sm);\r\n      font-size: 0.875rem;\r\n    }\r\n  }\r\n}\r\n\r\n.expenses-table {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  overflow: hidden;\r\n  \r\n  table {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    \r\n    thead {\r\n      background: var(--bg-secondary);\r\n      \r\n      th {\r\n        padding: var(--spacing-md) var(--spacing-lg);\r\n        text-align: left;\r\n        font-weight: 600;\r\n        color: var(--text-secondary);\r\n        font-size: 0.875rem;\r\n        text-transform: uppercase;\r\n        letter-spacing: 0.5px;\r\n      }\r\n    }\r\n    \r\n    tbody {\r\n      tr {\r\n        border-bottom: 1px solid var(--border-color);\r\n        transition: background-color 0.2s;\r\n        \r\n        &:hover {\r\n          background: var(--bg-secondary);\r\n        }\r\n        \r\n        &:last-child {\r\n          border-bottom: none;\r\n        }\r\n        \r\n        td {\r\n          padding: var(--spacing-md) var(--spacing-lg);\r\n          color: var(--text-primary);\r\n          \r\n          &.amount {\r\n            font-weight: 700;\r\n            color: var(--danger);\r\n          }\r\n          \r\n          &.actions {\r\n            display: flex;\r\n            gap: var(--spacing-sm);\r\n          }\r\n          \r\n    