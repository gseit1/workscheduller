{"ast":null,"code":"import { ref, computed, onMounted } from 'vue';\nexport default {\n  __name: 'Expenses',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const showAddModal = ref(false);\n    const categoryFilter = ref('all');\n    const periodFilter = ref('month');\n    const monthlyTotal = ref(450);\n    const yearlyTotal = ref(5400);\n    const averageMonthly = ref(450);\n    const expenses = ref([{\n      id: 1,\n      date: 'Jan 15, 2024',\n      description: 'Adobe Creative Cloud',\n      category: 'software',\n      amount: 54.99\n    }, {\n      id: 2,\n      date: 'Jan 10, 2024',\n      description: 'Office Supplies',\n      category: 'office',\n      amount: 125.50\n    }, {\n      id: 3,\n      date: 'Jan 5, 2024',\n      description: 'GitHub Pro',\n      category: 'software',\n      amount: 7.00\n    }]);\n    const editExpense = expense => {\n      console.log('Edit expense:', expense);\n    };\n    const deleteExpense = expense => {\n      console.log('Delete expense:', expense);\n    };\n    onMounted(() => {\n      // TODO: Fetch expenses from API\n    });\n    const __returned__ = {\n      showAddModal,\n      categoryFilter,\n      periodFilter,\n      monthlyTotal,\n      yearlyTotal,\n      averageMonthly,\n      expenses,\n      editExpense,\n      deleteExpense,\n      ref,\n      computed,\n      onMounted\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","showAddModal","categoryFilter","periodFilter","monthlyTotal","yearlyTotal","averageMonthly","expenses","id","date","description","category","amount","editExpense","expense","console","log","deleteExpense"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Expenses.vue"],"sourcesContent":["<template>\r\n  <div class=\"expenses-page\">\r\n    <div class=\"page-header\">\r\n      <div class=\"header-content\">\r\n        <h1>Expenses</h1>\r\n        <p>Track and manage your business expenses</p>\r\n      </div>\r\n      <div class=\"header-actions\">\r\n        <button class=\"btn btn-primary\" @click=\"showAddModal = true\">\r\n          <i class=\"bi bi-plus-circle\"></i>\r\n          <span>Add Expense</span>\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"expenses-summary\">\r\n      <div class=\"summary-card\">\r\n        <div class=\"summary-icon\">\r\n          <i class=\"bi bi-calendar-month\"></i>\r\n        </div>\r\n        <div class=\"summary-content\">\r\n          <span class=\"summary-label\">This Month</span>\r\n          <span class=\"summary-value\">${{ monthlyTotal }}</span>\r\n        </div>\r\n      </div>\r\n      \r\n      <div class=\"summary-card\">\r\n        <div class=\"summary-icon\">\r\n          <i class=\"bi bi-calendar-range\"></i>\r\n        </div>\r\n        <div class=\"summary-content\">\r\n          <span class=\"summary-label\">This Year</span>\r\n          <span class=\"summary-value\">${{ yearlyTotal }}</span>\r\n        </div>\r\n      </div>\r\n      \r\n      <div class=\"summary-card\">\r\n        <div class=\"summary-icon\">\r\n          <i class=\"bi bi-piggy-bank\"></i>\r\n        </div>\r\n        <div class=\"summary-content\">\r\n          <span class=\"summary-label\">Average/Month</span>\r\n          <span class=\"summary-value\">${{ averageMonthly }}</span>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"expenses-content\">\r\n      <div class=\"filters-bar\">\r\n        <div class=\"filter-group\">\r\n          <label>Category</label>\r\n          <select v-model=\"categoryFilter\" class=\"form-select\">\r\n            <option value=\"all\">All Categories</option>\r\n            <option value=\"software\">Software</option>\r\n            <option value=\"equipment\">Equipment</option>\r\n            <option value=\"office\">Office</option>\r\n            <option value=\"other\">Other</option>\r\n          </select>\r\n        </div>\r\n        \r\n        <div class=\"filter-group\">\r\n          <label>Period</label>\r\n          <select v-model=\"periodFilter\" class=\"form-select\">\r\n            <option value=\"month\">This Month</option>\r\n            <option value=\"quarter\">This Quarter</option>\r\n            <option value=\"year\">This Year</option>\r\n            <option value=\"all\">All Time</option>\r\n          </select>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"expenses-table\">\r\n        <table>\r\n          <thead>\r\n            <tr>\r\n              <th>Date</th>\r\n              <th>Description</th>\r\n              <th>Category</th>\r\n              <th>Amount</th>\r\n              <th>Actions</th>\r\n            </tr>\r\n          </thead>\r\n          <tbody>\r\n            <tr v-for=\"expense in expenses\" :key=\"expense.id\">\r\n              <td>{{ expense.date }}</td>\r\n              <td>{{ expense.description }}</td>\r\n              <td>\r\n                <span :class=\"['badge', `badge-${expense.category}`]\">\r\n                  {{ expense.category }}\r\n                </span>\r\n              </td>\r\n              <td class=\"amount\">${{ expense.amount }}</td>\r\n              <td class=\"actions\">\r\n                <button @click=\"editExpense(expense)\" class=\"btn btn-sm btn-icon\">\r\n                  <i class=\"bi bi-pencil\"></i>\r\n                </button>\r\n                <button @click=\"deleteExpense(expense)\" class=\"btn btn-sm btn-icon btn-danger\">\r\n                  <i class=\"bi bi-trash\"></i>\r\n                </button>\r\n              </td>\r\n            </tr>\r\n          </tbody>\r\n        </table>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\n\r\nconst showAddModal = ref(false)\r\nconst categoryFilter = ref('all')\r\nconst periodFilter = ref('month')\r\nconst monthlyTotal = ref(450)\r\nconst yearlyTotal = ref(5400)\r\nconst averageMonthly = ref(450)\r\n\r\nconst expenses = ref([\r\n  {\r\n    id: 1,\r\n    date: 'Jan 15, 2024',\r\n    description: 'Adobe Creative Cloud',\r\n    category: 'software',\r\n    amount: 54.99\r\n  },\r\n  {\r\n    id: 2,\r\n    date: 'Jan 10, 2024',\r\n    description: 'Office Supplies',\r\n    category: 'office',\r\n    amount: 125.50\r\n  },\r\n  {\r\n    id: 3,\r\n    date: 'Jan 5, 2024',\r\n    description: 'GitHub Pro',\r\n    category: 'software',\r\n    amount: 7.00\r\n  }\r\n])\r\n\r\nconst editExpense = (expense) => {\r\n  console.log('Edit expense:', expense)\r\n}\r\n\r\nconst deleteExpense = (expense) => {\r\n  console.log('Delete expense:', expense)\r\n}\r\n\r\nonMounted(() => {\r\n  // TODO: Fetch expenses from API\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.expenses-page {\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-xl);\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-md);\r\n  \r\n  .header-content {\r\n    h1 {\r\n      font-size: 2rem;\r\n      font-weight: 800;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      color: var(--text-secondary);\r\n    }\r\n  }\r\n}\r\n\r\n.expenses-summary {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\r\n  gap: var(--spacing-lg);\r\n  margin-bottom: var(--spacing-xl);\r\n  \r\n  .summary-card {\r\n    background: var(--bg-primary);\r\n    border-radius: var(--radius-lg);\r\n    padding: var(--spacing-lg);\r\n    display: flex;\r\n    align-items: center;\r\n    gap: var(--spacing-md);\r\n    box-shadow: var(--shadow-sm);\r\n    \r\n    .summary-icon {\r\n      width: 60px;\r\n      height: 60px;\r\n      border-radius: var(--radius-lg);\r\n      background: linear-gradient(135deg, var(--danger) 0%, var(--danger-light) 100%);\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      color: white;\r\n      font-size: 1.5rem;\r\n    }\r\n    \r\n    .summary-content {\r\n      display: flex;\r\n      flex-direction: column;\r\n      \r\n      .summary-label {\r\n        font-size: 0.875rem;\r\n        color: var(--text-secondary);\r\n        margin-bottom: var(--spacing-xs);\r\n      }\r\n      \r\n      .summary-value {\r\n        font-size: 1.75rem;\r\n        font-weight: 800;\r\n        color: var(--text-primary);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n.filters-bar {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  margin-bottom: var(--spacing-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  display: flex;\r\n  gap: var(--spacing-lg);\r\n  flex-wrap: wrap;\r\n  \r\n  .filter-group {\r\n    flex: 1;\r\n    min-width: 200px;\r\n    \r\n    label {\r\n      display: block;\r\n      font-weight: 600;\r\n      color: var(--text-secondary);\r\n      margin-bottom: var(--spacing-sm);\r\n      font-size: 0.875rem;\r\n    }\r\n  }\r\n}\r\n\r\n.expenses-table {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  overflow: hidden;\r\n  \r\n  table {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    \r\n    thead {\r\n      background: var(--bg-secondary);\r\n      \r\n      th {\r\n        padding: var(--spacing-md) var(--spacing-lg);\r\n        text-align: left;\r\n        font-weight: 600;\r\n        color: var(--text-secondary);\r\n        font-size: 0.875rem;\r\n        text-transform: uppercase;\r\n        letter-spacing: 0.5px;\r\n      }\r\n    }\r\n    \r\n    tbody {\r\n      tr {\r\n        border-bottom: 1px solid var(--border-color);\r\n        transition: background-color 0.2s;\r\n        \r\n        &:hover {\r\n          background: var(--bg-secondary);\r\n        }\r\n        \r\n        &:last-child {\r\n          border-bottom: none;\r\n        }\r\n        \r\n        td {\r\n          padding: var(--spacing-md) var(--spacing-lg);\r\n          color: var(--text-primary);\r\n          \r\n          &.amount {\r\n            font-weight: 700;\r\n            color: var(--danger);\r\n          }\r\n          \r\n          &.actions {\r\n            display: flex;\r\n            gap: var(--spacing-sm);\r\n          }\r\n          \r\n          .badge {\r\n            display: inline-block;\r\n            padding: var(--spacing-xs) var(--spacing-sm);\r\n            border-radius: var(--radius-full);\r\n            font-size: 0.75rem;\r\n            font-weight: 600;\r\n            text-transform: capitalize;\r\n            \r\n            &.badge-software {\r\n              background: var(--primary-light);\r\n              color: var(--primary);\r\n            }\r\n            \r\n            &.badge-equipment {\r\n              background: var(--warning-light);\r\n              color: var(--warning);\r\n            }\r\n            \r\n            &.badge-office {\r\n              background: var(--success-light);\r\n              color: var(--success);\r\n            }\r\n            \r\n            &.badge-other {\r\n              background: var(--bg-secondary);\r\n              color: var(--text-secondary);\r\n            }\r\n          }\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .page-header {\r\n    .header-content h1 {\r\n      font-size: 1.5rem;\r\n    }\r\n  }\r\n  \r\n  .expenses-table {\r\n    overflow-x: auto;\r\n    \r\n    table {\r\n      min-width: 600px;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA6GA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,QAAQ,KAAK;;;;;;;IAE9C,MAAMC,YAAY,GAAGH,GAAG,CAAC,KAAK,CAAC;IAC/B,MAAMI,cAAc,GAAGJ,GAAG,CAAC,KAAK,CAAC;IACjC,MAAMK,YAAY,GAAGL,GAAG,CAAC,OAAO,CAAC;IACjC,MAAMM,YAAY,GAAGN,GAAG,CAAC,GAAG,CAAC;IAC7B,MAAMO,WAAW,GAAG