{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport { useAuthStore } from '../stores/auth';\nimport { useToast } from 'vue-toastification';\nexport default {\n  __name: 'Profile',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const authStore = useAuthStore();\n    const toast = useToast();\n    const fileInput = ref(null);\n    const profile = ref({\n      name: '',\n      email: '',\n      hourlyRate: 30,\n      currency: 'USD',\n      timezone: 'America/New_York',\n      emailNotifications: true,\n      avatar: ''\n    });\n    const passwordForm = ref({\n      current: '',\n      new: '',\n      confirm: ''\n    });\n    const handleImageUpload = event => {\n      const file = event.target.files[0];\n      if (!file) return;\n\n      // Check file size (max 5MB)\n      if (file.size > 5 * 1024 * 1024) {\n        toast.error('Image size must be less than 5MB');\n        return;\n      }\n\n      // Check file type\n      if (!file.type.startsWith('image/')) {\n        toast.error('Please select a valid image file');\n        return;\n      }\n\n      // Create preview\n      const reader = new FileReader();\n      reader.onload = e => {\n        profile.value.avatar = e.target.result;\n        authStore.updateUser({\n          avatar: e.target.result\n        });\n        toast.success('Profile photo updated!');\n      };\n      reader.readAsDataURL(file);\n    };\n    const removeAvatar = () => {\n      profile.value.avatar = '';\n      authStore.updateUser({\n        avatar: ''\n      });\n      toast.success('Profile photo removed!');\n    };\n    const updateProfile = () => {\n      authStore.updateUser({\n        name: profile.value.name,\n        email: profile.value.email,\n        hourlyRate: profile.value.hourlyRate\n      });\n      toast.success('Profile updated successfully!');\n      // TODO: Call API to update profile\n    };\n    const updatePassword = () => {\n      if (passwordForm.value.new !== passwordForm.value.confirm) {\n        toast.error('Passwords do not match!');\n        return;\n      }\n      toast.success('Password updated successfully!');\n      passwordForm.value = {\n        current: '',\n        new: '',\n        confirm: ''\n      };\n      // TODO: Call API to update password\n    };\n    onMounted(() => {\n      if (authStore.user) {\n        profile.value.name = authStore.user.name || authStore.user.username;\n        profile.value.email = authStore.user.email;\n        profile.value.hourlyRate = authStore.user.hourlyRate || 30;\n        profile.value.avatar = authStore.user.avatar || '';\n      }\n    });\n    const __returned__ = {\n      authStore,\n      toast,\n      fileInput,\n      profile,\n      passwordForm,\n      handleImageUpload,\n      removeAvatar,\n      updateProfile,\n      updatePassword,\n      ref,\n      onMounted,\n      get useAuthStore() {\n        return useAuthStore;\n      },\n      get useToast() {\n        return useToast;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useAuthStore","useToast","authStore","toast","fileInput","profile","name","email","hourlyRate","currency","timezone","emailNotifications","avatar","passwordForm","current","new","confirm","handleImageUpload","event","file","target","files","size","error","type","startsWith","reader","FileReader","onload","e","value","result","updateUser","success","readAsDataURL","removeAvatar","updateProfile","updatePassword","user","username"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Profile.vue"],"sourcesContent":["<template>\r\n  <div class=\"profile-page\">\r\n    <div class=\"page-header\">\r\n      <h1>Profile Settings</h1>\r\n      <p>Manage your account information and preferences</p>\r\n    </div>\r\n\r\n    <div class=\"profile-content\">\r\n      <div class=\"profile-card\">\r\n        <div class=\"avatar-section\">\r\n          <div class=\"avatar-wrapper\">\r\n            <div class=\"avatar\" :class=\"{ 'has-image': profile.avatar }\">\r\n              <img v-if=\"profile.avatar\" :src=\"profile.avatar\" alt=\"Profile\" />\r\n              <i v-else class=\"bi bi-person-circle\"></i>\r\n            </div>\r\n            <input \r\n              ref=\"fileInput\" \r\n              type=\"file\" \r\n              accept=\"image/*\" \r\n              @change=\"handleImageUpload\" \r\n              style=\"display: none\"\r\n            />\r\n            <button \r\n              type=\"button\" \r\n              class=\"btn btn-sm btn-primary avatar-btn\"\r\n              @click=\"$refs.fileInput.click()\"\r\n            >\r\n              <i class=\"bi bi-camera\"></i>\r\n            </button>\r\n          </div>\r\n          <button \r\n            v-if=\"profile.avatar\" \r\n            type=\"button\"\r\n            class=\"btn btn-sm btn-outline-danger remove-avatar-btn\"\r\n            @click=\"removeAvatar\"\r\n          >\r\n            <i class=\"bi bi-trash\"></i>\r\n            Remove Photo\r\n          </button>\r\n        </div>\r\n\r\n        <form @submit.prevent=\"updateProfile\" class=\"profile-form\">\r\n          <div class=\"form-section\">\r\n            <h3>Personal Information</h3>\r\n            \r\n            <div class=\"form-group\">\r\n              <label>Full Name</label>\r\n              <input \r\n                v-model=\"profile.name\" \r\n                type=\"text\" \r\n                class=\"form-control\"\r\n                placeholder=\"Enter your name\"\r\n              />\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <label>Email Address</label>\r\n              <input \r\n                v-model=\"profile.email\" \r\n                type=\"email\" \r\n                class=\"form-control\"\r\n                placeholder=\"Enter your email\"\r\n              />\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <label>Hourly Rate ($)</label>\r\n              <input \r\n                v-model=\"profile.hourlyRate\" \r\n                type=\"number\" \r\n                class=\"form-control\"\r\n                step=\"0.01\"\r\n                placeholder=\"30.00\"\r\n              />\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"form-section\">\r\n            <h3>Preferences</h3>\r\n            \r\n            <div class=\"form-group\">\r\n              <label>Currency</label>\r\n              <select v-model=\"profile.currency\" class=\"form-select\">\r\n                <option value=\"USD\">USD ($)</option>\r\n                <option value=\"EUR\">EUR (€)</option>\r\n                <option value=\"GBP\">GBP (£)</option>\r\n                <option value=\"CAD\">CAD ($)</option>\r\n              </select>\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <label>Timezone</label>\r\n              <select v-model=\"profile.timezone\" class=\"form-select\">\r\n                <option value=\"America/New_York\">Eastern Time (ET)</option>\r\n                <option value=\"America/Chicago\">Central Time (CT)</option>\r\n                <option value=\"America/Denver\">Mountain Time (MT)</option>\r\n                <option value=\"America/Los_Angeles\">Pacific Time (PT)</option>\r\n              </select>\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <div class=\"checkbox-group\">\r\n                <input \r\n                  v-model=\"profile.emailNotifications\" \r\n                  type=\"checkbox\" \r\n                  id=\"emailNotifications\"\r\n                />\r\n                <label for=\"emailNotifications\">\r\n                  Email notifications for goal achievements\r\n                </label>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"form-actions\">\r\n            <button type=\"submit\" class=\"btn btn-primary btn-lg\">\r\n              <i class=\"bi bi-check-circle\"></i>\r\n              Save Changes\r\n            </button>\r\n          </div>\r\n        </form>\r\n      </div>\r\n\r\n      <div class=\"security-card\">\r\n        <h3>Security</h3>\r\n        <p>Update your password to keep your account secure</p>\r\n        \r\n        <form @submit.prevent=\"updatePassword\" class=\"password-form\">\r\n          <div class=\"form-group\">\r\n            <label>Current Password</label>\r\n            <input \r\n              v-model=\"passwordForm.current\" \r\n              type=\"password\" \r\n              class=\"form-control\"\r\n              placeholder=\"Enter current password\"\r\n            />\r\n          </div>\r\n          \r\n          <div class=\"form-group\">\r\n            <label>New Password</label>\r\n            <input \r\n              v-model=\"passwordForm.new\" \r\n              type=\"password\" \r\n              class=\"form-control\"\r\n              placeholder=\"Enter new password\"\r\n            />\r\n          </div>\r\n          \r\n          <div class=\"form-group\">\r\n            <label>Confirm New Password</label>\r\n            <input \r\n              v-model=\"passwordForm.confirm\" \r\n              type=\"password\" \r\n              class=\"form-control\"\r\n              placeholder=\"Confirm new password\"\r\n            />\r\n          </div>\r\n          \r\n          <button type=\"submit\" class=\"btn btn-secondary\">\r\n            <i class=\"bi bi-shield-check\"></i>\r\n            Update Password\r\n          </button>\r\n        </form>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport { useAuthStore } from '../stores/auth'\r\nimport { useToast } from 'vue-toastification'\r\n\r\nc