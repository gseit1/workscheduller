ew Date(day.date), 'yyyy-MM-dd');\n      if (!scheduledDays.value.includes(dateStr)) {\n        scheduledDays.value.push(dateStr);\n      }\n      // TODO: Call API to save schedule\n    };\n    const removeSchedule = day => {\n      const dateStr = format(new Date(day.date), 'yyyy-MM-dd');\n      const index = scheduledDays.value.indexOf(dateStr);\n      if (index > -1) {\n        scheduledDays.value.splice(index, 1);\n      }\n      // TODO: Call API to remove schedule\n    };\n    onMounted(() => {\n      // TODO: Fetch scheduled days from API\n    });\n    const __returned__ = {\n      currentWeekStart,\n      scheduledDays,\n      showAddModal,\n      weekRange,\n      weekDays,\n      upcomingDays,\n      previousWeek,\n      nextWeek,\n      scheduleDay,\n      removeSchedule,\n      ref,\n      computed,\n      onMounted,\n      get format() {\n        return format;\n      },\n      get startOfWeek() {\n        return startOfWeek;\n      },\n      get addDays() {\n        return addDays;\n      },\n      get addWeeks() {\n        return addWeeks;\n      },\n      get subWeeks() {\n        return subWeeks;\n      },\n      get isToday() {\n        return isToday;\n      },\n      get isBefore() {\n        return isBefore;\n      },\n      get startOfDay() {\n        return startOfDay;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","format","startOfWeek","addDays","addWeeks","subWeeks","isToday","isBefore","startOfDay","currentWeekStart","Date","weekStartsOn","scheduledDays","showAddModal","weekRange","start","value","end","weekDays","days","today","i","date","dateStr","push","toISOString","dayName","isPast","isScheduled","includes","upcomingDays","map","rawDate","filter","item","sort","a","b","slice","previousWeek","nextWeek","scheduleDay","day","removeSchedule","index","indexOf","splice"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Schedule.vue"],"sourcesContent":["<template>\r\n  <div class=\"schedule-page\">\r\n    <div class=\"page-header\">\r\n      <div class=\"header-content\">\r\n        <h1>Schedule</h1>\r\n        <p>Manage your work schedule and planned days</p>\r\n      </div>\r\n      <div class=\"header-actions\">\r\n        <button class=\"btn btn-primary\" @click=\"showAddModal = true\">\r\n          <i class=\"bi bi-plus-circle\"></i>\r\n          <span>Add Day</span>\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"schedule-content\">\r\n      <!-- Week View -->\r\n      <div class=\"week-selector\">\r\n        <button @click=\"previousWeek\" class=\"btn btn-icon\">\r\n          <i class=\"bi bi-chevron-left\"></i>\r\n        </button>\r\n        <h2>{{ weekRange }}</h2>\r\n        <button @click=\"nextWeek\" class=\"btn btn-icon\">\r\n          <i class=\"bi bi-chevron-right\"></i>\r\n        </button>\r\n      </div>\r\n\r\n      <div class=\"week-grid\">\r\n        <div \r\n          v-for=\"day in weekDays\" \r\n          :key=\"day.date\"\r\n          :class=\"['day-card', {\r\n            'today': day.isToday,\r\n            'scheduled': day.isScheduled,\r\n            'past': day.isPast\r\n          }]\"\r\n        >\r\n          <div class=\"day-header\">\r\n            <div class=\"day-name\">{{ day.dayName }}</div>\r\n            <div class=\"day-date\">{{ day.dateStr }}</div>\r\n          </div>\r\n          <div class=\"day-content\">\r\n            <div v-if=\"day.isScheduled\" class=\"scheduled-info\">\r\n              <i class=\"bi bi-calendar-check\"></i>\r\n              <span>Scheduled</span>\r\n            </div>\r\n            <div v-else class=\"no-schedule\">\r\n              <i class=\"bi bi-calendar-x\"></i>\r\n              <span>Not scheduled</span>\r\n            </div>\r\n          </div>\r\n          <div class=\"day-actions\">\r\n            <button \r\n              v-if=\"!day.isScheduled && !day.isPast\" \r\n              @click=\"scheduleDay(day)\"\r\n              class=\"btn btn-sm btn-primary\"\r\n            >\r\n              Schedule\r\n            </button>\r\n            <button \r\n              v-else-if=\"day.isScheduled && !day.isPast\" \r\n              @click=\"removeSchedule(day)\"\r\n              class=\"btn btn-sm btn-danger\"\r\n            >\r\n              Remove\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Upcoming Scheduled Days -->\r\n      <div class=\"upcoming-section\">\r\n        <h3>Upcoming Scheduled Days</h3>\r\n        <div class=\"upcoming-list\">\r\n          <div v-for=\"item in upcomingDays\" :key=\"item.date\" class=\"upcoming-item\">\r\n            <div class=\"upcoming-date\">\r\n              <i class=\"bi bi-calendar-event\"></i>\r\n              <span>{{ item.dateStr }}</span>\r\n            </div>\r\n            <div class=\"upcoming-day\">{{ item.dayName }}</div>\r\n            <button @click=\"removeSchedule(item)\" class=\"btn btn-sm btn-outline-danger\">\r\n              <i class=\"bi bi-trash\"></i>\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\nimport { format, startOfWeek, addDays, addWeeks, subWeeks, isToday, isBefore, startOfDay } from 'date-fns'\r\n\r\nconst currentWeekStart = ref(startOfWeek(new Date(), { weekStartsOn: 0 }))\r\nconst scheduledDays = ref([])\r\nconst showAddModal = ref(false)\r\n\r\nconst weekRange = computed(() => {\r\n  const start = currentWeekStart.value\r\n  const end = addDays(start, 6)\r\n  return `${format(start, 'MMM d')} - ${format(end, 'MMM d, yyyy')}`\r\n})\r\n\r\nconst weekDays = computed(() => {\r\n  const days = []\r\n  const today = startOfDay(new Date())\r\n  \r\n  for (let i = 0; i < 7; i++) {\r\n    const date = addDays(currentWeekStart.value, i)\r\n    const dateStr = format(date, 'yyyy-MM-dd')\r\n    \r\n    days.push({\r\n      date: date.toISOString(),\r\n      dateStr: format(date, 'MMM d'),\r\n      dayName: format(date, 'EEEE'),\r\n      isToday: isToday(date),\r\n      isPast: isBefore(date, today),\r\n      isScheduled: scheduledDays.value.includes(dateStr)\r\n    })\r\n  }\r\n  \r\n  return days\r\n})\r\n\r\nconst upcomingDays = computed(() => {\r\n  const today = startOfDay(new Date())\r\n  return scheduledDays.value\r\n    .map(dateStr => {\r\n      const date = new Date(dateStr)\r\n      return {\r\n        date: dateStr,\r\n        dateStr: format(date, 'MMM d, yyyy'),\r\n        dayName: format(date, 'EEEE'),\r\n        rawDate: date\r\n      }\r\n    })\r\n    .filter(item => !isBefore(item.rawDate, today))\r\n    .sort((a, b) => a.rawDate - b.rawDate)\r\n    .slice(0, 5)\r\n})\r\n\r\nconst previousWeek = () => {\r\n  currentWeekStart.value = subWeeks(currentWeekStart.value, 1)\r\n}\r\n\r\nconst nextWeek = () => {\r\n  currentWeekStart.value = addWeeks(currentWeekStart.value, 1)\r\n}\r\n\r\nconst scheduleDay = (day) => {\r\n  const dateStr = format(new Date(day.date), 'yyyy-MM-dd')\r\n  if (!scheduledDays.value.includes(dateStr)) {\r\n    scheduledDays.value.push(dateStr)\r\n  }\r\n  // TODO: Call API to save schedule\r\n}\r\n\r\nconst removeSchedule = (day) => {\r\n  const dateStr = format(new Date(day.date), 'yyyy-MM-dd')\r\n  const index = scheduledDays.value.indexOf(dateStr)\r\n  if (index > -1) {\r\n    scheduledDays.value.splice(index, 1)\r\n  }\r\n  // TODO: Call API to remove schedule\r\n}\r\n\r\nonMounted(() => {\r\n  // TODO: Fetch scheduled days from API\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.schedule-page {\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-xl);\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-md);\r\n  \r\n  .header-content {\r\n    h1 {\r\n      font-size: 2rem;\r\n      font-weight: 800;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      color: var(--text-secondary);\r\n    }\r\n  }\r\n}\r\n\r\n.schedule-content {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--spacing-xl);\r\n}\r\n\r\n.week-selector {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: var(--spacing-lg);\r\n  \r\n  h2 {\r\n    font-size: 1.5rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    min-width: 250px;\r\n    text-align: center;\r\n  }\r\n}\r\n\r\n.week-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));\r\n  gap: var(--spacing-md);\r\n}\r\n\r\n.day-card {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  transition: all 0.3s;\r\n  border: 2px solid transparent;\r\n  \r\n  &.today {\r\n    border-color: var(--primary);\r\n    box-shadow: var(--shadow-md);\r\n  }\r\n  \r\n  &.scheduled {\r\n    background: linear-gradient(135deg, var(--success-light) 0%, var(--bg-primary) 100%);\r\n  }\r\n  \r\n  &.past {\r\n    opacity: 0.6;\r\n  }\r\n  \r\n  .day-header {\r\n    text-align: center;\r\n    margin-bottom: var(--spacing-md);\r\n    \r\n    .day-name {\r\n      font-weight: 700;\r\n      color: var(--text-primary);\r\n      font-size: 1rem;\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    .day-date {\r\n      color: var(--text-secondary);\r\n      font-size: 0.875rem;\r\n    }\r\n  }\r\n  \r\n  .day-content {\r\n    text-align: center;\r\n    margin-bottom: var(--spacing-md);\r\n    \r\n    .scheduled-info,\r\n    .no-schedule {\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      gap: var(--spacing-sm);\r\n      padding: var(--spacing-sm);\r\n      border-radius: var(--radius-md);\r\n      font-size: 0.875rem;\r\n    }\r\n    \r\n    .scheduled-info {\r\n      color: var(--success);\r\n      background: var(--success-light);\r\n    }\r\n    \r\n    .no-schedule {\r\n      color: var(--text-secondary);\r\n      background: var(--bg-secondary);\r\n    }\r\n  }\r\n  \r\n  .day-actions {\r\n    display: flex;\r\n    justify-content: center;\r\n    \r\n    button {\r\n      width: 100%;\r\n    }\r\n  }\r\n}\r\n\r\n.upcoming-section {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-xl);\r\n  box-shadow: var(--shadow-sm);\r\n  \r\n  h3 {\r\n    font-size: 1.25rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-lg);\r\n  }\r\n  \r\n  .upcoming-list {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: var(--spacing-md);\r\n  }\r\n  \r\n  .upcoming-item {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: var(--spacing-md);\r\n    padding: var(--spacing-md);\r\n    background: var(--bg-secondary);\r\n    border-radius: var(--radius-md);\r\n    \r\n    .upcoming-date {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: var(--spacing-sm);\r\n      color: var(--text-primary);\r\n      font-weight: 600;\r\n      flex: 1;\r\n    }\r\n    \r\n    .upcoming-day {\r\n      color: var(--text-secondary);\r\n      font-size: 0.875rem;\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .page-header {\r\n    .header-content h1 {\r\n      font-size: 1.5rem;\r\n    }\r\n  }\r\n  \r\n  .week-selector h2 {\r\n    font-size: 1.125rem;\r\n    min-width: 200px;\r\n  }\r\n  \r\n  .week-grid {\r\n    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA2FA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,QAAQ,KAAK;AAC9C,SAASC,MAAM,EAAEC,WAAW,EAAEC,OAAO,EAAEC,QAAQ,EAAEC,QAAQ,EAAEC,OAAO,EAAEC,QAAQ,EAAEC,UAAU,QAAQ,UAAU;;;;;;;IAE1G,MAAMC,gBAAgB,GAAGX,G