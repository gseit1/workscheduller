      <div class=\"day-content\">\r\n            <div v-if=\"day.isScheduled\" class=\"scheduled-info\">\r\n              <i class=\"bi bi-calendar-check\"></i>\r\n              <span>Scheduled</span>\r\n            </div>\r\n            <div v-else class=\"no-schedule\">\r\n              <i class=\"bi bi-calendar-x\"></i>\r\n              <span>Not scheduled</span>\r\n            </div>\r\n          </div>\r\n          <div class=\"day-actions\">\r\n            <button \r\n              v-if=\"!day.isScheduled && !day.isPast\" \r\n              @click=\"scheduleDay(day)\"\r\n              class=\"btn btn-sm btn-primary\"\r\n            >\r\n              Schedule\r\n            </button>\r\n            <button \r\n              v-else-if=\"day.isScheduled && !day.isPast\" \r\n              @click=\"removeSchedule(day)\"\r\n              class=\"btn btn-sm btn-danger\"\r\n            >\r\n              Remove\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Upcoming Scheduled Days -->\r\n      <div class=\"upcoming-section\">\r\n        <h3>Upcoming Scheduled Days</h3>\r\n        <div class=\"upcoming-list\">\r\n          <div v-for=\"item in upcomingDays\" :key=\"item.date\" class=\"upcoming-item\">\r\n            <div class=\"upcoming-date\">\r\n              <i class=\"bi bi-calendar-event\"></i>\r\n              <span>{{ item.dateStr }}</span>\r\n            </div>\r\n            <div class=\"upcoming-day\">{{ item.dayName }}</div>\r\n            <button @click=\"removeSchedule(item)\" class=\"btn btn-sm btn-outline-danger\">\r\n              <i class=\"bi bi-trash\"></i>\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\nimport { format, startOfWeek, addDays, addWeeks, subWeeks, isToday, isBefore, startOfDay } from 'date-fns'\r\nimport api from '../services/api'\r\nimport { useToast } from 'vue-toastification'\r\n\r\nconst toast = useToast()\r\nconst currentWeekStart = ref(startOfWeek(new Date(), { weekStartsOn: 0 }))\r\nconst scheduledDays = ref([])\r\nconst showAddModal = ref(false)\r\nconst loading = ref(false)\r\n\r\nconst fetchScheduledDays = async () => {\r\n  try {\r\n    loading.value = true\r\n    const startDate = format(currentWeekStart.value, 'yyyy-MM-dd')\r\n    const endDate = format(addDays(currentWeekStart.value, 6), 'yyyy-MM-dd')\r\n    \r\n    const response = await api.get('/calendar/events', {\r\n      params: { startDate, endDate }\r\n    })\r\n    \r\n    scheduledDays.value = response.data.map(event => format(new Date(event.event_date), 'yyyy-MM-dd'))\r\n  } catch (error) {\r\n    console.error('Error fetching scheduled days:', error)\r\n    toast.error('Failed to load schedule')\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\nconst weekRange = computed(() => {\r\n  const start = currentWeekStart.value\r\n  const end = addDays(start, 6)\r\n  return `${format(start, 'MMM d')} - ${format(end, 'MMM d, yyyy')}`\r\n})\r\n\r\nconst weekDays = computed(() => {\r\n  const days = []\r\n  const today = startOfDay(new Date())\r\n  \r\n  for (let i = 0; i < 7; i++) {\r\n    const date = addDays(currentWeekStart.value, i)\r\n    const dateStr = format(date, 'yyyy-MM-dd')\r\n    \r\n    days.push({\r\n      date: date.toISOString(),\r\n      dateStr: format(date, 'MMM d'),\r\n      dayName: format(date, 'EEEE'),\r\n      isToday: isToday(date),\r\n      isPast: isBefore(date, today),\r\n      isScheduled: scheduledDays.value.includes(dateStr)\r\n    })\r\n  }\r\n  \r\n  return days\r\n})\r\n\r\nconst upcomingDays = computed(() => {\r\n  const today = startOfDay(new Date())\r\n  return scheduledDays.value\r\n    .map(dateStr => {\r\n      const date = new Date(dateStr)\r\n      return {\r\n        date: dateStr,\r\n        dateStr: format(date, 'MMM d, yyyy'),\r\n        dayName: format(date, 'EEEE'),\r\n        rawDate: date\r\n      }\r\n    })\r\n    .filter(item => !isBefore(item.rawDate, today))\r\n    .sort((a, b) => a.rawDate - b.rawDate)\r\n    .slice(0, 5)\r\n})\r\n\r\nconst previousWeek = () => {\r\n  currentWeekStart.value = subWeeks(currentWeekStart.value, 1)\r\n  fetchScheduledDays()\r\n}\r\n\r\nconst nextWeek = () => {\r\n  currentWeekStart.value = addWeeks(currentWeekStart.value, 1)\r\n  fetchScheduledDays()\r\n}\r\n\r\nconst scheduleDay = async (day) => {\r\n  try {\r\n    const dateStr = format(new Date(day.date), 'yyyy-MM-dd')\r\n    await api.post('/work/schedule', {\r\n      date: dateStr,\r\n      hours: 8,\r\n      notes: 'Scheduled work day'\r\n    })\r\n    toast.success('Day scheduled successfully')\r\n    fetchScheduledDays()\r\n  } catch (error) {\r\n    console.error('Error scheduling day:', error)\r\n    toast.error('Failed to schedule day')\r\n  }\r\n}\r\n\r\nconst removeSchedule = async (day) => {\r\n  try {\r\n    const dateStr = format(new Date(day.date), 'yyyy-MM-dd')\r\n    await api.delete(`/work/schedule/${dateStr}`)\r\n    toast.success('Schedule removed successfully')\r\n    fetchScheduledDays()\r\n  } catch (error) {\r\n    console.error('Error removing schedule:', error)\r\n    toast.error('Failed to remove schedule')\r\n  }\r\n}\r\n\r\nonMounted(() => {\r\n  fetchScheduledDays()\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.schedule-page {\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-xl);\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-md);\r\n  \r\n  .header-content {\r\n    h1 {\r\n      font-size: 2rem;\r\n      font-weight: 800;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      color: var(--text-secondary);\r\n    }\r\n  }\r\n}\r\n\r\n.schedule-content {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--spacing-xl);\r\n}\r\n\r\n.week-selector {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: var(--spacing-lg);\r\n  \r\n  h2 {\r\n    font-size: 1.5rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    min-width: 250px;\r\n    text-align: center;\r\n  }\r\n}\r\n\r\n.week-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));\r\n  gap: var(--spacing-md);\r\n}\r\n\r\n.day-card {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  box-shadow: var(--shadow-sm);\r\n  transition: all 0.3s;\r\n  border: 2px solid transparent;\r\n  \r\n  &.today {\r\n    border-color: var(--primary);\r\n    box-shadow: var(--shadow-md);\r\n  }\r\n  \r\n  &.scheduled {\r\n    background: linear-gradient(135deg, var(--success-light) 0%, var(--bg-primary) 100%);\r\n  }\r\n  \r\n  &.past {\r\n    opacity: 0.6;\r\n  }\r\n  \r\n  .day-header {\r\n    text-align: center;\r\n    margin-bottom: var(--spacing-md);\r\n    \r\n    .day-name {\r\n      font-weight: 700;\r\n      color: var(--text-primary);\r\n      font-size: 1rem;\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    .day-date {\r\n      color: var(--text-secondary);\r\n      font-size: 0.875rem;\r\n    }\r\n  }\r\n  \r\n  .day-content {\r\n    text-align: center;\r\n    margin-bottom: var(--spacing-md);\r\n    \r\n    .scheduled-info,\r\n    .no-schedule {\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      gap: var(--spacing-sm);\r\n      padding: var(--spacing-sm);\r\n      border-radius: var(--radius-md);\r\n      font-size: 0.875rem;\r\n    }\r\n    \r\n    .scheduled-info {\r\n      color: var(--success);\r\n      background: var(--success-light);\r\n    }\r\n    \r\n    .no-schedule {\r\n      color: var(--text-secondary);\r\n      background: var(--bg-secondary);\r\n    }\r\n  }\r\n  \r\n  .day-actions {\r\n    display: flex;\r\n    justify-content: center;\r\n    \r\n    button {\r\n      width: 100%;\r\n    }\r\n  }\r\n}\r\n\r\n.upcoming-section {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-xl);\r\n  box-shadow: var(--shadow-sm);\r\n  \r\n  h3 {\r\n    font-size: 1.25rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-lg);\r\n  }\r\n  \r\n  .upcoming-list {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: var(--spacing-md);\r\n  }\r\n  \r\n  .upcoming-item {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: var(--spacing-md);\r\n    padding: var(--spacing-md);\r\n    background: var(--bg-secondary);\r\n    border-radius: var(--radius-md);\r\n    \r\n    .upcoming-date {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: var(--spacing-sm);\r\n      color: var(--text-primary);\r\n      font-weight: 600;\r\n      flex: 1;\r\n    }\r\n    \r\n    .upcoming-day {\r\n      color: var(--text-secondary);\r\n      font-size: 0.875rem;\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .page-header {\r\n    .header-content h1 {\r\n      font-size: 1.5rem;\r\n    }\r\n  }\r\n  \r\n  .week-selector h2 {\r\n    font-size: 1.125rem;\r\n    min-width: 200px;\r\n  }\r\n  \r\n  .week-grid {\r\n    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));\r\n  }\r\n}\r\n</style>\r\n"],"mappings":";;EACOA,KAAK,EAAC;AAAe;;EACnBA,KAAK,EAAC;AAAa;;EAKjBA,KAAK,EAAC;AAAgB;;EAQxBA,KAAK,EAAC;AAAkB;;EAEtBA,KAAK,EAAC;AAAe;;EAUrBA,KAAK,EAAC;AAAW;;EAUbA,KAAK,EAAC;AAAY;;EAChBA,KAAK,EAAC;AAAU;;EAChBA,KAAK,EAAC;AAAU;;EAElBA,KAAK,EAAC;AAAa;;;EACMA,KAAK,EAAC;;;;EAItBA,KAAK,EAAC;;;EAKfA,KAAK,EAAC;AAAa;;;;EAoBvBA,KAAK,EAAC;AAAkB;;EAEtBA,KAAK,EAAC;AAAe;;EAEjBA,KAAK,EAAC;AAAe;;EAIrBA,KAAK,EAAC;AAAc;;;uBA9EnCC,mBAAA,CAsFM,OAtFNC,UAsFM,GArFJC,mBAAA,CAWM,OAXNC,UAWM,G,0BAVJD,mBAAA,CAGM;IAHDH,KAAK,EAAC;EAAgB,IACzBG,mBAAA,CAAiB,YAAb,UAAQ,GACZA,mBAAA,CA