{"ast":null,"code":"import { ref, computed, onMounted } from 'vue';\nimport { format, startOfMonth, endOfMonth, eachDayOfInterval, isSameMonth, isToday, addMonths, subMonths } from 'date-fns';\nexport default {\n  __name: 'Calendar',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const currentDate = ref(new Date());\n    const daysOfWeek = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];\n    const scheduledDays = ref([]);\n    const workDays = ref([]);\n    const currentMonthYear = computed(() => {\n      return format(currentDate.value, 'MMMM yyyy');\n    });\n    const calendarDays = computed(() => {\n      const start = startOfMonth(currentDate.value);\n      const end = endOfMonth(currentDate.value);\n      const days = eachDayOfInterval({\n        start,\n        end\n      });\n\n      // Add padding days from previous month\n      const startDay = start.getDay();\n      const previousMonthEnd = new Date(start);\n      previousMonthEnd.setDate(0);\n      const previousMonthDays = [];\n      for (let i = startDay - 1; i >= 0; i--) {\n        const date = new Date(previousMonthEnd);\n        date.setDate(previousMonthEnd.getDate() - i);\n        previousMonthDays.push(date);\n      }\n\n      // Add padding days from next month\n      const endDay = end.getDay();\n      const nextMonthDays = [];\n      for (let i = 1; i <= 6 - endDay; i++) {\n        const date = new Date(end);\n        date.setDate(end.getDate() + i);\n        nextMonthDays.push(date);\n      }\n      const allDays = [...previousMonthDays, ...days, ...nextMonthDays];\n      return allDays.map(date => ({\n        date: date.toISOString(),\n        day: date.getDate(),\n        isToday: isToday(date),\n        isCurrentMonth: isSameMonth(date, currentDate.value),\n        hasWork: workDays.value.includes(format(date, 'yyyy-MM-dd')),\n        isScheduled: scheduledDays.value.includes(format(date, 'yyyy-MM-dd'))\n      }));\n    });\n    const previousMonth = () => {\n      currentDate.value = subMonths(currentDate.value, 1);\n    };\n    const nextMonth = () => {\n      currentDate.value = addMonths(currentDate.value, 1);\n    };\n    const goToToday = () => {\n      currentDate.value = new Date();\n    };\n    const selectDay = day => {\n      console.log('Selected day:', day);\n      // TODO: Implement day selection logic\n    };\n    onMounted(() => {\n      // TODO: Fetch scheduled and work days from API\n    });\n    const __returned__ = {\n      currentDate,\n      daysOfWeek,\n      scheduledDays,\n      workDays,\n      currentMonthYear,\n      calendarDays,\n      previousMonth,\n      nextMonth,\n      goToToday,\n      selectDay,\n      ref,\n      computed,\n      onMounted,\n      get format() {\n        return format;\n      },\n      get startOfMonth() {\n        return startOfMonth;\n      },\n      get endOfMonth() {\n        return endOfMonth;\n      },\n      get eachDayOfInterval() {\n        return eachDayOfInterval;\n      },\n      get isSameMonth() {\n        return isSameMonth;\n      },\n      get isToday() {\n        return isToday;\n      },\n      get addMonths() {\n        return addMonths;\n      },\n      get subMonths() {\n        return subMonths;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","format","startOfMonth","endOfMonth","eachDayOfInterval","isSameMonth","isToday","addMonths","subMonths","currentDate","Date","daysOfWeek","scheduledDays","workDays","currentMonthYear","value","calendarDays","start","end","days","startDay","getDay","previousMonthEnd","setDate","previousMonthDays","i","date","getDate","push","endDay","nextMonthDays","allDays","map","toISOString","day","isCurrentMonth","hasWork","includes","isScheduled","previousMonth","nextMonth","goToToday","selectDay","console","log"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Calendar.vue"],"sourcesContent":["<template>\r\n  <div class=\"calendar-page\">\r\n    <div class=\"page-header\">\r\n      <div class=\"header-content\">\r\n        <h1>Calendar</h1>\r\n        <p>View your work schedule and planned days</p>\r\n      </div>\r\n      <div class=\"header-actions\">\r\n        <button class=\"btn btn-secondary\" @click=\"goToToday\">\r\n          <i class=\"bi bi-calendar-today\"></i>\r\n          <span>Today</span>\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"calendar-controls\">\r\n      <button @click=\"previousMonth\" class=\"btn btn-icon\">\r\n        <i class=\"bi bi-chevron-left\"></i>\r\n      </button>\r\n      <h2>{{ currentMonthYear }}</h2>\r\n      <button @click=\"nextMonth\" class=\"btn btn-icon\">\r\n        <i class=\"bi bi-chevron-right\"></i>\r\n      </button>\r\n    </div>\r\n\r\n    <div class=\"calendar-grid\">\r\n      <div class=\"calendar-header\">\r\n        <div class=\"day-label\" v-for=\"day in daysOfWeek\" :key=\"day\">{{ day }}</div>\r\n      </div>\r\n      <div class=\"calendar-body\">\r\n        <div \r\n          v-for=\"day in calendarDays\" \r\n          :key=\"day.date\"\r\n          :class=\"['calendar-day', {\r\n            'today': day.isToday,\r\n            'other-month': !day.isCurrentMonth,\r\n            'has-work': day.hasWork,\r\n            'scheduled': day.isScheduled\r\n          }]\"\r\n          @click=\"selectDay(day)\"\r\n        >\r\n          <div class=\"day-number\">{{ day.day }}</div>\r\n          <div class=\"day-indicator\" v-if=\"day.hasWork || day.isScheduled\"></div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"calendar-legend\">\r\n      <div class=\"legend-item\">\r\n        <span class=\"legend-dot scheduled\"></span>\r\n        <span>Scheduled</span>\r\n      </div>\r\n      <div class=\"legend-item\">\r\n        <span class=\"legend-dot has-work\"></span>\r\n        <span>Worked</span>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\nimport { format, startOfMonth, endOfMonth, eachDayOfInterval, isSameMonth, isToday, addMonths, subMonths } from 'date-fns'\r\n\r\nconst currentDate = ref(new Date())\r\nconst daysOfWeek = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']\r\nconst scheduledDays = ref([])\r\nconst workDays = ref([])\r\n\r\nconst currentMonthYear = computed(() => {\r\n  return format(currentDate.value, 'MMMM yyyy')\r\n})\r\n\r\nconst calendarDays = computed(() => {\r\n  const start = startOfMonth(currentDate.value)\r\n  const end = endOfMonth(currentDate.value)\r\n  const days = eachDayOfInterval({ start, end })\r\n  \r\n  // Add padding days from previous month\r\n  const startDay = start.getDay()\r\n  const previousMonthEnd = new Date(start)\r\n  previousMonthEnd.setDate(0)\r\n  const previousMonthDays = []\r\n  for (let i = startDay - 1; i >= 0; i--) {\r\n    const date = new Date(previousMonthEnd)\r\n    date.setDate(previousMonthEnd.getDate() - i)\r\n    previousMonthDays.push(date)\r\n  }\r\n  \r\n  // Add padding days from next month\r\n  const endDay = end.getDay()\r\n  const nextMonthDays = []\r\n  for (let i = 1; i <= (6 - endDay); i++) {\r\n    const date = new Date(end)\r\n    date.setDate(end.getDate() + i)\r\n    nextMonthDays.push(date)\r\n  }\r\n  \r\n  const allDays = [...previousMonthDays, ...days, ...nextMonthDays]\r\n  \r\n  return allDays.map(date => ({\r\n    date: date.toISOString(),\r\n    day: date.getDate(),\r\n    isToday: isToday(date),\r\n    isCurrentMonth: isSameMonth(date, currentDate.value),\r\n    hasWork: workDays.value.includes(format(date, 'yyyy-MM-dd')),\r\n    isScheduled: scheduledDays.value.includes(format(date, 'yyyy-MM-dd'))\r\n  }))\r\n})\r\n\r\nconst previousMonth = () => {\r\n  currentDate.value = subMonths(currentDate.value, 1)\r\n}\r\n\r\nconst nextMonth = () => {\r\n  currentDate.value = addMonths(currentDate.value, 1)\r\n}\r\n\r\nconst goToToday = () => {\r\n  currentDate.value = new Date()\r\n}\r\n\r\nconst selectDay = (day) => {\r\n  console.log('Selected day:', day)\r\n  // TODO: Implement day selection logic\r\n}\r\n\r\nonMounted(() => {\r\n  // TODO: Fetch scheduled and work days from API\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.calendar-page {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: space-between;\r\n  margin-bottom: var(--spacing-xl);\r\n  flex-wrap: wrap;\r\n  gap: var(--spacing-md);\r\n  \r\n  .header-content {\r\n    h1 {\r\n      font-size: 2rem;\r\n      font-weight: 800;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      color: var(--text-secondary);\r\n    }\r\n  }\r\n}\r\n\r\n.calendar-controls {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: var(--spacing-lg);\r\n  margin-bottom: var(--spacing-xl);\r\n  \r\n  h2 {\r\n    font-size: 1.5rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    min-width: 200px;\r\n    text-align: center;\r\n  }\r\n}\r\n\r\n.calendar-grid {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  box-shadow: var(--shadow-sm);\r\n}\r\n\r\n.calendar-header {\r\n  display: grid;\r\n  grid-template-columns: repeat(7, 1fr);\r\n  gap: var(--spacing-sm);\r\n  margin-bottom: var(--spacing-md);\r\n  \r\n  .day-label {\r\n    text-align: center;\r\n    font-weight: 600;\r\n    color: var(--text-secondary);\r\n    font-size: 0.875rem;\r\n    padding: var(--spacing-sm);\r\n  }\r\n}\r\n\r\n.calendar-body {\r\n  display: grid;\r\n  grid-template-columns: repeat(7, 1fr);\r\n  gap: var(--spacing-sm);\r\n}\r\n\r\n.calendar-day {\r\n  aspect-ratio: 1;\r\n  border-radius: var(--radius-md);\r\n  padding: var(--spacing-sm);\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n  background: var(--bg-secondary);\r\n  position: relative;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  \r\n  &:hover {\r\n    background: var(--primary-light);\r\n    transform: scale(1.05);\r\n  }\r\n  \r\n  &.other-month {\r\n    opacity: 0.3;\r\n  }\r\n  \r\n  &.today {\r\n    background: var(--primary);\r\n    color: white;\r\n    \r\n    .day-number {\r\n      color: white;\r\n    }\r\n  }\r\n  \r\n  &.scheduled {\r\n    border: 2px solid var(--warning);\r\n  }\r\n  \r\n  &.has-work {\r\n    border: 2px solid var(--success);\r\n  }\r\n  \r\n  .day-number {\r\n    font-weight: 600;\r\n    color: var(--text-primary);\r\n    font-size: 0.875rem;\r\n  }\r\n  \r\n  .day-indicator {\r\n    width: 6px;\r\n    height: 6px;\r\n    border-radius: 50%;\r\n    background: var(--primary);\r\n    margin-top: var(--spacing-xs);\r\n  }\r\n}\r\n\r\n.calendar-legend {\r\n  display: flex;\r\n  gap: var(--spacing-lg);\r\n  justify-content: center;\r\n  margin-top: var(--spacing-lg);\r\n  \r\n  .legend-item {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: var(--spacing-sm);\r\n    font-size: 0.875rem;\r\n    color: var(--text-secondary);\r\n    \r\n    .legend-dot {\r\n      width: 16px;\r\n      height: 16px;\r\n      border-radius: var(--radius-sm);\r\n      \r\n      &.scheduled {\r\n        border: 2px solid var(--warning);\r\n      }\r\n      \r\n      &.has-work {\r\n        border: 2px solid var(--success);\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .page-header {\r\n    .header-content h1 {\r\n      font-size: 1.5rem;\r\n    }\r\n  }\r\n  \r\n  .calendar-controls h2 {\r\n    font-size: 1.25rem;\r\n    min-width: 150px;\r\n  }\r\n  \r\n  .calendar-grid {\r\n    padding: var(--spacing-md);\r\n  }\r\n  \r\n  .calendar-day {\r\n    padding: var(--spacing-xs);\r\n    \r\n    .day-number {\r\n      font-size: 0.75rem;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA6DA,SAASA,GAAG,EAAEC,QAAQ,EAAEC,SAAS,QAAQ,KAAK;AAC9C,SAASC,MAAM,EAAEC,YAAY,EAAEC,UAAU,EAAEC,iBAAiB,EAAEC,WAAW,EAAEC,OAAO,EAAEC,SAAS,EAAEC,SAAS,QAAQ,UAAU;;;;;;;IAE1H,MAAMC,WAAW,GAAGX,GAAG,CAAC,IAAIY,IAAI,CAAC,CAAC,CAAC;IACnC,MAAMC,UAAU,GAAG,CAAC,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,EAAE,KAAK,CAAC;IACpE,MAAMC,aAAa,GAAGd,GAAG,CAAC,EAAE,CAAC;IAC7B,MAAMe,QAAQ,GAAGf,GAAG,CAAC,EAAE,CAAC;IAExB,MAAMgB,gBAAgB,GAAGf,QAAQ,CAAC,MAAM;MACtC,OAAOE,MAAM,CAACQ,WAAW,CAACM,KAAK,EAAE,WAAW,CAAC;IAC/C,CAAC,CAAC;IAEF,MAAMC,YAAY,GAAGjB,QAAQ,CAAC,MAAM;MAClC,MAAMkB,KAAK,GAAGf,YAAY,CAACO,WAAW,CAACM,KAAK,CAAC;MAC7C,MAAMG,GAAG,GAAGf,UAAU,CAACM,WAAW,CAACM,KAAK,CAAC;MACzC,MAAMI,IAAI,GAAGf,iBAAiB,CAAC;QAAEa,KAAK;QAAEC;MAAI,CAAC,CAAC;;MAE9C;MACA,MAAME,QAAQ,GAAGH,KAAK,CAACI,MAAM,CAAC,CAAC;MAC/B,MAAMC,gBAAgB,GAAG,IAAIZ,IAAI,CAACO,KAAK,CAAC;MACxCK,gBAAgB,CAACC,OAAO,CAAC,CAAC,CAAC;MAC3B,MAAMC,iBAAiB,GAAG,EAAE;MAC5B,KAAK,IAAIC,CAAC,GAAGL,QAAQ,GAAG,CAAC,EAAEK,CAAC,IAAI,CAAC,EAAEA,CAAC,EAAE,EAAE;QACtC,MAAMC,IAAI,GAAG,IAAIhB,IAAI,CAACY,gBAAgB,CAAC;QACvCI,IAAI,CAACH,OAAO,CAACD,gBAAgB,CAACK,OAAO,CAAC,CAAC,GAAGF,CAAC,CAAC;QAC5CD,iBAAiB,CAACI,IAAI,CAACF,IAAI,CAAC;MAC9B;;MAEA;MACA,MAAMG,MAAM,GAAGX,GAAG,CAACG,MAAM,CAAC,CAAC;MAC3B,MAAMS,aAAa,GAAG,EAAE;MACxB,KAAK,IAAIL,CAAC,GAAG,CAAC,EAAEA,CAAC,IAAK,CAAC,GAAGI,MAAO,EAAEJ,CAAC,EAAE,EAAE;QACtC,MAAMC,IAAI,GAAG,IAAIhB,IAAI,CAACQ,GAAG,CAAC;QAC1BQ,IAAI,CAACH,OAAO,CAACL,GAAG,CAACS,OAAO,CAAC,CAAC,GAAGF,CAAC,CAAC;QAC/BK,aAAa,CAACF,IAAI,CAACF,IAAI,CAAC;MAC1B;MAEA,MAAMK,OAAO,GAAG,CAAC,GAAGP,iBAAiB,EAAE,GAAGL,IAAI,EAAE,GAAGW,aAAa,CAAC;MAEjE,OAAOC,OAAO,CAACC,GAAG,CAACN,IAAI,KAAK;QAC1BA,IAAI,EAAEA,IAAI,CAACO,WAAW,CAAC,CAAC;QACxBC,GAAG,EAAER,IAAI,CAACC,OAAO,CAAC,CAAC;QACnBrB,OAAO,EAAEA,OAAO,CAACoB,IAAI,CAAC;QACtBS,cAAc,EAAE9B,WAAW,CAACqB,IAAI,EAAEjB,WAAW,CAACM,KAAK,CAAC;QACpDqB,OAAO,EAAEvB,QAAQ,CAACE,KAAK,CAACsB,QAAQ,CAACpC,MAAM,CAACyB,IAAI,EAAE,YAAY,CAAC,CAAC;QAC5DY,WAAW,EAAE1B,aAAa,CAACG,KAAK,CAACsB,QAAQ,CAACpC,MAAM,CAACyB,IAAI,EA