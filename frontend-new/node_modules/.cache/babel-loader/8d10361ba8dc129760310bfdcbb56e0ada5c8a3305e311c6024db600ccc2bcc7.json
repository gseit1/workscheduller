{"ast":null,"code":"import { ref, computed, onMounted } from 'vue';\nimport { format } from 'date-fns';\nimport { useToast } from 'vue-toastification';\nimport { useAuthStore } from '../stores/auth';\nimport api from '../services/api';\nexport default {\n  __name: 'Dashboard',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const toast = useToast();\n    const authStore = useAuthStore();\n    const user = computed(() => authStore.user);\n    const loading = ref(true);\n    const stats = ref({\n      totalEarnings: 0,\n      totalHours: 0,\n      daysWorked: 0,\n      completionRate: 0\n    });\n    const recentActivity = ref([]);\n    const showRateModal = ref(false);\n    const newRate = ref(user.value?.hourlyRate || 15);\n    const effectiveDate = ref(format(new Date(), 'yyyy-MM-dd'));\n    const updating = ref(false);\n    const formatAmount = amount => {\n      return new Intl.NumberFormat('en-IE', {\n        minimumFractionDigits: 2,\n        maximumFractionDigits: 2\n      }).format(amount || 0);\n    };\n    const formatRelativeDate = dateString => {\n      const date = new Date(dateString);\n      const now = new Date();\n      const diffTime = Math.abs(now - date);\n      const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));\n      if (diffDays === 0) return 'Today';\n      if (diffDays === 1) return 'Yesterday';\n      if (diffDays < 7) return `${diffDays} days ago`;\n      return format(date, 'MMM d, yyyy');\n    };\n    const fetchDashboard = async () => {\n      try {\n        loading.value = true;\n        const response = await api.get('/dashboard/overview');\n        const data = response.data;\n\n        // Update stats from API\n        stats.value = {\n          totalEarnings: data.currentMonth.work.total_earnings || 0,\n          totalHours: data.currentMonth.work.total_hours || 0,\n          daysWorked: data.currentMonth.work.days_worked || 0,\n          completionRate: calculateCompletionRate(data.currentMonth.work)\n        };\n\n        // Build activity list\n        const activities = [];\n        if (data.recentActivity.workDays) {\n          data.recentActivity.workDays.forEach(day => {\n            activities.push({\n              id: `work-${day.id}`,\n              type: 'work',\n              description: `Worked ${day.hours_worked} hours`,\n              amount: day.calculated_payment,\n              date: formatRelativeDate(day.work_date)\n            });\n          });\n        }\n        if (data.recentActivity.transactions) {\n          data.recentActivity.transactions.forEach(expense => {\n            activities.push({\n              id: `expense-${expense.id}`,\n              type: expense.type === 'income' ? 'work' : 'expense',\n              description: expense.description || expense.category,\n              amount: expense.type === 'expense' ? -expense.amount : expense.amount,\n              date: formatRelativeDate(expense.expense_date)\n            });\n          });\n        }\n        recentActivity.value = activities.slice(0, 5);\n      } catch (error) {\n        console.error('Failed to fetch dashboard', error);\n        toast.error('Failed to load dashboard data');\n      } finally {\n        loading.value = false;\n      }\n    };\n    const calculateCompletionRate = workData => {\n      const daysWorked = workData.days_worked || 0;\n      const currentDate = new Date();\n      const daysPassed = currentDate.getDate();\n      const expectedDays = Math.floor(daysPassed / 7 * 5); // Assuming 5 work days per week\n      return expectedDays > 0 ? Math.round(daysWorked / expectedDays * 100) : 0;\n    };\n    const updateRate = async () => {\n      try {\n        updating.value = true;\n        const result = await authStore.updateHourlyRate(newRate.value, effectiveDate.value);\n        if (result.success) {\n          toast.success('Hourly rate updated successfully');\n          showRateModal.value = false;\n          await fetchDashboard();\n        } else {\n          toast.error(result.message);\n        }\n      } catch (error) {\n        toast.error('Failed to update rate');\n      } finally {\n        updating.value = false;\n      }\n    };\n    onMounted(() => {\n      fetchDashboard();\n    });\n    const __returned__ = {\n      toast,\n      authStore,\n      user,\n      loading,\n      stats,\n      recentActivity,\n      showRateModal,\n      newRate,\n      effectiveDate,\n      updating,\n      formatAmount,\n      formatRelativeDate,\n      fetchDashboard,\n      calculateCompletionRate,\n      updateRate,\n      ref,\n      computed,\n      onMounted,\n      get format() {\n        return format;\n      },\n      get useToast() {\n        return useToast;\n      },\n      get useAuthStore() {\n        return useAuthStore;\n      },\n      get api() {\n        return api;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","computed","onMounted","format","useToast","useAuthStore","api","toast","authStore","user","loading","stats","totalEarnings","totalHours","daysWorked","completionRate","recentActivity","showRateModal","newRate","value","hourlyRate","effectiveDate","Date","updating","formatAmount","amount","Intl","NumberFormat","minimumFractionDigits","maximumFractionDigits","formatRelativeDate","dateString","date","now","diffTime","Math","abs","diffDays","floor","fetchDashboard","response","get","data","currentMonth","work","total_earnings","total_hours","days_worked","calculateCompletionRate","activities","workDays","forEach","day","push","id","type","description","hours_worked","calculated_payment","work_date","transactions","expense","category","expense_date","slice","error","console","workData","currentDate","daysPassed","getDate","expectedDays","round","updateRate","result","updateHourlyRate","success","message"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Dashboard.vue"],"sourcesContent":["<template>\r\n  <div class=\"dashboard-page\">\r\n    <div class=\"container\">\r\n      <!-- Header -->\r\n      <header class=\"page-header\">\r\n        <div class=\"header-content\">\r\n          <div>\r\n            <h1 class=\"page-title\">Dashboard</h1>\r\n            <p class=\"page-subtitle\">Welcome back, {{ user?.name || 'User' }}!</p>\r\n          </div>\r\n          <div class=\"header-actions\">\r\n            <button class=\"btn btn-secondary\">\r\n              <i class=\"bi bi-download\"></i>\r\n              Export\r\n            </button>\r\n            <button class=\"btn btn-primary\">\r\n              <i class=\"bi bi-plus-lg\"></i>\r\n              Add Work\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </header>\r\n\r\n      <!-- Loading State -->\r\n      <div v-if=\"loading\" class=\"loading-state\">\r\n        <div class=\"spinner\"></div>\r\n        <p>Loading your dashboard...</p>\r\n      </div>\r\n\r\n      <!-- Dashboard Content -->\r\n      <div v-else class=\"dashboard-content\">\r\n        <!-- Stats Grid -->\r\n        <div class=\"stats-grid\">\r\n          <div class=\"stat-card\">\r\n            <div class=\"stat-header\">\r\n              <div class=\"stat-icon earnings\">\r\n                <i class=\"bi bi-cash-stack\"></i>\r\n              </div>\r\n              <span class=\"stat-trend positive\">\r\n                <i class=\"bi bi-arrow-up\"></i> 12.5%\r\n              </span>\r\n            </div>\r\n            <div class=\"stat-value\">€{{ formatAmount(stats.totalEarnings) }}</div>\r\n            <div class=\"stat-label\">Total Earnings</div>\r\n            <div class=\"stat-footer\">\r\n              <span class=\"stat-detail\">This month</span>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"stat-card\">\r\n            <div class=\"stat-header\">\r\n              <div class=\"stat-icon hours\">\r\n                <i class=\"bi bi-clock\"></i>\r\n              </div>\r\n              <span class=\"stat-trend positive\">\r\n                <i class=\"bi bi-arrow-up\"></i> 8.3%\r\n              </span>\r\n            </div>\r\n            <div class=\"stat-value\">{{ stats.totalHours }}h</div>\r\n            <div class=\"stat-label\">Hours Worked</div>\r\n            <div class=\"stat-footer\">\r\n              <span class=\"stat-detail\">{{ stats.daysWorked }} days this month</span>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"stat-card\">\r\n            <div class=\"stat-header\">\r\n              <div class=\"stat-icon rate\">\r\n                <i class=\"bi bi-graph-up\"></i>\r\n              </div>\r\n              <span class=\"stat-trend neutral\">\r\n                <i class=\"bi bi-dash\"></i> 0%\r\n              </span>\r\n            </div>\r\n            <div class=\"stat-value\">€{{ user?.hourlyRate || 0 }}</div>\r\n            <div class=\"stat-label\">Hourly Rate</div>\r\n            <div class=\"stat-footer\">\r\n              <button class=\"stat-action\" @click=\"showRateModal = true\">\r\n                Update rate\r\n              </button>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"stat-card\">\r\n            <div class=\"stat-header\">\r\n              <div class=\"stat-icon goals\">\r\n                <i class=\"bi bi-bullseye\"></i>\r\n              </div>\r\n              <span class=\"stat-trend positive\">\r\n                <i class=\"bi bi-arrow-up\"></i> 15%\r\n              </span>\r\n            </div>\r\n            <div class=\"stat-value\">{{ stats.completionRate }}%</div>\r\n            <div class=\"stat-label\">Completion Rate</div>\r\n            <div class=\"stat-footer\">\r\n              <span class=\"stat-detail\">Monthly target</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Charts Row -->\r\n        <div class=\"charts-row\">\r\n          <div class=\"chart-card\">\r\n            <div class=\"chart-header\">\r\n              <h3>Earnings Overview</h3>\r\n              <select class=\"chart-period\">\r\n                <option>This Month</option>\r\n                <option>Last Month</option>\r\n                <option>This Year</option>\r\n              </select>\r\n            </div>\r\n            <div class=\"chart-container\">\r\n              <div class=\"chart-placeholder\">\r\n                <i class=\"bi bi-bar-chart-line\"></i>\r\n                <p>Earnings chart will be displayed here</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"chart-card\">\r\n            <div class=\"chart-header\">\r\n              <h3>Hours Distribution</h3>\r\n              <select class=\"chart-period\">\r\n                <option>This Week</option>\r\n                <option>This Month</option>\r\n              </select>\r\n            </div>\r\n            <div class=\"chart-container\">\r\n              <div class=\"chart-placeholder\">\r\n                <i class=\"bi bi-pie-chart\"></i>\r\n                <p>Hours distribution will be displayed here</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Recent Activity -->\r\n        <div class=\"activity-section\">\r\n          <div class=\"section-header\">\r\n            <h3>Recent Activity</h3>\r\n            <a href=\"/work\" class=\"view-all\">View all →</a>\r\n          </div>\r\n          <div class=\"activity-list\">\r\n            <div v-for=\"i in 5\" :key=\"i\" class=\"activity-item\">\r\n              <div class=\"activity-icon\">\r\n                <i class=\"bi bi-briefcase\"></i>\r\n              </div>\r\n              <div class=\"activity-content\">\r\n                <div class=\"activity-title\">Work day completed</div>\r\n                <div class=\"activity-meta\">\r\n                  <span>8.5 hours</span>\r\n                  <span class=\"separator\">•</span>\r\n                  <span>€127.50</span>\r\n                </div>\r\n              </div>\r\n              <div class=\"activity-time\">2 hours ago</div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Rate Modal -->\r\n    <div v-if=\"showRateModal\" class=\"modal-overlay\" @click.self=\"showRateModal = false\">\r\n      <div class=\"modal\">\r\n        <div class=\"modal-header\">\r\n          <h3>Update Hourly Rate</h3>\r\n          <button class=\"modal-close\" @click=\"showRateModal = false\">\r\n            <i class=\"bi bi-x\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>New Hourly Rate (€)</label>\r\n            <input\r\n              type=\"number\"\r\n              step=\"0.01\"\r\n              v-model=\"newRate\"\r\n              class=\"form-input\"\r\n              placeholder=\"15.00\"\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Effective From</label>\r\n            <input\r\n              type=\"date\"\r\n              v-model=\"effectiveDate\"\r\n              class=\"form-input\"\r\n            />\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button class=\"btn btn-secondary\" @click=\"showRateModal = false\">Cancel</button>\r\n          <button class=\"btn btn-primary\" @click=\"updateRate\" :disabled=\"updating\">\r\n            <span v-if=\"updating\" class=\"spinner\" style=\"width: 16px; height: 16px;\"></span>\r\n            {{ updating ? 'Updating...' : 'Update Rate' }}\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, computed, onMounted } from 'vue'\r\nimport { format } from 'date-fns'\r\nimport { useToast } from 'vue-toastification'\r\nimport { useAuthStore } from '../stores/auth'\r\nimport api from '../services/api'\r\n\r\nconst toast = useToast()\r\nconst authStore = useAuthStore()\r\nconst user = computed(() => authStore.user)\r\n\r\nconst loading = ref(true)\r\nconst stats = ref({\r\n  totalEarnings: 0,\r\n  totalHours: 0,\r\n  daysWorked: 0,\r\n  completionRate: 0\r\n})\r\n\r\nconst recentActivity = ref([])\r\n\r\nconst showRateModal = ref(false)\r\nconst newRate = ref(user.value?.hourlyRate || 15)\r\nconst effectiveDate = ref(format(new Date(), 'yyyy-MM-dd'))\r\nconst updating = ref(false)\r\n\r\nconst formatAmount = (amount) => {\r\n  return new Intl.NumberFormat('en-IE', {\r\n    minimumFractionDigits: 2,\r\n    maximumFractionDigits: 2\r\n  }).format(amount || 0)\r\n}\r\n\r\nconst formatRelativeDate = (dateString) => {\r\n  const date = new Date(dateString)\r\n  const now = new Date()\r\n  const diffTime = Math.abs(now - date)\r\n  const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24))\r\n  \r\n  if (diffDays === 0) return 'Today'\r\n  if (diffDays === 1) return 'Yesterday'\r\n  if (diffDays < 7) return `${diffDays} days ago`\r\n  return format(date, 'MMM d, yyyy')\r\n}\r\n\r\nconst fetchDashboard = async () => {\r\n  try {\r\n    loading.value = true\r\n    const response = await api.get('/dashboard/overview')\r\n    const data = response.data\r\n    \r\n    // Update stats from API\r\n    stats.value = {\r\n      totalEarnings: data.currentMonth.work.total_earnings || 0,\r\n      totalHours: data.currentMonth.work.total_hours || 0,\r\n      daysWorked: data.currentMonth.work.days_worked || 0,\r\n      completionRate: calculateCompletionRate(data.currentMonth.work)\r\n    }\r\n    \r\n    // Build activity list\r\n    const activities = []\r\n    \r\n    if (data.recentActivity.workDays) {\r\n      data.recentActivity.workDays.forEach(day => {\r\n        activities.push({\r\n          id: `work-${day.id}`,\r\n          type: 'work',\r\n          description: `Worked ${day.hours_worked} hours`,\r\n          amount: day.calculated_payment,\r\n          date: formatRelativeDate(day.work_date)\r\n        })\r\n      })\r\n    }\r\n    \r\n    if (data.recentActivity.transactions) {\r\n      data.recentActivity.transactions.forEach(expense => {\r\n        activities.push({\r\n          id: `expense-${expense.id}`,\r\n          type: expense.type === 'income' ? 'work' : 'expense',\r\n          description: expense.description || expense.category,\r\n          amount: expense.type === 'expense' ? -expense.amount : expense.amount,\r\n          date: formatRelativeDate(expense.expense_date)\r\n        })\r\n      })\r\n    }\r\n    \r\n    recentActivity.value = activities.slice(0, 5)\r\n    \r\n  } catch (error) {\r\n    console.error('Failed to fetch dashboard', error)\r\n    toast.error('Failed to load dashboard data')\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\nconst calculateCompletionRate = (workData) => {\r\n  const daysWorked = workData.days_worked || 0\r\n  const currentDate = new Date()\r\n  const daysPassed = currentDate.getDate()\r\n  const expectedDays = Math.floor(daysPassed / 7 * 5) // Assuming 5 work days per week\r\n  return expectedDays > 0 ? Math.round((daysWorked / expectedDays) * 100) : 0\r\n}\r\n\r\nconst updateRate = async () => {\r\n  try {\r\n    updating.value = true\r\n    const result = await authStore.updateHourlyRate(newRate.value, effectiveDate.value)\r\n    if (result.success) {\r\n      toast.success('Hourly rate updated successfully')\r\n      showRateModal.value = false\r\n      await fetchDashboard()\r\n    } else {\r\n      toast.error(result.message)\r\n    }\r\n  } catch (error) {\r\n    toast.error('Failed to update rate')\r\n  } finally {\r\n    updating.value = false\r\n  }\r\n}\r\n\r\nonMounted(() => {\r\n  fetchDashboard()\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.dashboard-page {\r\n  min-height: 100vh;\r\n  padding: var(--spacing-xl) 0;\r\n  background: var(--bg-secondary);\r\n}\r\n\r\n.page-header {\r\n  margin-bottom: var(--spacing-2xl);\r\n  \r\n  .header-content {\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: space-between;\r\n    flex-wrap: wrap;\r\n    gap: var(--spacing-lg);\r\n  }\r\n  \r\n  .page-title {\r\n    font-size: 2rem;\r\n    font-weight: 800;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-xs);\r\n  }\r\n  \r\n  .page-subtitle {\r\n    font-size: 1rem;\r\n    color: var(--text-secondary);\r\n  }\r\n  \r\n  .header-actions {\r\n    display: flex;\r\n    gap: var(--spacing-md);\r\n  }\r\n  \r\n  @media (max-width: 767px) {\r\n    .page-title {\r\n      font-size: 1.5rem;\r\n    }\r\n    \r\n    .header-actions {\r\n      width: 100%;\r\n      \r\n      .btn {\r\n        flex: 1;\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n.loading-state {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  padding: var(--spacing-2xl);\r\n  gap: var(--spacing-md);\r\n  \r\n  p {\r\n    color: var(--text-secondary);\r\n  }\r\n}\r\n\r\n.stats-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\r\n  gap: var(--spacing-lg);\r\n  margin-bottom: var(--spacing-2xl);\r\n}\r\n\r\n.stat-card {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-lg);\r\n  border: 1px solid var(--border-light);\r\n  transition: all var(--transition-fast);\r\n  \r\n  &:hover {\r\n    box-shadow: var(--shadow-md);\r\n    transform: translateY(-2px);\r\n  }\r\n  \r\n  .stat-header {\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: space-between;\r\n    margin-bottom: var(--spacing-md);\r\n  }\r\n  \r\n  .stat-icon {\r\n    width: 48px;\r\n    height: 48px;\r\n    border-radius: var(--radius-md);\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    font-size: 1.5rem;\r\n    \r\n    &.earnings {\r\n      background: linear-gradient(135deg, #10b981 0%, #059669 100%);\r\n      color: white;\r\n    }\r\n    \r\n    &.hours {\r\n      background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);\r\n      color: white;\r\n    }\r\n    \r\n    &.rate {\r\n      background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);\r\n      color: white;\r\n    }\r\n    \r\n    &.goals {\r\n      background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);\r\n      color: white;\r\n    }\r\n  }\r\n  \r\n  .stat-trend {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 0.25rem;\r\n    font-size: 0.875rem;\r\n    font-weight: 600;\r\n    padding: 0.25rem 0.5rem;\r\n    border-radius: var(--radius-full);\r\n    \r\n    &.positive {\r\n      background: rgba(16, 185, 129, 0.1);\r\n      color: var(--success);\r\n    }\r\n    \r\n    &.negative {\r\n      background: rgba(239, 68, 68, 0.1);\r\n      color: var(--danger);\r\n    }\r\n    \r\n    &.neutral {\r\n      background: var(--bg-tertiary);\r\n      color: var(--text-tertiary);\r\n    }\r\n  }\r\n  \r\n  .stat-value {\r\n    font-size: 2rem;\r\n    font-weight: 800;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-xs);\r\n  }\r\n  \r\n  .stat-label {\r\n    font-size: 0.875rem;\r\n    color: var(--text-secondary);\r\n    margin-bottom: var(--spacing-md);\r\n  }\r\n  \r\n  .stat-footer {\r\n    padding-top: var(--spacing-md);\r\n    border-top: 1px solid var(--border-light);\r\n    \r\n    .stat-detail {\r\n      font-size: 0.8125rem;\r\n      color: var(--text-tertiary);\r\n    }\r\n    \r\n    .stat-action {\r\n      background: none;\r\n      border: none;\r\n      color: var(--primary);\r\n      font-weight: 600;\r\n      font-size: 0.8125rem;\r\n      cursor: pointer;\r\n      \r\n      &:hover {\r\n        text-decoration: underline;\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n.charts-row {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));\r\n  gap: var(--spacing-lg);\r\