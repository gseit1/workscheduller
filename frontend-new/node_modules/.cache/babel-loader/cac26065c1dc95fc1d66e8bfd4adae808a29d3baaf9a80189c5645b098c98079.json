{"ast":null,"code":"import { ref } from 'vue';\nimport { useToast } from 'vue-toastification';\nexport default {\n  __name: 'Settings',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const toast = useToast();\n    const settings = ref({\n      theme: 'light',\n      compactMode: false,\n      goalReminders: true,\n      scheduleAlerts: true,\n      weeklyReports: false\n    });\n    const saveSettings = () => {\n      toast.success('Settings saved successfully!');\n      // TODO: Save settings to API\n    };\n    const exportData = () => {\n      toast.info('Preparing your data export...');\n      // TODO: Implement data export\n    };\n    const clearCache = () => {\n      toast.success('Cache cleared successfully!');\n      // TODO: Implement cache clearing\n    };\n    const deleteAccount = () => {\n      if (confirm('Are you sure you want to delete your account? This action cannot be undone.')) {\n        toast.error('Account deletion feature not implemented yet');\n        // TODO: Implement account deletion\n      }\n    };\n    const __returned__ = {\n      toast,\n      settings,\n      saveSettings,\n      exportData,\n      clearCache,\n      deleteAccount,\n      ref,\n      get useToast() {\n        return useToast;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","useToast","toast","settings","theme","compactMode","goalReminders","scheduleAlerts","weeklyReports","saveSettings","success","exportData","info","clearCache","deleteAccount","confirm","error"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Settings.vue"],"sourcesContent":["<template>\r\n  <div class=\"settings-page\">\r\n    <div class=\"page-header\">\r\n      <h1>Settings</h1>\r\n      <p>Customize your application preferences</p>\r\n    </div>\r\n\r\n    <div class=\"settings-content\">\r\n      <div class=\"settings-card\">\r\n        <h3>Appearance</h3>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Theme</h4>\r\n            <p>Choose your preferred color scheme</p>\r\n          </div>\r\n          <select v-model=\"settings.theme\" class=\"form-select\">\r\n            <option value=\"light\">Light</option>\r\n            <option value=\"dark\">Dark</option>\r\n            <option value=\"auto\">Auto</option>\r\n          </select>\r\n        </div>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Compact Mode</h4>\r\n            <p>Reduce spacing for a denser layout</p>\r\n          </div>\r\n          <label class=\"toggle\">\r\n            <input v-model=\"settings.compactMode\" type=\"checkbox\" />\r\n            <span class=\"toggle-slider\"></span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"settings-card\">\r\n        <h3>Notifications</h3>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Goal Reminders</h4>\r\n            <p>Get notified about upcoming goal deadlines</p>\r\n          </div>\r\n          <label class=\"toggle\">\r\n            <input v-model=\"settings.goalReminders\" type=\"checkbox\" />\r\n            <span class=\"toggle-slider\"></span>\r\n          </label>\r\n        </div>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Work Schedule Alerts</h4>\r\n            <p>Receive alerts for scheduled work days</p>\r\n          </div>\r\n          <label class=\"toggle\">\r\n            <input v-model=\"settings.scheduleAlerts\" type=\"checkbox\" />\r\n            <span class=\"toggle-slider\"></span>\r\n          </label>\r\n        </div>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Weekly Reports</h4>\r\n            <p>Get weekly summary of your work and earnings</p>\r\n          </div>\r\n          <label class=\"toggle\">\r\n            <input v-model=\"settings.weeklyReports\" type=\"checkbox\" />\r\n            <span class=\"toggle-slider\"></span>\r\n          </label>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"settings-card\">\r\n        <h3>Data & Privacy</h3>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Export Data</h4>\r\n            <p>Download all your data in JSON format</p>\r\n          </div>\r\n          <button @click=\"exportData\" class=\"btn btn-secondary\">\r\n            <i class=\"bi bi-download\"></i>\r\n            Export\r\n          </button>\r\n        </div>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Clear Cache</h4>\r\n            <p>Clear application cache and temporary data</p>\r\n          </div>\r\n          <button @click=\"clearCache\" class=\"btn btn-outline-secondary\">\r\n            <i class=\"bi bi-trash\"></i>\r\n            Clear\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"settings-card danger-zone\">\r\n        <h3>Danger Zone</h3>\r\n        \r\n        <div class=\"setting-item\">\r\n          <div class=\"setting-info\">\r\n            <h4>Delete Account</h4>\r\n            <p>Permanently delete your account and all data</p>\r\n          </div>\r\n          <button @click=\"deleteAccount\" class=\"btn btn-danger\">\r\n            <i class=\"bi bi-exclamation-triangle\"></i>\r\n            Delete Account\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"settings-actions\">\r\n        <button @click=\"saveSettings\" class=\"btn btn-primary btn-lg\">\r\n          <i class=\"bi bi-check-circle\"></i>\r\n          Save Settings\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref } from 'vue'\r\nimport { useToast } from 'vue-toastification'\r\n\r\nconst toast = useToast()\r\n\r\nconst settings = ref({\r\n  theme: 'light',\r\n  compactMode: false,\r\n  goalReminders: true,\r\n  scheduleAlerts: true,\r\n  weeklyReports: false\r\n})\r\n\r\nconst saveSettings = () => {\r\n  toast.success('Settings saved successfully!')\r\n  // TODO: Save settings to API\r\n}\r\n\r\nconst exportData = () => {\r\n  toast.info('Preparing your data export...')\r\n  // TODO: Implement data export\r\n}\r\n\r\nconst clearCache = () => {\r\n  toast.success('Cache cleared successfully!')\r\n  // TODO: Implement cache clearing\r\n}\r\n\r\nconst deleteAccount = () => {\r\n  if (confirm('Are you sure you want to delete your account? This action cannot be undone.')) {\r\n    toast.error('Account deletion feature not implemented yet')\r\n    // TODO: Implement account deletion\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.settings-page {\r\n  max-width: 900px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  margin-bottom: var(--spacing-xl);\r\n  \r\n  h1 {\r\n    font-size: 2rem;\r\n    font-weight: 800;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-xs);\r\n  }\r\n  \r\n  p {\r\n    color: var(--text-secondary);\r\n  }\r\n}\r\n\r\n.settings-content {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--spacing-lg);\r\n}\r\n\r\n.settings-card {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-xl);\r\n  box-shadow: var(--shadow-sm);\r\n  \r\n  h3 {\r\n    font-size: 1.25rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-lg);\r\n    padding-bottom: var(--spacing-sm);\r\n    border-bottom: 2px solid var(--border-color);\r\n  }\r\n  \r\n  &.danger-zone {\r\n    border: 2px solid var(--danger);\r\n    \r\n    h3 {\r\n      color: var(--danger);\r\n      border-color: var(--danger);\r\n    }\r\n  }\r\n}\r\n\r\n.setting-item {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: var(--spacing-lg);\r\n  background: var(--bg-secondary);\r\n  border-radius: var(--radius-md);\r\n  margin-bottom: var(--spacing-md);\r\n  \r\n  &:last-child {\r\n    margin-bottom: 0;\r\n  }\r\n  \r\n  .setting-info {\r\n    flex: 1;\r\n    \r\n    h4 {\r\n      font-size: 1rem;\r\n      font-weight: 600;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-xs);\r\n    }\r\n    \r\n    p {\r\n      font-size: 0.875rem;\r\n      color: var(--text-secondary);\r\n      margin: 0;\r\n    }\r\n  }\r\n  \r\n  .form-select {\r\n    width: 150px;\r\n  }\r\n}\r\n\r\n.toggle {\r\n  position: relative;\r\n  display: inline-block;\r\n  width: 60px;\r\n  height: 34px;\r\n  \r\n  input {\r\n    opacity: 0;\r\n    width: 0;\r\n    height: 0;\r\n    \r\n    &:checked + .toggle-slider {\r\n      background: var(--primary);\r\n      \r\n      &:before {\r\n        transform: translateX(26px);\r\n      }\r\n    }\r\n  }\r\n  \r\n  .toggle-slider {\r\n    position: absolute;\r\n    cursor: pointer;\r\n    top: 0;\r\n    left: 0;\r\n    right: 0;\r\n    bottom: 0;\r\n    background: var(--bg-secondary);\r\n    border: 2px solid var(--border-color);\r\n    border-radius: 34px;\r\n    transition: 0.3s;\r\n    \r\n    &:before {\r\n      content: '';\r\n      position: absolute;\r\n      height: 24px;\r\n      width: 24px;\r\n      left: 3px;\r\n      bottom: 3px;\r\n      background: white;\r\n      border-radius: 50%;\r\n      transition: 0.3s;\r\n      box-shadow: var(--shadow-sm);\r\n    }\r\n  }\r\n}\r\n\r\n.settings-actions {\r\n  padding-top: var(--spacing-lg);\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .page-header h1 {\r\n    font-size: 1.5rem;\r\n  }\r\n  \r\n  .settings-card {\r\n    padding: var(--spacing-lg);\r\n  }\r\n  \r\n  .setting-item {\r\n    flex-direction: column;\r\n    align-items: flex-start;\r\n    gap: var(--spacing-md);\r\n    \r\n    .form-select {\r\n      width: 100%;\r\n    }\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AA4HA,SAASA,GAAG,QAAQ,KAAK;AACzB,SAASC,QAAQ,QAAQ,oBAAoB;;;;;;;IAE7C,MAAMC,KAAK,GAAGD,QAAQ,CAAC,CAAC;IAExB,MAAME,QAAQ,GAAGH,GAAG,CAAC;MACnBI,KAAK,EAAE,OAAO;MACdC,WAAW,EAAE,KAAK;MAClBC,aAAa,EAAE,IAAI;MACnBC,cAAc,EAAE,IAAI;MACpBC,aAAa,EAAE;IACjB,CAAC,CAAC;IAEF,MAAMC,YAAY,GAAGA,CAAA,KAAM;MACzBP,KAAK,CAACQ,OAAO,CAAC,8BAA8B,CAAC;MAC7C;IACF,CAAC;IAED,MAAMC,UAAU,GAAGA,CAAA,KAAM;MACvBT,KAAK,CAACU,IAAI,CAAC,+BAA+B,CAAC;MAC3C;IACF,CAAC;IAED,MAAMC,UAAU,GAAGA,CAAA,KAAM;MACvBX,KAAK,CAACQ,OAAO,CAAC,6BAA6B,CAAC;MAC5C;IACF,CAAC;IAED,MAAMI,aAAa,GAAGA,CAAA,KAAM;MAC1B,IAAIC,OAAO,CAAC,6EAA6E,CAAC,EAAE;QAC1Fb,KAAK,CAACc,KAAK,CAAC,8CAA8C,CAAC;QAC3D;MACF;IACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}