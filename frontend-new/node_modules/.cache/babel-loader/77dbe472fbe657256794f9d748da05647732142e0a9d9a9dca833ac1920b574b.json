{"ast":null,"code":"import { ref, onMounted } from 'vue';\nimport { useAuthStore } from '../stores/auth';\nimport { useToast } from 'vue-toastification';\nexport default {\n  __name: 'Profile',\n  setup(__props, {\n    expose: __expose\n  }) {\n    __expose();\n    const authStore = useAuthStore();\n    const toast = useToast();\n    const profile = ref({\n      name: '',\n      email: '',\n      hourlyRate: 30,\n      currency: 'USD',\n      timezone: 'America/New_York',\n      emailNotifications: true\n    });\n    const passwordForm = ref({\n      current: '',\n      new: '',\n      confirm: ''\n    });\n    const updateProfile = () => {\n      toast.success('Profile updated successfully!');\n      // TODO: Call API to update profile\n    };\n    const updatePassword = () => {\n      if (passwordForm.value.new !== passwordForm.value.confirm) {\n        toast.error('Passwords do not match!');\n        return;\n      }\n      toast.success('Password updated successfully!');\n      passwordForm.value = {\n        current: '',\n        new: '',\n        confirm: ''\n      };\n      // TODO: Call API to update password\n    };\n    onMounted(() => {\n      if (authStore.user) {\n        profile.value.name = authStore.user.name;\n        profile.value.email = authStore.user.email;\n        profile.value.hourlyRate = authStore.user.hourlyRate || 30;\n      }\n    });\n    const __returned__ = {\n      authStore,\n      toast,\n      profile,\n      passwordForm,\n      updateProfile,\n      updatePassword,\n      ref,\n      onMounted,\n      get useAuthStore() {\n        return useAuthStore;\n      },\n      get useToast() {\n        return useToast;\n      }\n    };\n    Object.defineProperty(__returned__, '__isScriptSetup', {\n      enumerable: false,\n      value: true\n    });\n    return __returned__;\n  }\n};","map":{"version":3,"names":["ref","onMounted","useAuthStore","useToast","authStore","toast","profile","name","email","hourlyRate","currency","timezone","emailNotifications","passwordForm","current","new","confirm","updateProfile","success","updatePassword","value","error","user"],"sources":["C:/xampp/htdocs/jobAnalytics/frontend-new/src/views/Profile.vue"],"sourcesContent":["<template>\r\n  <div class=\"profile-page\">\r\n    <div class=\"page-header\">\r\n      <h1>Profile Settings</h1>\r\n      <p>Manage your account information and preferences</p>\r\n    </div>\r\n\r\n    <div class=\"profile-content\">\r\n      <div class=\"profile-card\">\r\n        <div class=\"avatar-section\">\r\n          <div class=\"avatar-wrapper\">\r\n            <div class=\"avatar\" :class=\"{ 'has-image': profile.avatar }\">\r\n              <img v-if=\"profile.avatar\" :src=\"profile.avatar\" alt=\"Profile\" />\r\n              <i v-else class=\"bi bi-person-circle\"></i>\r\n            </div>\r\n            <input \r\n              ref=\"fileInput\" \r\n              type=\"file\" \r\n              accept=\"image/*\" \r\n              @change=\"handleImageUpload\" \r\n              style=\"display: none\"\r\n            />\r\n            <button \r\n              type=\"button\" \r\n              class=\"btn btn-sm btn-primary avatar-btn\"\r\n              @click=\"$refs.fileInput.click()\"\r\n            >\r\n              <i class=\"bi bi-camera\"></i>\r\n            </button>\r\n          </div>\r\n          <button \r\n            v-if=\"profile.avatar\" \r\n            type=\"button\"\r\n            class=\"btn btn-sm btn-outline-danger remove-avatar-btn\"\r\n            @click=\"removeAvatar\"\r\n          >\r\n            <i class=\"bi bi-trash\"></i>\r\n            Remove Photo\r\n          </button>\r\n        </div>\r\n\r\n        <form @submit.prevent=\"updateProfile\" class=\"profile-form\">\r\n          <div class=\"form-section\">\r\n            <h3>Personal Information</h3>\r\n            \r\n            <div class=\"form-group\">\r\n              <label>Full Name</label>\r\n              <input \r\n                v-model=\"profile.name\" \r\n                type=\"text\" \r\n                class=\"form-control\"\r\n                placeholder=\"Enter your name\"\r\n              />\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <label>Email Address</label>\r\n              <input \r\n                v-model=\"profile.email\" \r\n                type=\"email\" \r\n                class=\"form-control\"\r\n                placeholder=\"Enter your email\"\r\n              />\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <label>Hourly Rate ($)</label>\r\n              <input \r\n                v-model=\"profile.hourlyRate\" \r\n                type=\"number\" \r\n                class=\"form-control\"\r\n                step=\"0.01\"\r\n                placeholder=\"30.00\"\r\n              />\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"form-section\">\r\n            <h3>Preferences</h3>\r\n            \r\n            <div class=\"form-group\">\r\n              <label>Currency</label>\r\n              <select v-model=\"profile.currency\" class=\"form-select\">\r\n                <option value=\"USD\">USD ($)</option>\r\n                <option value=\"EUR\">EUR (€)</option>\r\n                <option value=\"GBP\">GBP (£)</option>\r\n                <option value=\"CAD\">CAD ($)</option>\r\n              </select>\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <label>Timezone</label>\r\n              <select v-model=\"profile.timezone\" class=\"form-select\">\r\n                <option value=\"America/New_York\">Eastern Time (ET)</option>\r\n                <option value=\"America/Chicago\">Central Time (CT)</option>\r\n                <option value=\"America/Denver\">Mountain Time (MT)</option>\r\n                <option value=\"America/Los_Angeles\">Pacific Time (PT)</option>\r\n              </select>\r\n            </div>\r\n            \r\n            <div class=\"form-group\">\r\n              <div class=\"checkbox-group\">\r\n                <input \r\n                  v-model=\"profile.emailNotifications\" \r\n                  type=\"checkbox\" \r\n                  id=\"emailNotifications\"\r\n                />\r\n                <label for=\"emailNotifications\">\r\n                  Email notifications for goal achievements\r\n                </label>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"form-actions\">\r\n            <button type=\"submit\" class=\"btn btn-primary btn-lg\">\r\n              <i class=\"bi bi-check-circle\"></i>\r\n              Save Changes\r\n            </button>\r\n          </div>\r\n        </form>\r\n      </div>\r\n\r\n      <div class=\"security-card\">\r\n        <h3>Security</h3>\r\n        <p>Update your password to keep your account secure</p>\r\n        \r\n        <form @submit.prevent=\"updatePassword\" class=\"password-form\">\r\n          <div class=\"form-group\">\r\n            <label>Current Password</label>\r\n            <input \r\n              v-model=\"passwordForm.current\" \r\n              type=\"password\" \r\n              class=\"form-control\"\r\n              placeholder=\"Enter current password\"\r\n            />\r\n          </div>\r\n          \r\n          <div class=\"form-group\">\r\n            <label>New Password</label>\r\n            <input \r\n              v-model=\"passwordForm.new\" \r\n              type=\"password\" \r\n              class=\"form-control\"\r\n              placeholder=\"Enter new password\"\r\n            />\r\n          </div>\r\n          \r\n          <div class=\"form-group\">\r\n            <label>Confirm New Password</label>\r\n            <input \r\n              v-model=\"passwordForm.confirm\" \r\n              type=\"password\" \r\n              class=\"form-control\"\r\n              placeholder=\"Confirm new password\"\r\n            />\r\n          </div>\r\n          \r\n          <button type=\"submit\" class=\"btn btn-secondary\">\r\n            <i class=\"bi bi-shield-check\"></i>\r\n            Update Password\r\n          </button>\r\n        </form>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref, onMounted } from 'vue'\r\nimport { useAuthStore } from '../stores/auth'\r\nimport { useToast } from 'vue-toastification'\r\n\r\nconst authStore = useAuthStore()\r\nconst toast = useToast()\r\n\r\nconst profile = ref({\r\n  name: '',\r\n  email: '',\r\n  hourlyRate: 30,\r\n  currency: 'USD',\r\n  timezone: 'America/New_York',\r\n  emailNotifications: true\r\n})\r\n\r\nconst passwordForm = ref({\r\n  current: '',\r\n  new: '',\r\n  confirm: ''\r\n})\r\n\r\nconst updateProfile = () => {\r\n  toast.success('Profile updated successfully!')\r\n  // TODO: Call API to update profile\r\n}\r\n\r\nconst updatePassword = () => {\r\n  if (passwordForm.value.new !== passwordForm.value.confirm) {\r\n    toast.error('Passwords do not match!')\r\n    return\r\n  }\r\n  \r\n  toast.success('Password updated successfully!')\r\n  passwordForm.value = { current: '', new: '', confirm: '' }\r\n  // TODO: Call API to update password\r\n}\r\n\r\nonMounted(() => {\r\n  if (authStore.user) {\r\n    profile.value.name = authStore.user.name\r\n    profile.value.email = authStore.user.email\r\n    profile.value.hourlyRate = authStore.user.hourlyRate || 30\r\n  }\r\n})\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.profile-page {\r\n  max-width: 900px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.page-header {\r\n  margin-bottom: var(--spacing-xl);\r\n  \r\n  h1 {\r\n    font-size: 2rem;\r\n    font-weight: 800;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-xs);\r\n  }\r\n  \r\n  p {\r\n    color: var(--text-secondary);\r\n  }\r\n}\r\n\r\n.profile-content {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: var(--spacing-xl);\r\n}\r\n\r\n.profile-card,\r\n.security-card {\r\n  background: var(--bg-primary);\r\n  border-radius: var(--radius-lg);\r\n  padding: var(--spacing-xl);\r\n  box-shadow: var(--shadow-sm);\r\n}\r\n\r\n.avatar-section {\r\n  text-align: center;\r\n  margin-bottom: var(--spacing-2xl);\r\n  \r\n  .avatar-wrapper {\r\n    position: relative;\r\n    display: inline-block;\r\n    \r\n    .avatar {\r\n      width: 120px;\r\n      height: 120px;\r\n      border-radius: 50%;\r\n      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n      color: white;\r\n      font-size: 4rem;\r\n      box-shadow: var(--shadow-lg);\r\n    }\r\n    \r\n    .avatar-btn {\r\n      position: absolute;\r\n      bottom: 0;\r\n      right: 0;\r\n      width: 36px;\r\n      height: 36px;\r\n      border-radius: 50%;\r\n      padding: 0;\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: center;\r\n    }\r\n  }\r\n}\r\n\r\n.profile-form,\r\n.password-form {\r\n  .form-section {\r\n    margin-bottom: var(--spacing-2xl);\r\n    \r\n    h3 {\r\n      font-size: 1.25rem;\r\n      font-weight: 700;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-lg);\r\n      padding-bottom: var(--spacing-sm);\r\n      border-bottom: 2px solid var(--border-color);\r\n    }\r\n  }\r\n  \r\n  .form-group {\r\n    margin-bottom: var(--spacing-lg);\r\n    \r\n    label {\r\n      display: block;\r\n      font-weight: 600;\r\n      color: var(--text-primary);\r\n      margin-bottom: var(--spacing-sm);\r\n    }\r\n  }\r\n  \r\n  .checkbox-group {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: var(--spacing-sm);\r\n    \r\n    input[type=\"checkbox\"] {\r\n      width: 20px;\r\n      height: 20px;\r\n    }\r\n    \r\n    label {\r\n      margin: 0;\r\n      font-weight: 400;\r\n      cursor: pointer;\r\n    }\r\n  }\r\n  \r\n  .form-actions {\r\n    padding-top: var(--spacing-lg);\r\n    border-top: 1px solid var(--border-color);\r\n  }\r\n}\r\n\r\n.security-card {\r\n  h3 {\r\n    font-size: 1.25rem;\r\n    font-weight: 700;\r\n    color: var(--text-primary);\r\n    margin-bottom: var(--spacing-xs);\r\n  }\r\n  \r\n  p {\r\n    color: var(--text-secondary);\r\n    margin-bottom: var(--spacing-xl);\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .page-header h1 {\r\n    font-size: 1.5rem;\r\n  }\r\n  \r\n  .profile-card,\r\n  .security-card {\r\n    padding: var(--spacing-lg);\r\n  }\r\n}\r\n</style>\r\n"],"mappings":"AAyKA,SAASA,GAAG,EAAEC,SAAS,QAAQ,KAAK;AACpC,SAASC,YAAY,QAAQ,gBAAgB;AAC7C,SAASC,QAAQ,QAAQ,oBAAoB;;;;;;;IAE7C,MAAMC,SAAS,GAAGF,YAAY,CAAC,CAAC;IAChC,MAAMG,KAAK,GAAGF,QAAQ,CAAC,CAAC;IAExB,MAAMG,OAAO,GAAGN,GAAG,CAAC;MAClBO,IAAI,EAAE,EAAE;MACRC,KAAK,EAAE,EAAE;MACTC,UAAU,EAAE,EAAE;MACdC,QAAQ,EAAE,KAAK;MACfC,QAAQ,EAAE,kBAAkB;MAC5BC,kBAAkB,EAAE;IACtB,CAAC,CAAC;IAEF,MAAMC,YAAY,GAAGb,GAAG,CAAC;MACvBc,OAAO,EAAE,EAAE;MACXC,GAAG,EAAE,EAAE;MACPC,OAAO,EAAE;IACX,CAAC,CAAC;IAEF,MAAMC,aAAa,GAAGA,CAAA,KAAM;MAC1BZ,KAAK,CAACa,OAAO,CAAC,+BAA+B,CAAC;MAC9C;IACF,CAAC;IAED,MAAMC,cAAc,GAAGA,CAAA,KAAM;MAC3B,IAAIN,YAAY,CAACO,KAAK,CAACL,GAAG,KAAKF,YAAY,CAACO,KAAK,CAACJ,OAAO,EAAE;QACzDX,KAAK,CAACgB,KAAK,CAAC,yBAAyB,CAAC;QACtC;MACF;MAEAhB,KAAK,CAACa,OAAO,CAAC,gCAAgC,CAAC;MAC/CL,YAAY,CAACO,KAAK,GAAG;QAAEN,OAAO,EAAE,EAAE;QAAEC,GAAG,EAAE,EAAE;QAAEC,OAAO,EAAE;MAAG,CAAC;MAC1D;IACF,CAAC;IAEDf,SAAS,CAAC,MAAM;MACd,IAAIG,SAAS,CAACkB,IAAI,EAAE;QAClBhB,OAAO,CAACc,KAAK,CAACb,IAAI,GAAGH,SAAS,CAACkB,IAAI,CAACf,IAAI;QACxCD,OAAO,CAACc,KAAK,CAACZ,KAAK,GAAGJ,SAAS,CAACkB,IAAI,CAACd,KAAK;QAC1CF,OAAO,CAACc,KAAK,CAACX,UAAU,GAAGL,SAAS,CAACkB,IAAI,CAACb,UAAU,IAAI,EAAE;MAC5D;IACF,CAAC,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}