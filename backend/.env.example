# MongoDB Configuration (Production - MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/jobanalytics?retryWrites=true&w=majority

# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production

# CORS Origins (comma-separated for multiple origins)
# Development: http://localhost:8080
# Production: https://your-app-name.netlify.app,https://your-backend-app.onrender.com
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# Rate Limiting (Optional)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
